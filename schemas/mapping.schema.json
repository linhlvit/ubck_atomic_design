{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ubck-atomic-design.local/schemas/mapping.schema.json",
  "title": "Mapping Design Schema",
  "description": "Schema định nghĩa định dạng YAML cho Mapping spec — ánh xạ từ Bronze source table sang Atomic entity. Dùng để validate và parse các file mapping_atm_*.yaml trong thư mục Mapping/Atomic/.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_type",
    "schema_version",
    "mapping",
    "target",
    "input",
    "relationship",
    "mapping_columns",
    "final_filter"
  ],
  "if": {
    "properties": {
      "mapping": {
        "properties": {
          "pattern": {
            "const": "unpivot"
          }
        }
      }
    }
  },
  "then": {
    "required": [
      "mapping_legs"
    ]
  },
  "properties": {
    "schema_type": {
      "type": "string",
      "const": "mapping",
      "description": "Khai báo loại schema — dùng để xác định file type"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$",
      "description": "Phiên bản schema (semantic versioning)"
    },
    "mapping": {
      "$ref": "#/definitions/mapping_header"
    },
    "target": {
      "$ref": "#/definitions/target"
    },
    "input": {
      "type": "array",
      "minItems": 1,
      "description": "Danh sách bảng/CTE nguồn (physical_table, derived_cte, unpivot_cte)",
      "items": {
        "$ref": "#/definitions/input_source"
      }
    },
    "relationship": {
      "type": "array",
      "description": "Danh sách JOIN giữa các bảng/CTE nguồn. Để trống [] nếu không có JOIN.",
      "items": {
        "$ref": "#/definitions/relationship_item"
      }
    },
    "mapping_columns": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "description": "Danh sách mapping cột cho pattern regular",
          "items": {
            "$ref": "#/definitions/mapping_column"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "mapping_legs": {
      "type": "array",
      "minItems": 1,
      "description": "Danh sách legs cho pattern unpivot — mỗi leg là 1 loại giấy tờ/nhóm cột",
      "items": {
        "$ref": "#/definitions/mapping_leg"
      }
    },
    "transformation_rules_ref": {
      "type": "string",
      "description": "Đường dẫn tương đối đến file shared transformation rules. Mặc định: Mapping/rules/transformation_rules.yaml"
    },
    "final_filter": {
      "type": "array",
      "description": "Danh sách mệnh đề WHERE / UNION ALL cuối transform. Để trống [] nếu không có.",
      "items": {
        "$ref": "#/definitions/final_filter_item"
      }
    }
  },
  "definitions": {
    "mapping_header": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "logical_name",
        "physical_name",
        "pattern",
        "dm_ref",
        "brd_ref"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^MAP-ATM-[a-z][a-z0-9_]*-[A-Za-z][A-Za-z0-9_.]*$",
          "description": "Định danh duy nhất: MAP-ATM-{physical_name}-{SOURCE}.{TABLE}"
        },
        "logical_name": {
          "type": "string",
          "minLength": 10,
          "description": "Tên đầy đủ — thường là 'Mapping Atomic - {Entity} – source {SOURCE}.{TABLE}'"
        },
        "physical_name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Tên bảng Atomic đích (snake_case)"
        },
        "pattern": {
          "type": "string",
          "enum": [
            "regular",
            "unpivot",
            "direct",
            "shared_entity"
          ],
          "description": "Loại mapping pattern. regular=1 source+JOIN, unpivot=LATERAL VIEW/UNION ALL legs, direct=1 source không JOIN, shared_entity=multi-source UNION ALL"
        },
        "dm_ref": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^ATM-[a-z][a-z0-9_]*-[A-Za-z][A-Za-z0-9_.]*$",
              "description": "Tham chiếu đến DM YAML id — single source"
            },
            {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "string",
                "pattern": "^ATM-[a-z][a-z0-9_]*-[A-Za-z][A-Za-z0-9_.]*$"
              },
              "description": "Tham chiếu đến nhiều DM YAML id — multi-source shared entity"
            }
          ]
        },
        "brd_ref": {
          "type": "string",
          "pattern": "^BRD-SRC-[A-Za-z][A-Za-z0-9_-]*-[A-Za-z][A-Za-z0-9_]*$",
          "description": "Tham chiếu BRD entry tương ứng"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "physical_name",
        "etl_handle",
        "description"
      ],
      "properties": {
        "schema": {
          "type": "string",
          "const": "atomic",
          "description": "Schema đích — luôn là 'atomic'"
        },
        "physical_name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Tên bảng Atomic đích (snake_case) — dùng cho ETL job generation"
        },
        "etl_handle": {
          "type": "string",
          "enum": [
            "SCD4A",
            "SCD2",
            "Fact Append",
            "Upsert"
          ],
          "description": "ETL handle — định nghĩa cách xử lý dữ liệu trên Atomic (SCD4A/SCD2 cho dimension, Fact Append cho fact, Upsert cho classification value)"
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "description": "Mô tả nghiệp vụ của mapping"
        }
      }
    },
    "input_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "table_name",
        "alias",
        "select_fields"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "physical_table",
            "derived_cte",
            "unpivot_cte"
          ],
          "description": "Loại nguồn: physical_table (bảng Bronze thực tế), derived_cte (CTE tính toán), unpivot_cte (LATERAL VIEW stack)"
        },
        "schema": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "bronze"
              ]
            },
            {
              "type": "null"
            }
          ],
          "description": "Schema Bronze — null nếu là CTE"
        },
        "table_name": {
          "type": "string",
          "minLength": 1,
          "description": "Tên bảng nguồn hoặc alias CTE đầu vào"
        },
        "alias": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Alias dùng trong query"
        },
        "select_fields": {
          "type": "string",
          "minLength": 1,
          "description": "Danh sách cột select hoặc LATERAL VIEW expression"
        },
        "filter": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ],
          "description": "Điều kiện filter (WHERE) hoặc GROUP BY. Null nếu không có."
        },
        "note": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ],
          "description": "Ghi chú bổ sung về input source"
        }
      }
    },
    "relationship_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "main_alias",
        "join_type",
        "join_alias",
        "join_on"
      ],
      "properties": {
        "main_alias": {
          "type": "string",
          "description": "Alias của bảng/CTE chính (left side)"
        },
        "join_type": {
          "type": "string",
          "enum": [
            "INNER JOIN",
            "LEFT JOIN",
            "RIGHT JOIN",
            "FULL OUTER JOIN"
          ],
          "description": "Loại JOIN"
        },
        "join_alias": {
          "type": "string",
          "description": "Alias của bảng/CTE JOIN vào (right side)"
        },
        "join_on": {
          "type": "string",
          "minLength": 1,
          "description": "Điều kiện JOIN"
        }
      }
    },
    "mapping_column": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_column",
        "transformation",
        "data_type",
        "description"
      ],
      "properties": {
        "target_column": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Tên cột Atomic đích (snake_case)"
        },
        "transformation": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ],
          "description": "Biểu thức transformation. Null nếu chưa xác định."
        },
        "data_type": {
          "type": "string",
          "enum": [
            "string",
            "date",
            "timestamp",
            "boolean",
            "int",
            "decimal(23,2)",
            "decimal(5,2)",
            "decimal(8,5)",
            "array<string>",
            "array<struct<...>>"
          ],
          "description": "Kiểu dữ liệu đích (Delta Lake / Spark)"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Mô tả nghiệp vụ của cột"
        }
      }
    },
    "mapping_leg": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "leg",
        "mapping_columns"
      ],
      "properties": {
        "leg": {
          "type": "string",
          "minLength": 1,
          "description": "Tên leg — thường là identification_type_code value (VD: BUSINESS_LICENSE)"
        },
        "filter": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ],
          "description": "Điều kiện filter riêng cho leg này"
        },
        "comment": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ],
          "description": "Ghi chú kỹ thuật cho leg"
        },
        "mapping_columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/leg_column"
          }
        }
      }
    },
    "leg_column": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_column",
        "transformation",
        "source_column",
        "data_type"
      ],
      "properties": {
        "target_column": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Tên cột Atomic đích (snake_case)"
        },
        "transformation": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ],
          "description": "Biểu thức transformation. Null nếu chưa xác định."
        },
        "source_column": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "pattern": "^[A-Za-z][A-Za-z0-9_]*\\.[A-Za-z][A-Za-z0-9_]*\\.[A-Za-z][A-Za-z0-9_.]*$",
              "description": "Format: SYSTEM.TABLE.column"
            }
          ]
        },
        "data_type": {
          "type": "string",
          "enum": [
            "string",
            "date",
            "timestamp",
            "boolean",
            "int",
            "decimal(23,2)",
            "decimal(5,2)",
            "decimal(8,5)",
            "array<string>",
            "array<struct<...>>"
          ]
        },
        "etl_derived_value": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ],
          "description": "Giá trị hardcode ETL-derived — null nếu map thẳng từ source"
        },
        "comment": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ],
          "description": "Ghi chú kỹ thuật"
        }
      }
    },
    "final_filter_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clause_type",
        "expression"
      ],
      "properties": {
        "clause_type": {
          "type": "string",
          "enum": [
            "WHERE",
            "UNION ALL",
            "GROUP BY",
            "HAVING",
            "ORDER BY"
          ],
          "description": "Loại mệnh đề"
        },
        "expression": {
          "type": "string",
          "minLength": 1,
          "description": "Nội dung mệnh đề"
        },
        "description": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ],
          "description": "Mô tả mục đích"
        }
      }
    }
  }
}