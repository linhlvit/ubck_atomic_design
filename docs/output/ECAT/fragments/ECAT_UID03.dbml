// ECAT — UID03 Danh mục tiền tệ

Project ECAT_UID03 {
  database_type: "Delta Lake"
  Note: "ECAT — UID03 Danh mục tiền tệ"
}

Table "ccy" [note: "Đơn vị tiền tệ theo chuẩn ISO 4217. ECAT là source chuẩn (authoritative). Currency là data domain riêng theo quy tắc #4 — không có surrogate key, BK = currency_code 3 ký tự."] {
  "ccy_code" varchar [pk]
}

