// Silver Lakehouse — ECAT

Project ECAT {
  database_type: "Delta Lake"
  Note: "Silver Lakehouse — ECAT"
}

Table "Geographic Area" [note: "Đơn vị địa lý dùng làm FK tham chiếu: quốc gia/quốc tịch (COUNTRY), vùng/miền (REGION), tỉnh/thành phố mới/cũ (PROVINCE/PROVINCE_OLD), quận/huyện cũ (DISTRICT_OLD), phường/xã mới/cũ (WARD/WARD_OLD). P"] {
  "Geographic Area Id" varchar [pk]
  "Parent Geographic Area Id" varchar
}

Table "Currency" [note: ""] {
  "Currency Id" varchar [pk]
}

Table "Security" [note: ""] {
  "Security Id" varchar [pk]
}

Table "Calendar Date" [note: ""] {
  "Calendar Date Id" varchar [pk]
}

TableGroup "UID01 — Danh mục địa lý hành chính" {
  "Geographic Area"
}

TableGroup "UID03 — Danh mục tiền tệ" {
  "Currency"
}

TableGroup "UID04 — Danh mục chứng khoán & thị trường" {
  "Security"
}

TableGroup "UID08 — Danh mục lịch & ngày nghỉ" {
  "Calendar Date"
}

Ref: "Geographic Area"."Parent Geographic Area Id" > "Geographic Area"."Geographic Area Id"
