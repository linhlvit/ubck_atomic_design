// Atomic Lakehouse — ThanhTra

Project ThanhTra {
  database_type: "Delta Lake"
  Note: "Atomic Lakehouse — ThanhTra"
}

Table "Inspection Officer" [note: "Cán bộ thanh tra viên thuộc UBCKNN. Ghi nhận thông tin cá nhân và trạng thái công tác."] {
  "Inspection Officer Id" varchar [pk]
}

Table "Involved Party Electronic Address" [note: "Lưu trữ các địa chỉ liên lạc điện tử của Involved Party (điện thoại/fax/email). Mỗi dòng = 1 kênh liên lạc từ 1 nguồn."] {
  "Involved Party Id" varchar
}

Table "Involved Party Postal Address" [note: "Lưu trữ các địa chỉ bưu chính của Involved Party (trụ sở/kinh doanh/thường trú/nơi ở hiện tại). Mỗi dòng = 1 loại địa chỉ từ 1 nguồn."] {
  "Involved Party Id" varchar
}

Table "Public Company" [note: "Công ty đại chúng được UBCKNN quản lý. Lưu thông tin pháp lý và trạng thái hoạt động."] {
  "Public Company Id" varchar [pk]
}

Table "Securities Company" [note: "Công ty chứng khoán - thành viên thị trường trong hệ thống FIMS. Quản lý tài khoản và danh mục NĐT nước ngoài."] {
  "Securities Company Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Fund Management Company" [note: "Công ty quản lý quỹ đầu tư chứng khoán trong nước được UBCKNN cấp phép hoạt động. Lưu thông tin pháp lý và hoạt động của công ty."] {
  "Fund Management Company Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Inspection Subject Other Party" [note: "Đối tượng thanh tra khác (cá nhân hoặc tổ chức) không thuộc danh mục CK/QLQ/ĐC. Phân biệt qua party_type_code."] {
  "Inspection Subject Other Party Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Inspection Annual Plan" [note: "Kế hoạch thanh tra kiểm tra cấp năm được phê duyệt. Khởi đầu quy trình thanh tra trong năm."] {
  "Inspection Annual Plan Id" varchar [pk]
}

Table "Surveillance Enforcement Case" [note: "Hồ sơ xử lý vi phạm từ kết quả giám sát thị trường. Ghi nhận đối tượng và trạng thái xử lý."] {
  "Surveillance Enforcement Case Id" varchar [pk]
  "Responsible Officer Id" varchar
  "Processing Officer Id" varchar
}

Table "Complaint Petition" [note: "Đơn thư khiếu nại/tố cáo/phản ánh/kiến nghị nhận từ công dân hoặc tổ chức. Khởi đầu quy trình giải quyết đơn thư."] {
  "Complaint Petition Id" varchar [pk]
}

Table "AML Enforcement Case" [note: "Hồ sơ xử lý vi phạm phòng chống rửa tiền. Ghi nhận đối tượng vi phạm và trạng thái xử lý."] {
  "AML Enforcement Case Id" varchar [pk]
  "Responsible Officer Id" varchar
  "Processing Officer Id" varchar
}

Table "Anti-Corruption Report" [note: "Báo cáo tổng hợp định kỳ về hoạt động phòng chống tham nhũng. Mỗi dòng = 1 lần lập báo cáo."] {
  "Anti-Corruption Report Id" varchar [pk]
}

Table "AML Periodic Report" [note: "Báo cáo định kỳ về hoạt động phòng chống rửa tiền. Mỗi dòng = 1 lần lập báo cáo."] {
  "AML Periodic Report Id" varchar [pk]
}

Table "Inspection Annual Plan Subject" [note: "Đối tượng thanh tra được đưa vào kế hoạch năm. Grain: 1 đối tượng × 1 kế hoạch."] {
  "Inspection Annual Plan Subject Id" varchar [pk]
  "Inspection Annual Plan Id" varchar
}

Table "Inspection Annual Plan Document Attachment" [note: "Văn bản đính kèm kế hoạch thanh tra năm. FK → Inspection Annual Plan."] {
  "Inspection Annual Plan Document Attachment Id" varchar [pk]
  "Inspection Annual Plan Id" varchar
}

Table "Inspection Decision" [note: "Quyết định thanh tra/kiểm tra cụ thể. FK → Inspection Annual Plan (nullable — thanh tra đột xuất không có kế hoạch)."] {
  "Inspection Decision Id" varchar [pk]
  "Inspection Annual Plan Id" varchar
}

Table "Complaint Processing Case" [note: "Hồ sơ giải quyết đơn thư khiếu nại/tố cáo. FK → Complaint Petition."] {
  "Complaint Processing Case Id" varchar [pk]
  "Complaint Petition Id" varchar
}

Table "Surveillance Case Document Attachment" [note: "Văn bản đính kèm hồ sơ giám sát. FK → Surveillance Enforcement Case."] {
  "Surveillance Case Document Attachment Id" varchar [pk]
  "Surveillance Enforcement Case Id" varchar
}

Table "Surveillance Enforcement Decision" [note: "Văn bản xử lý vi phạm từ giám sát. FK → Surveillance Enforcement Case."] {
  "Surveillance Enforcement Decision Id" varchar [pk]
  "Surveillance Enforcement Case Id" varchar
}

Table "AML Case Document Attachment" [note: "Văn bản đính kèm hồ sơ PCRT. FK → AML Enforcement Case."] {
  "AML Case Document Attachment Id" varchar [pk]
  "AML Enforcement Case Id" varchar
}

Table "AML Enforcement Decision" [note: "Văn bản xử lý vi phạm rửa tiền. FK → AML Enforcement Case."] {
  "AML Enforcement Decision Id" varchar [pk]
  "AML Enforcement Case Id" varchar
}

Table "Inspection Decision Subject" [note: "Đối tượng cụ thể được thanh tra theo một quyết định. FK → Inspection Decision."] {
  "Inspection Decision Subject Id" varchar [pk]
  "Inspection Decision Id" varchar
}

Table "Inspection Decision Team Member" [note: "Thành viên đoàn thanh tra chỉ định theo quyết định. FK → Inspection Decision + FK → Inspection Officer."] {
  "Inspection Decision Team Member Id" varchar [pk]
  "Inspection Decision Id" varchar
  "Inspection Officer Id" varchar
}

Table "Inspection Decision Document Attachment" [note: "Văn bản đính kèm quyết định thanh tra. FK → Inspection Decision."] {
  "Inspection Decision Document Attachment Id" varchar [pk]
  "Inspection Decision Id" varchar
}

Table "Inspection Case" [note: "Hồ sơ thanh tra cụ thể — tập hợp tài liệu và kết quả 1 cuộc thanh tra. FK → Inspection Decision. Thông tin đối tượng denormalized (snapshot tại thời điểm thanh tra)."] {
  "Inspection Case Id" varchar [pk]
  "Inspection Decision Id" varchar
  "Responsible Officer Id" varchar
  "Processing Officer Id" varchar
}

Table "Complaint Processing Case Document Attachment" [note: "Văn bản đính kèm hồ sơ giải quyết đơn thư. FK → Complaint Processing Case."] {
  "Complaint Processing Case Document Attachment Id" varchar [pk]
  "Complaint Processing Case Id" varchar
}

Table "Complaint Processing Conclusion" [note: "Kết luận giải quyết đơn thư. FK → Complaint Processing Case."] {
  "Complaint Processing Conclusion Id" varchar [pk]
  "Complaint Processing Case Id" varchar
}

Table "Complaint Enforcement Decision" [note: "Văn bản xử lý / quyết định xử phạt từ hồ sơ đơn thư. FK → Complaint Processing Case."] {
  "Complaint Enforcement Decision Id" varchar [pk]
  "Complaint Processing Case Id" varchar
}

Table "Surveillance Enforcement Decision File Attachment" [note: "File đính kèm văn bản xử lý giám sát. FK → Surveillance Enforcement Decision."] {
  "Surveillance Enforcement Decision File Attachment Id" varchar [pk]
  "Surveillance Enforcement Decision Id" varchar
}

Table "Surveillance Penalty Announcement" [note: "Công bố quyết định xử phạt từ giám sát. FK → Surveillance Enforcement Decision."] {
  "Surveillance Penalty Announcement Id" varchar [pk]
  "Surveillance Enforcement Case Id" varchar
  "Surveillance Enforcement Decision Id" varchar
}

Table "Inspection Case Officer Assignment" [note: "Phân công cán bộ phụ trách hồ sơ thanh tra. FK → Inspection Case + FK → Inspection Officer."] {
  "Inspection Case Officer Assignment Id" varchar [pk]
  "Inspection Case Id" varchar
  "Inspection Officer Id" varchar
}

Table "Inspection Case Document Attachment" [note: "Văn bản đính kèm hồ sơ thanh tra (biên bản làm việc v.v.). FK → Inspection Case."] {
  "Inspection Case Document Attachment Id" varchar [pk]
  "Inspection Case Id" varchar
}

Table "Inspection Case Conclusion" [note: "Kết luận thanh tra kèm thông tin xử lý vi phạm. FK → Inspection Case."] {
  "Inspection Case Conclusion Id" varchar [pk]
  "Inspection Case Id" varchar
}

Table "Complaint Penalty Announcement" [note: "Công bố quyết định xử phạt từ hồ sơ đơn thư. FK → Complaint Enforcement Decision."] {
  "Complaint Penalty Announcement Id" varchar [pk]
  "Complaint Processing Case Id" varchar
  "Complaint Enforcement Decision Id" varchar
}

Table "Inspection Penalty Announcement" [note: "Công bố quyết định xử phạt từ kết luận thanh tra. FK → Inspection Case Conclusion."] {
  "Inspection Penalty Announcement Id" varchar [pk]
  "Inspection Case Id" varchar
  "Inspection Case Conclusion Id" varchar
}

TableGroup "UID01 — Hoạt động thanh tra - kiểm tra" {
  "Public Company"
  "Securities Company"
  "Fund Management Company"
  "Inspection Subject Other Party"
  "Inspection Annual Plan"
  "Inspection Annual Plan Subject"
  "Inspection Annual Plan Document Attachment"
  "Inspection Decision"
  "Inspection Decision Subject"
  "Inspection Decision Team Member"
  "Inspection Decision Document Attachment"
  "Inspection Case"
  "Inspection Case Officer Assignment"
  "Inspection Case Document Attachment"
  "Inspection Case Conclusion"
  "Inspection Penalty Announcement"
}

TableGroup "UID02 — Xử lý vi phạm hành chính" {
  "Surveillance Enforcement Case"
  "Surveillance Case Document Attachment"
  "Surveillance Enforcement Decision"
  "Surveillance Enforcement Decision File Attachment"
  "Surveillance Penalty Announcement"
}

TableGroup "UID03 — Tiếp công dân, xử lý đơn thư" {
  "Complaint Petition"
  "Complaint Processing Case"
  "Complaint Processing Case Document Attachment"
  "Complaint Processing Conclusion"
  "Complaint Enforcement Decision"
  "Complaint Penalty Announcement"
}

TableGroup "UID04 — Phòng chống tham nhũng, tiêu cực" {
  "Anti-Corruption Report"
}

TableGroup "UID05 — Phòng chống rửa tiền, tài trợ khủng bố" {
  "AML Enforcement Case"
  "AML Periodic Report"
  "AML Case Document Attachment"
  "AML Enforcement Decision"
}

TableGroup "UID08 — Quản trị phân hệ" {
  "Inspection Officer"
  "Public Company"
  "Securities Company"
  "Fund Management Company"
  "Inspection Subject Other Party"
}

Ref: "Involved Party Electronic Address"."Involved Party Id" > "Inspection Officer"."Inspection Officer Id"
Ref: "Involved Party Postal Address"."Involved Party Id" > "Inspection Officer"."Inspection Officer Id"
Ref: "Involved Party Electronic Address"."Involved Party Id" > "Public Company"."Public Company Id"
Ref: "Involved Party Postal Address"."Involved Party Id" > "Public Company"."Public Company Id"
