// ThanhTra — UID03 Tiếp công dân, xử lý đơn thư

Project ThanhTra_UID03 {
  database_type: "Delta Lake"
  Note: "ThanhTra — UID03 Tiếp công dân, xử lý đơn thư"
}

Table "cpln_nfrc_dcsn" [note: "Văn bản xử lý / quyết định xử phạt từ hồ sơ đơn thư. FK → Complaint Processing Case."] {
  "cpln_nfrc_dcsn_id" varchar [pk]
  "cpln_pcs_case_id" varchar
}

Table "cpln_pny_ancm" [note: "Công bố quyết định xử phạt từ hồ sơ đơn thư. FK → Complaint Enforcement Decision."] {
  "cpln_pny_ancm_id" varchar [pk]
  "cpln_pcs_case_id" varchar
  "cpln_nfrc_dcsn_id" varchar
}

Table "cpln_petition" [note: "Đơn thư khiếu nại/tố cáo/phản ánh/kiến nghị nhận từ công dân hoặc tổ chức. Khởi đầu quy trình giải quyết đơn thư."] {
  "cpln_petition_id" varchar [pk]
}

Table "cpln_pcs_case" [note: "Hồ sơ giải quyết đơn thư khiếu nại/tố cáo. FK → Complaint Petition."] {
  "cpln_pcs_case_id" varchar [pk]
  "cpln_petition_id" varchar
}

Table "cpln_pcs_conclusion" [note: "Kết luận giải quyết đơn thư. FK → Complaint Processing Case."] {
  "cpln_pcs_conclusion_id" varchar [pk]
  "cpln_pcs_case_id" varchar
}

Table "cpln_pcs_case_doc_attch" [note: "Văn bản đính kèm hồ sơ giải quyết đơn thư. FK → Complaint Processing Case."] {
  "cpln_pcs_case_doc_attch_id" varchar [pk]
  "cpln_pcs_case_id" varchar
}

Ref: "cpln_nfrc_dcsn"."cpln_pcs_case_id" > "cpln_pcs_case"."cpln_pcs_case_id"
Ref: "cpln_pny_ancm"."cpln_pcs_case_id" > "cpln_pcs_case"."cpln_pcs_case_id"
Ref: "cpln_pny_ancm"."cpln_nfrc_dcsn_id" > "cpln_nfrc_dcsn"."cpln_nfrc_dcsn_id"
Ref: "cpln_pcs_case"."cpln_petition_id" > "cpln_petition"."cpln_petition_id"
Ref: "cpln_pcs_conclusion"."cpln_pcs_case_id" > "cpln_pcs_case"."cpln_pcs_case_id"
Ref: "cpln_pcs_case_doc_attch"."cpln_pcs_case_id" > "cpln_pcs_case"."cpln_pcs_case_id"
