// ThanhTra — UID08 Quản trị phân hệ

Project ThanhTra_UID08 {
  database_type: "Delta Lake"
  Note: "ThanhTra — UID08 Quản trị phân hệ"
}

Table "fnd_mgt_co" [note: "Công ty quản lý quỹ đầu tư chứng khoán trong nước được UBCKNN cấp phép hoạt động. Lưu thông tin pháp lý và hoạt động của công ty."] {
  "fnd_mgt_co_id" varchar [pk]
  "cty_of_rgst_id" varchar
}

Table "insp_ofcr" [note: "Cán bộ thanh tra viên thuộc UBCKNN. Ghi nhận thông tin cá nhân và trạng thái công tác."] {
  "insp_ofcr_id" varchar [pk]
}

Table "insp_sbj_othr_p" [note: "Đối tượng thanh tra khác (cá nhân hoặc tổ chức) không thuộc danh mục CK/QLQ/ĐC. Phân biệt qua party_type_code."] {
  "insp_sbj_othr_p_id" varchar [pk]
  "cty_of_rgst_id" varchar
}

Table "pblc_co" [note: "Công ty đại chúng được UBCKNN quản lý. Lưu thông tin pháp lý và trạng thái hoạt động."] {
  "pblc_co_id" varchar [pk]
}

Table "scr_co" [note: "Công ty chứng khoán - thành viên thị trường trong hệ thống FIMS. Quản lý tài khoản và danh mục NĐT nước ngoài."] {
  "scr_co_id" varchar [pk]
  "cty_of_rgst_id" varchar
}

// Ref: "fnd_mgt_co"."cty_of_rgst_id" > ""."" // out-of-source
// Ref: "insp_sbj_othr_p"."cty_of_rgst_id" > ""."" // out-of-source
// Ref: "scr_co"."cty_of_rgst_id" > ""."" // out-of-source
