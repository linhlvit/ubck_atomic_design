// FMS — UID06 Đánh giá xếp loại và cảnh báo

Project FMS_UID06 {
  database_type: "Delta Lake"
  Note: "FMS — UID06 Đánh giá xếp loại và cảnh báo"
}

Table "mbr_rtg_prd" [note: "Kỳ đánh giá xếp loại định kỳ cho các thành viên thị trường (công ty quản lý quỹ). Xác định phạm vi thời gian áp dụng tiêu chí chấm điểm."] {
  "mbr_rtg_prd_id" varchar [pk]
}

Table "rtg_criterion" [note: "Tiêu chí chấm điểm đánh giá xếp loại thành viên thị trường. Lưu tên tiêu chí và điểm tối đa/trọng số. Có cấu trúc cha/con."] {
  "rtg_criterion_id" varchar [pk]
  "prn_rtg_criterion_id" varchar
}

Table "mbr_rtg" [note: "Kết quả xếp loại của một công ty quản lý quỹ trong một kỳ đánh giá. Ghi nhận điểm tổng hợp và hạng xếp loại."] {
  "mbr_rtg_id" varchar [pk]
  "fnd_mgt_co_id" varchar
  "mbr_rtg_prd_id" varchar
}

Ref: "rtg_criterion"."prn_rtg_criterion_id" > "rtg_criterion"."rtg_criterion_id"
// Ref: "mbr_rtg"."fnd_mgt_co_id" > ""."" // out-of-source
Ref: "mbr_rtg"."mbr_rtg_prd_id" > "mbr_rtg_prd"."mbr_rtg_prd_id"
