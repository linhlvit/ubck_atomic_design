// FMS — UID03 Thông tin thành viên — Công ty QLQ

Project FMS_UID03 {
  database_type: "Delta Lake"
  Note: "FMS — UID03 Thông tin thành viên — Công ty QLQ"
}

Table "Fund Management Company" [note: "Công ty quản lý quỹ đầu tư chứng khoán trong nước được UBCKNN cấp phép hoạt động. Lưu thông tin pháp lý và hoạt động của công ty."] {
  "Fund Management Company Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Foreign Fund Management Organization Unit Staff" [note: "Nhân sự đảm nhận chức vụ tại văn phòng đại diện/chi nhánh công ty quản lý quỹ nước ngoài. Ghi nhận vai trò và tư cách pháp lý."] {
  "Foreign Fund Management Organization Unit Staff Id" varchar [pk]
  "Foreign Fund Management Organization Unit Id" varchar
  "Fund Management Company Key Person Id" varchar
}

// Ref: "Fund Management Company"."Country of Registration Id" > "Geographic Area"."Geographic Area Id" // out-of-source
// Ref: "Foreign Fund Management Organization Unit Staff"."Foreign Fund Management Organization Unit Id" > "Foreign Fund Management Organization Unit"."Foreign Fund Management Organization Unit Id" // out-of-source
// Ref: "Foreign Fund Management Organization Unit Staff"."Fund Management Company Key Person Id" > "Fund Management Company Key Person"."Fund Management Company Key Person Id" // out-of-source
