Table "fnd_mgt_co" [note: "Công ty quản lý quỹ đầu tư chứng khoán trong nước được UBCKNN cấp phép hoạt động. Lưu thông tin pháp lý và hoạt động của công ty."] {
  "fnd_mgt_co_id" varchar [pk]
  "cty_of_rgst_id" varchar
}

