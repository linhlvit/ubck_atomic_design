// Atomic Lakehouse — FMS

Project FMS {
  database_type: "Delta Lake"
  Note: "Atomic Lakehouse — FMS"
}

Table "dscr_ivsm_ac" [note: "Tài khoản đầu tư ủy thác — hợp đồng dịch vụ quản lý danh mục tài chính giữa nhà đầu tư ủy thác và công ty quản lý quỹ."] {
  "dscr_ivsm_ac_id" varchar [pk]
  "dscr_ivsm_ivsr_id" varchar
}

Table "fnd_mgt_conduct_vln" [note: "Vi phạm pháp luật hoặc hành chính của công ty quản lý quỹ hoặc quỹ đầu tư. Ghi nhận loại vi phạm và trạng thái xử lý."] {
  "fnd_mgt_conduct_vln_id" varchar [pk]
  "fnd_mgt_co_id" varchar
  "ivsm_fnd_id" varchar
}

Table "ivsm_fnd_ivsr_cptl_chg_log" [note: "Lịch sử thay đổi phần vốn góp của nhà đầu tư trong quỹ đầu tư. Ghi nhận vốn trước/sau và lý do thay đổi."] {
  "ivsm_fnd_ivsr_cptl_chg_log_id" varchar [pk]
  "ivsm_fnd_ivsr_mbr_id" varchar
}

Table "mbr_prd_rpt_st_log" [note: "Nhật ký thay đổi trạng thái của báo cáo định kỳ thành viên. Mỗi dòng ghi nhận một lần thay đổi trạng thái kèm nội dung tóm tắt."] {
  "mbr_prd_rpt_hist_id" varchar [pk]
  "mbr_prd_rpt_id" varchar
  "changed_by_ofcr_id" varchar
}

Table "mbr_prd_rpt" [note: "Báo cáo định kỳ do thành viên thị trường nộp lên UBCKNN theo từng kỳ báo cáo. Ghi nhận trạng thái nộp và thời hạn."] {
  "mbr_prd_rpt_id" varchar [pk]
  "fnd_mgt_co_id" varchar
  "ivsm_fnd_id" varchar
  "cstd_bnk_id" varchar
  "frgn_fnd_mgt_ou_id" varchar
  "rpt_tpl_id" varchar
  "rpt_prd_id" varchar
  "scr_co_id" varchar
  "rpt_subm_shd_id" varchar
}

Table "mbr_rtg_prd" [note: "Kỳ đánh giá xếp loại định kỳ cho các thành viên thị trường (công ty quản lý quỹ). Xác định phạm vi thời gian áp dụng tiêu chí chấm điểm."] {
  "mbr_rtg_prd_id" varchar [pk]
}

Table "rtg_criterion" [note: "Tiêu chí chấm điểm đánh giá xếp loại thành viên thị trường. Lưu tên tiêu chí và điểm tối đa/trọng số. Có cấu trúc cha/con."] {
  "rtg_criterion_id" varchar [pk]
  "prn_rtg_criterion_id" varchar
}

Table "rpt_prd" [note: "Kỳ báo cáo định kỳ (ngày/tuần/tháng/quý/bán niên/năm) mà thành viên thị trường phải nộp báo cáo lên UBCKNN."] {
  "rpt_prd_id" varchar [pk]
  "rpt_tpl_id" varchar
}

Table "rpt_impr_val" [note: "Dữ liệu giá trị từng ô chỉ tiêu trong sheet báo cáo được import vào hệ thống FMS. Grain ở mức cell-level."] {
  "mbr_rpt_val_id" varchar [pk]
  "mbr_prd_rpt_id" varchar
  "fnd_mgt_co_id" varchar
  "ivsm_fnd_id" varchar
  "cstd_bnk_id" varchar
  "frgn_fnd_mgt_ou_id" varchar
  "rpt_prd_id" varchar
}

Table "cstd_bnk" [note: "Ngân hàng lưu ký giám sát tài sản quỹ đầu tư chứng khoán được UBCKNN chấp thuận. Chịu trách nhiệm lưu giữ và giám sát tài sản của quỹ."] {
  "cstd_bnk_id" varchar [pk]
  "cty_of_rgst_id" varchar
}

Table "dscr_ivsm_ivsr" [note: "Nhà đầu tư ủy thác — cá nhân hoặc tổ chức giao tài sản cho công ty quản lý quỹ quản lý theo hợp đồng ủy thác đầu tư."] {
  "dscr_ivsm_ivsr_id" varchar [pk]
  "fnd_mgt_co_id" varchar
}

Table "frgn_fnd_mgt_ou" [note: "Văn phòng đại diện hoặc chi nhánh của công ty quản lý quỹ nước ngoài tại Việt Nam được UBCKNN chấp thuận hoạt động."] {
  "frgn_fnd_mgt_ou_id" varchar [pk]
}

Table "frgn_fnd_mgt_ou_stff" [note: "Nhân sự đảm nhận chức vụ tại văn phòng đại diện/chi nhánh công ty quản lý quỹ nước ngoài. Ghi nhận vai trò và tư cách pháp lý."] {
  "frgn_fnd_mgt_ou_stff_id" varchar [pk]
  "frgn_fnd_mgt_ou_id" varchar
  "fnd_mgt_co_key_psn_id" varchar
}

Table "fnd_dstr_agnt" [note: "Tổ chức đại lý được ủy quyền phân phối chứng chỉ quỹ đầu tư cho nhà đầu tư."] {
  "fnd_dstr_agnt_id" varchar [pk]
}

Table "fnd_dstr_agnt_ou" [note: "Chi nhánh hoặc phòng giao dịch của tổ chức đại lý phân phối quỹ đầu tư."] {
  "fnd_dstr_agnt_ou_id" varchar [pk]
  "fnd_dstr_agnt_id" varchar
}

Table "fnd_mgt_co" [note: "Công ty quản lý quỹ đầu tư chứng khoán trong nước được UBCKNN cấp phép hoạt động. Lưu thông tin pháp lý và hoạt động của công ty."] {
  "fnd_mgt_co_id" varchar [pk]
  "cty_of_rgst_id" varchar
}

Table "fnd_mgt_co_key_psn" [note: "Nhân sự chủ chốt của công ty quản lý quỹ (giám đốc/chuyên gia đầu tư/người được ủy quyền). Lưu thông tin cá nhân và chứng chỉ hành nghề."] {
  "fnd_mgt_co_key_psn_id" varchar [pk]
  "fnd_mgt_co_id" varchar
}

Table "fnd_mgt_co_ou" [note: "Chi nhánh hoặc văn phòng đại diện của công ty quản lý quỹ trong nước. Có địa chỉ và giấy phép hoạt động riêng."] {
  "fnd_mgt_co_ou_id" varchar [pk]
  "fnd_mgt_co_id" varchar
  "prn_ou_id" varchar
  "lgl_rprs_id" varchar
  "cty_of_rgst_id" varchar
}

Table "ivsm_fnd" [note: "Quỹ đầu tư chứng khoán — pháp nhân độc lập do công ty quản lý quỹ thành lập và quản lý. Lưu thông tin pháp lý và vốn của quỹ."] {
  "ivsm_fnd_id" varchar [pk]
  "fnd_mgt_co_id" varchar
}

Table "ivsm_fnd_ivsr_mbr" [note: "Quan hệ thành viên của nhà đầu tư trong một quỹ đầu tư. Lưu tỷ lệ vốn góp và trạng thái tham gia."] {
  "ivsm_fnd_ivsr_mbr_id" varchar [pk]
  "ivsm_fnd_id" varchar
  "dscr_ivsm_ivsr_id" varchar
}

Table "ivsm_fnd_rprs_board_mbr" [note: "Thành viên ban đại diện hoặc hội đồng quản trị của quỹ đầu tư. Cá nhân đảm nhận vai trò quản trị trong cơ cấu tổ chức quỹ."] {
  "ivsm_fnd_rprs_board_mbr_id" varchar [pk]
  "ivsm_fnd_id" varchar
  "fnd_mgt_co_key_psn_id" varchar
}

Table "mbr_rtg" [note: "Kết quả xếp loại của một công ty quản lý quỹ trong một kỳ đánh giá. Ghi nhận điểm tổng hợp và hạng xếp loại."] {
  "mbr_rtg_id" varchar [pk]
  "fnd_mgt_co_id" varchar
  "mbr_rtg_prd_id" varchar
}

Table "fnd_mgt_co_shr_tfr" [note: "Giao dịch chuyển nhượng cổ phần của công ty quản lý quỹ. Ghi nhận bên chuyển nhượng/nhận nhượng và giá trị giao dịch."] {
  "fnd_mgt_co_shr_tfr_id" varchar [pk]
  "fnd_mgt_co_id" varchar
}

Table "ivsm_fnd_ctf_tfr" [note: "Giao dịch mua/bán chứng chỉ quỹ của nhà đầu tư thành viên. Ghi nhận số lượng và giá giao dịch theo từng quỹ."] {
  "ivsm_fnd_ivsr_cptl_tfr_id" varchar [pk]
  "ivsm_fnd_id" varchar
  "ivsm_fnd_ivsr_mbr_id" varchar
}

Table "ip_alt_identn" [note: "Lưu trữ các giấy tờ định danh thay thế của Involved Party (CMND/CCCD/Hộ chiếu/Giấy phép kinh doanh/Chứng chỉ hành nghề). Mỗi dòng = 1 loại giấy tờ từ 1 nguồn."] {
  "ip_id" varchar
}

Table "ip_elc_adr" [note: "Lưu trữ các địa chỉ liên lạc điện tử của Involved Party (điện thoại/fax/email). Mỗi dòng = 1 kênh liên lạc từ 1 nguồn."] {
  "ip_id" varchar
}

Table "ip_pst_adr" [note: "Lưu trữ các địa chỉ bưu chính của Involved Party (trụ sở/kinh doanh/thường trú/nơi ở hiện tại). Mỗi dòng = 1 loại địa chỉ từ 1 nguồn."] {
  "ip_id" varchar
  "prov_id" varchar
  "geo_id" varchar
}

TableGroup "UID03 — Thông tin thành viên — Công ty QLQ" {
  "frgn_fnd_mgt_ou_stff"
  "fnd_mgt_co"
}

TableGroup "UID04 — Quỹ đầu tư chứng khoán" {
  "dscr_ivsm_ac"
  "ivsm_fnd_ivsr_cptl_chg_log"
  "fnd_mgt_co"
  "ivsm_fnd"
  "ivsm_fnd_ivsr_mbr"
  "ivsm_fnd_rprs_board_mbr"
  "fnd_mgt_co_shr_tfr"
  "ivsm_fnd_ctf_tfr"
}

TableGroup "UID05 — Quản lý báo cáo" {
  "mbr_prd_rpt_st_log"
  "mbr_prd_rpt"
  "rpt_prd"
  "rpt_impr_val"
}

TableGroup "UID06 — Đánh giá xếp loại và cảnh báo" {
  "mbr_rtg_prd"
  "rtg_criterion"
  "mbr_rtg"
}

TableGroup "UID07 — Tiện ích và hệ thống" {
  "fnd_mgt_conduct_vln"
}

Ref: "dscr_ivsm_ac"."dscr_ivsm_ivsr_id" > "dscr_ivsm_ivsr"."dscr_ivsm_ivsr_id"
Ref: "fnd_mgt_conduct_vln"."fnd_mgt_co_id" > "fnd_mgt_co"."fnd_mgt_co_id"
Ref: "fnd_mgt_conduct_vln"."ivsm_fnd_id" > "ivsm_fnd"."ivsm_fnd_id"
Ref: "ivsm_fnd_ivsr_cptl_chg_log"."ivsm_fnd_ivsr_mbr_id" > "ivsm_fnd_ivsr_mbr"."ivsm_fnd_ivsr_mbr_id"
Ref: "mbr_prd_rpt_st_log"."mbr_prd_rpt_id" > "mbr_prd_rpt"."mbr_prd_rpt_id"
Ref: "mbr_prd_rpt_st_log"."changed_by_ofcr_id" > "fnd_mgt_co_key_psn"."fnd_mgt_co_key_psn_id"
Ref: "mbr_prd_rpt"."fnd_mgt_co_id" > "fnd_mgt_co"."fnd_mgt_co_id"
Ref: "mbr_prd_rpt"."ivsm_fnd_id" > "ivsm_fnd"."ivsm_fnd_id"
