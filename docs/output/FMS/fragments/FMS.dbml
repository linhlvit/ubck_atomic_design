// Atomic Lakehouse — FMS

Project FMS {
  database_type: "Delta Lake"
  Note: "Atomic Lakehouse — FMS"
}

Table "Fund Management Company" [note: "Công ty quản lý quỹ đầu tư chứng khoán trong nước được UBCKNN cấp phép hoạt động. Lưu thông tin pháp lý và hoạt động của công ty."] {
  "Fund Management Company Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Involved Party Postal Address" [note: "Lưu trữ các địa chỉ bưu chính của Involved Party (trụ sở/kinh doanh/thường trú/nơi ở hiện tại). Mỗi dòng = 1 loại địa chỉ từ 1 nguồn."] {
  "Involved Party Id" varchar
  "Province Id" varchar
  "Geographic Area Id" varchar
}

Table "Involved Party Electronic Address" [note: "Lưu trữ các địa chỉ liên lạc điện tử của Involved Party (điện thoại/fax/email). Mỗi dòng = 1 kênh liên lạc từ 1 nguồn."] {
  "Involved Party Id" varchar
}

Table "Involved Party Alternative Identification" [note: "Lưu trữ các giấy tờ định danh thay thế của Involved Party (CMND/CCCD/Hộ chiếu/Giấy phép kinh doanh/Chứng chỉ hành nghề). Mỗi dòng = 1 loại giấy tờ từ 1 nguồn."] {
  "Involved Party Id" varchar
}

Table "Foreign Fund Management Organization Unit" [note: "Văn phòng đại diện hoặc chi nhánh của công ty quản lý quỹ nước ngoài tại Việt Nam được UBCKNN chấp thuận hoạt động."] {
  "Foreign Fund Management Organization Unit Id" varchar [pk]
}

Table "Custodian Bank" [note: "Ngân hàng lưu ký giám sát tài sản quỹ đầu tư chứng khoán được UBCKNN chấp thuận. Chịu trách nhiệm lưu giữ và giám sát tài sản của quỹ."] {
  "Custodian Bank Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Fund Distribution Agent" [note: "Tổ chức đại lý được ủy quyền phân phối chứng chỉ quỹ đầu tư cho nhà đầu tư."] {
  "Fund Distribution Agent Id" varchar [pk]
}

Table "Discretionary Investment Investor" [note: "Nhà đầu tư ủy thác — cá nhân hoặc tổ chức giao tài sản cho công ty quản lý quỹ quản lý theo hợp đồng ủy thác đầu tư."] {
  "Discretionary Investment Investor Id" varchar [pk]
  "Fund Management Company Id" varchar
}

Table "Reporting Period" [note: "Kỳ báo cáo định kỳ (ngày/tuần/tháng/quý/bán niên/năm) mà thành viên thị trường phải nộp báo cáo lên UBCKNN."] {
  "Reporting Period Id" varchar [pk]
  "Report Template Id" varchar
}

Table "Member Rating Period" [note: "Kỳ đánh giá xếp loại định kỳ cho các thành viên thị trường (công ty quản lý quỹ). Xác định phạm vi thời gian áp dụng tiêu chí chấm điểm."] {
  "Member Rating Period Id" varchar [pk]
}

Table "Investment Fund" [note: "Quỹ đầu tư chứng khoán — pháp nhân độc lập do công ty quản lý quỹ thành lập và quản lý. Lưu thông tin pháp lý và vốn của quỹ."] {
  "Investment Fund Id" varchar [pk]
  "Fund Management Company Id" varchar
}

Table "Fund Management Company Key Person" [note: "Nhân sự chủ chốt của công ty quản lý quỹ (giám đốc/chuyên gia đầu tư/người được ủy quyền). Lưu thông tin cá nhân và chứng chỉ hành nghề."] {
  "Fund Management Company Key Person Id" varchar [pk]
  "Fund Management Company Id" varchar
}

Table "Fund Management Company Organization Unit" [note: "Chi nhánh hoặc văn phòng đại diện của công ty quản lý quỹ trong nước. Có địa chỉ và giấy phép hoạt động riêng."] {
  "Fund Management Company Organization Unit Id" varchar [pk]
  "Fund Management Company Id" varchar
  "Parent Organization Unit Id" varchar
  "Legal Representative Id" varchar
  "Country of Registration Id" varchar
}

Table "Fund Distribution Agent Organization Unit" [note: "Chi nhánh hoặc phòng giao dịch của tổ chức đại lý phân phối quỹ đầu tư."] {
  "Fund Distribution Agent Organization Unit Id" varchar [pk]
  "Fund Distribution Agent Id" varchar
}

Table "Discretionary Investment Account" [note: "Tài khoản đầu tư ủy thác — hợp đồng dịch vụ quản lý danh mục tài chính giữa nhà đầu tư ủy thác và công ty quản lý quỹ."] {
  "Discretionary Investment Account Id" varchar [pk]
  "Discretionary Investment Investor Id" varchar
}

Table "Member Rating" [note: "Kết quả xếp loại của một công ty quản lý quỹ trong một kỳ đánh giá. Ghi nhận điểm tổng hợp và hạng xếp loại."] {
  "Member Rating Id" varchar [pk]
  "Fund Management Company Id" varchar
  "Member Rating Period Id" varchar
}

Table "Rating Criterion" [note: "Tiêu chí chấm điểm đánh giá xếp loại thành viên thị trường. Lưu tên tiêu chí và điểm tối đa/trọng số. Có cấu trúc cha/con."] {
  "Rating Criterion Id" varchar [pk]
  "Parent Rating Criterion Id" varchar
}

Table "Investment Fund Investor Membership" [note: "Quan hệ thành viên của nhà đầu tư trong một quỹ đầu tư. Lưu tỷ lệ vốn góp và trạng thái tham gia."] {
  "Investment Fund Investor Membership Id" varchar [pk]
  "Investment Fund Id" varchar
  "Discretionary Investment Investor Id" varchar
}

Table "Investment Fund Representative Board Member" [note: "Thành viên ban đại diện hoặc hội đồng quản trị của quỹ đầu tư. Cá nhân đảm nhận vai trò quản trị trong cơ cấu tổ chức quỹ."] {
  "Investment Fund Representative Board Member Id" varchar [pk]
  "Investment Fund Id" varchar
  "Fund Management Company Key Person Id" varchar
}

Table "Foreign Fund Management Organization Unit Staff" [note: "Nhân sự đảm nhận chức vụ tại văn phòng đại diện/chi nhánh công ty quản lý quỹ nước ngoài. Ghi nhận vai trò và tư cách pháp lý."] {
  "Foreign Fund Management Organization Unit Staff Id" varchar [pk]
  "Foreign Fund Management Organization Unit Id" varchar
  "Fund Management Company Key Person Id" varchar
}

Table "Member Periodic Report" [note: "Báo cáo định kỳ do thành viên thị trường nộp lên UBCKNN theo từng kỳ báo cáo. Ghi nhận trạng thái nộp và thời hạn."] {
  "Member Periodic Report Id" varchar [pk]
  "Fund Management Company Id" varchar
  "Investment Fund Id" varchar
  "Custodian Bank Id" varchar
  "Foreign Fund Management Organization Unit Id" varchar
  "Report Template Id" varchar
  "Reporting Period Id" varchar
  "Securities Company Id" varchar
  "Report Submission Schedule Id" varchar
}

Table "Fund Management Company Share Transfer" [note: "Giao dịch chuyển nhượng cổ phần của công ty quản lý quỹ. Ghi nhận bên chuyển nhượng/nhận nhượng và giá trị giao dịch."] {
  "Fund Management Company Share Transfer Id" varchar [pk]
  "Fund Management Company Id" varchar
}

Table "Fund Management Conduct Violation" [note: "Vi phạm pháp luật hoặc hành chính của công ty quản lý quỹ hoặc quỹ đầu tư. Ghi nhận loại vi phạm và trạng thái xử lý."] {
  "Fund Management Conduct Violation Id" varchar [pk]
  "Fund Management Company Id" varchar
  "Investment Fund Id" varchar
}

Table "Investment Fund Certificate Transfer" [note: "Giao dịch mua/bán chứng chỉ quỹ của nhà đầu tư thành viên. Ghi nhận số lượng và giá giao dịch theo từng quỹ."] {
  "Investment Fund Investor Capital Transfer Id" varchar [pk]
  "Investment Fund Id" varchar
  "Investment Fund Investor Membership Id" varchar
}

Table "Investment Fund Investor Capital Change Log" [note: "Lịch sử thay đổi phần vốn góp của nhà đầu tư trong quỹ đầu tư. Ghi nhận vốn trước/sau và lý do thay đổi."] {
  "Investment Fund Investor Capital Change Log Id" varchar [pk]
  "Investment Fund Investor Membership Id" varchar
}

Table "Member Periodic Report Status Log" [note: "Nhật ký thay đổi trạng thái của báo cáo định kỳ thành viên. Mỗi dòng ghi nhận một lần thay đổi trạng thái kèm nội dung tóm tắt."] {
  "Member Periodic Report History Id" varchar [pk]
  "Member Periodic Report Id" varchar
  "Changed By Officer Id" varchar
}

Table "Report Import Value" [note: "Dữ liệu giá trị từng ô chỉ tiêu trong sheet báo cáo được import vào hệ thống FMS. Grain ở mức cell-level."] {
  "Member Report Value Id" varchar [pk]
  "Member Periodic Report Id" varchar
  "Fund Management Company Id" varchar
  "Investment Fund Id" varchar
  "Custodian Bank Id" varchar
  "Foreign Fund Management Organization Unit Id" varchar
  "Reporting Period Id" varchar
}

TableGroup "UID03 — Thông tin thành viên — Công ty QLQ" {
  "Fund Management Company"
  "Foreign Fund Management Organization Unit Staff"
}

TableGroup "UID04 — Quỹ đầu tư chứng khoán" {
  "Fund Management Company"
  "Investment Fund"
  "Discretionary Investment Account"
  "Investment Fund Investor Membership"
  "Investment Fund Representative Board Member"
  "Fund Management Company Share Transfer"
  "Investment Fund Certificate Transfer"
  "Investment Fund Investor Capital Change Log"
}

TableGroup "UID05 — Quản lý báo cáo" {
  "Reporting Period"
  "Member Periodic Report"
  "Member Periodic Report Status Log"
  "Report Import Value"
}

TableGroup "UID06 — Đánh giá xếp loại và cảnh báo" {
  "Member Rating Period"
  "Member Rating"
  "Rating Criterion"
}

TableGroup "UID07 — Tiện ích và hệ thống" {
  "Fund Management Conduct Violation"
}

