// Ref: "mbr_prd_rpt"."scr_co_id" > ""."" // out-of-source
// Ref: "mbr_prd_rpt"."rpt_subm_shd_id" > ""."" // out-of-source
Ref: "rtg_criterion"."prn_rtg_criterion_id" > "rtg_criterion"."rtg_criterion_id"
// Ref: "rpt_prd"."rpt_tpl_id" > ""."" // out-of-source
Ref: "rpt_impr_val"."mbr_prd_rpt_id" > "mbr_prd_rpt"."mbr_prd_rpt_id"
Ref: "rpt_impr_val"."fnd_mgt_co_id" > "fnd_mgt_co"."fnd_mgt_co_id"
Ref: "rpt_impr_val"."ivsm_fnd_id" > "ivsm_fnd"."ivsm_fnd_id"
