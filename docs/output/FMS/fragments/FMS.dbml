// Ref: "cstd_bnk"."cty_of_rgst_id" > ""."" // out-of-source
Ref: "dscr_ivsm_ivsr"."fnd_mgt_co_id" > "fnd_mgt_co"."fnd_mgt_co_id"
Ref: "frgn_fnd_mgt_ou_stff"."frgn_fnd_mgt_ou_id" > "frgn_fnd_mgt_ou"."frgn_fnd_mgt_ou_id"
Ref: "frgn_fnd_mgt_ou_stff"."fnd_mgt_co_key_psn_id" > "fnd_mgt_co_key_psn"."fnd_mgt_co_key_psn_id"
Ref: "fnd_dstr_agnt_ou"."fnd_dstr_agnt_id" > "fnd_dstr_agnt"."fnd_dstr_agnt_id"
// Ref: "fnd_mgt_co"."cty_of_rgst_id" > ""."" // out-of-source
Ref: "fnd_mgt_co_key_psn"."fnd_mgt_co_id" > "fnd_mgt_co"."fnd_mgt_co_id"
