Ref: "ip_alt_identn"."ip_id" > "fnd_mgt_co_key_psn"."fnd_mgt_co_key_psn_id"
Ref: "ip_alt_identn"."ip_id" > "fnd_mgt_co_ou"."fnd_mgt_co_ou_id"
