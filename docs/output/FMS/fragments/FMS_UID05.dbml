// FMS — UID05 Quản lý báo cáo

Project FMS_UID05 {
  database_type: "Delta Lake"
  Note: "FMS — UID05 Quản lý báo cáo"
}

Table "mbr_prd_rpt_st_log" [note: "Nhật ký thay đổi trạng thái của báo cáo định kỳ thành viên. Mỗi dòng ghi nhận một lần thay đổi trạng thái kèm nội dung tóm tắt."] {
  "mbr_prd_rpt_hist_id" varchar [pk]
  "mbr_prd_rpt_id" varchar
  "changed_by_ofcr_id" varchar
}

Table "mbr_prd_rpt" [note: "Báo cáo định kỳ do thành viên thị trường nộp lên UBCKNN theo từng kỳ báo cáo. Ghi nhận trạng thái nộp và thời hạn."] {
  "mbr_prd_rpt_id" varchar [pk]
  "fnd_mgt_co_id" varchar
  "ivsm_fnd_id" varchar
  "cstd_bnk_id" varchar
  "frgn_fnd_mgt_ou_id" varchar
  "rpt_tpl_id" varchar
  "rpt_prd_id" varchar
  "scr_co_id" varchar
  "rpt_subm_shd_id" varchar
}

Table "rpt_prd" [note: "Kỳ báo cáo định kỳ (ngày/tuần/tháng/quý/bán niên/năm) mà thành viên thị trường phải nộp báo cáo lên UBCKNN."] {
  "rpt_prd_id" varchar [pk]
  "rpt_tpl_id" varchar
}

Table "rpt_impr_val" [note: "Dữ liệu giá trị từng ô chỉ tiêu trong sheet báo cáo được import vào hệ thống FMS. Grain ở mức cell-level."] {
  "mbr_rpt_val_id" varchar [pk]
  "mbr_prd_rpt_id" varchar
  "fnd_mgt_co_id" varchar
  "ivsm_fnd_id" varchar
  "cstd_bnk_id" varchar
  "frgn_fnd_mgt_ou_id" varchar
  "rpt_prd_id" varchar
}

Ref: "mbr_prd_rpt_st_log"."mbr_prd_rpt_id" > "mbr_prd_rpt"."mbr_prd_rpt_id"
// Ref: "mbr_prd_rpt_st_log"."changed_by_ofcr_id" > ""."" // out-of-source
// Ref: "mbr_prd_rpt"."fnd_mgt_co_id" > ""."" // out-of-source
// Ref: "mbr_prd_rpt"."ivsm_fnd_id" > ""."" // out-of-source
// Ref: "mbr_prd_rpt"."cstd_bnk_id" > ""."" // out-of-source
// Ref: "mbr_prd_rpt"."frgn_fnd_mgt_ou_id" > ""."" // out-of-source
// Ref: "mbr_prd_rpt"."rpt_tpl_id" > ""."" // out-of-source
Ref: "mbr_prd_rpt"."rpt_prd_id" > "rpt_prd"."rpt_prd_id"
// Ref: "mbr_prd_rpt"."scr_co_id" > ""."" // out-of-source
// Ref: "mbr_prd_rpt"."rpt_subm_shd_id" > ""."" // out-of-source
// Ref: "rpt_prd"."rpt_tpl_id" > ""."" // out-of-source
Ref: "rpt_impr_val"."mbr_prd_rpt_id" > "mbr_prd_rpt"."mbr_prd_rpt_id"
// Ref: "rpt_impr_val"."fnd_mgt_co_id" > ""."" // out-of-source
// Ref: "rpt_impr_val"."ivsm_fnd_id" > ""."" // out-of-source
// Ref: "rpt_impr_val"."cstd_bnk_id" > ""."" // out-of-source
// Ref: "rpt_impr_val"."frgn_fnd_mgt_ou_id" > ""."" // out-of-source
Ref: "rpt_impr_val"."rpt_prd_id" > "rpt_prd"."rpt_prd_id"
