// FMS — UID05 Quản lý báo cáo

Project FMS_UID05 {
  database_type: "Delta Lake"
  Note: "FMS — UID05 Quản lý báo cáo"
}

Table "Reporting Period" [note: "Kỳ báo cáo định kỳ (ngày/tuần/tháng/quý/bán niên/năm) mà thành viên thị trường phải nộp báo cáo lên UBCKNN."] {
  "Reporting Period Id" varchar [pk]
  "Report Template Id" varchar
}

Table "Member Periodic Report" [note: "Báo cáo định kỳ do thành viên thị trường nộp lên UBCKNN theo từng kỳ báo cáo. Ghi nhận trạng thái nộp và thời hạn."] {
  "Member Periodic Report Id" varchar [pk]
  "Fund Management Company Id" varchar
  "Investment Fund Id" varchar
  "Custodian Bank Id" varchar
  "Foreign Fund Management Organization Unit Id" varchar
  "Report Template Id" varchar
  "Reporting Period Id" varchar
  "Securities Company Id" varchar
  "Report Submission Schedule Id" varchar
}

Table "Member Periodic Report Status Log" [note: "Nhật ký thay đổi trạng thái của báo cáo định kỳ thành viên. Mỗi dòng ghi nhận một lần thay đổi trạng thái kèm nội dung tóm tắt."] {
  "Member Periodic Report History Id" varchar [pk]
  "Member Periodic Report Id" varchar
  "Changed By Officer Id" varchar
}

Table "Report Import Value" [note: "Dữ liệu giá trị từng ô chỉ tiêu trong sheet báo cáo được import vào hệ thống FMS. Grain ở mức cell-level."] {
  "Member Report Value Id" varchar [pk]
  "Member Periodic Report Id" varchar
  "Fund Management Company Id" varchar
  "Investment Fund Id" varchar
  "Custodian Bank Id" varchar
  "Foreign Fund Management Organization Unit Id" varchar
  "Reporting Period Id" varchar
}

// Ref: "Reporting Period"."Report Template Id" > "Report Template"."Report Template Id" // out-of-source
// Ref: "Member Periodic Report"."Fund Management Company Id" > "Fund Management Company"."Fund Management Company Id" // out-of-source
// Ref: "Member Periodic Report"."Investment Fund Id" > "Investment Fund"."Investment Fund Id" // out-of-source
// Ref: "Member Periodic Report"."Custodian Bank Id" > "Custodian Bank"."Custodian Bank Id" // out-of-source
// Ref: "Member Periodic Report"."Foreign Fund Management Organization Unit Id" > "Foreign Fund Management Organization Unit"."Foreign Fund Management Organization Unit Id" // out-of-source
// Ref: "Member Periodic Report"."Report Template Id" > "Report Template"."Report Template Id" // out-of-source
Ref: "Member Periodic Report"."Reporting Period Id" > "Reporting Period"."Reporting Period Id"
// Ref: "Member Periodic Report"."Securities Company Id" > "Securities Company"."Securities Company Id" // out-of-source
// Ref: "Member Periodic Report"."Report Submission Schedule Id" > "Report Submission Schedule"."Report Submission Schedule Id" // out-of-source
Ref: "Member Periodic Report Status Log"."Member Periodic Report Id" > "Member Periodic Report"."Member Periodic Report Id"
// Ref: "Member Periodic Report Status Log"."Changed By Officer Id" > "Fund Management Company Key Person"."Fund Management Company Key Person Id" // out-of-source
Ref: "Report Import Value"."Member Periodic Report Id" > "Member Periodic Report"."Member Periodic Report Id"
// Ref: "Report Import Value"."Fund Management Company Id" > "Fund Management Company"."Fund Management Company Id" // out-of-source
// Ref: "Report Import Value"."Investment Fund Id" > "Investment Fund"."Investment Fund Id" // out-of-source
// Ref: "Report Import Value"."Custodian Bank Id" > "Custodian Bank"."Custodian Bank Id" // out-of-source
// Ref: "Report Import Value"."Foreign Fund Management Organization Unit Id" > "Foreign Fund Management Organization Unit"."Foreign Fund Management Organization Unit Id" // out-of-source
Ref: "Report Import Value"."Reporting Period Id" > "Reporting Period"."Reporting Period Id"
