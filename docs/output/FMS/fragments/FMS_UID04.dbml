// FMS — UID04 Quỹ đầu tư chứng khoán

Project FMS_UID04 {
  database_type: "Delta Lake"
  Note: "FMS — UID04 Quỹ đầu tư chứng khoán"
}

Table "dscr_ivsm_ac" [note: "Tài khoản đầu tư ủy thác — hợp đồng dịch vụ quản lý danh mục tài chính giữa nhà đầu tư ủy thác và công ty quản lý quỹ."] {
  "dscr_ivsm_ac_id" varchar [pk]
  "dscr_ivsm_ivsr_id" varchar
}

Table "ivsm_fnd_ivsr_cptl_chg_log" [note: "Lịch sử thay đổi phần vốn góp của nhà đầu tư trong quỹ đầu tư. Ghi nhận vốn trước/sau và lý do thay đổi."] {
  "ivsm_fnd_ivsr_cptl_chg_log_id" varchar [pk]
  "ivsm_fnd_ivsr_mbr_id" varchar
}

Table "fnd_mgt_co" [note: "Công ty quản lý quỹ đầu tư chứng khoán trong nước được UBCKNN cấp phép hoạt động. Lưu thông tin pháp lý và hoạt động của công ty."] {
  "fnd_mgt_co_id" varchar [pk]
  "cty_of_rgst_id" varchar
}

Table "ivsm_fnd" [note: "Quỹ đầu tư chứng khoán — pháp nhân độc lập do công ty quản lý quỹ thành lập và quản lý. Lưu thông tin pháp lý và vốn của quỹ."] {
  "ivsm_fnd_id" varchar [pk]
  "fnd_mgt_co_id" varchar
}

Table "ivsm_fnd_ivsr_mbr" [note: "Quan hệ thành viên của nhà đầu tư trong một quỹ đầu tư. Lưu tỷ lệ vốn góp và trạng thái tham gia."] {
  "ivsm_fnd_ivsr_mbr_id" varchar [pk]
  "ivsm_fnd_id" varchar
  "dscr_ivsm_ivsr_id" varchar
}

Table "ivsm_fnd_rprs_board_mbr" [note: "Thành viên ban đại diện hoặc hội đồng quản trị của quỹ đầu tư. Cá nhân đảm nhận vai trò quản trị trong cơ cấu tổ chức quỹ."] {
  "ivsm_fnd_rprs_board_mbr_id" varchar [pk]
  "ivsm_fnd_id" varchar
  "fnd_mgt_co_key_psn_id" varchar
}

Table "fnd_mgt_co_shr_tfr" [note: "Giao dịch chuyển nhượng cổ phần của công ty quản lý quỹ. Ghi nhận bên chuyển nhượng/nhận nhượng và giá trị giao dịch."] {
  "fnd_mgt_co_shr_tfr_id" varchar [pk]
  "fnd_mgt_co_id" varchar
}

Table "ivsm_fnd_ctf_tfr" [note: "Giao dịch mua/bán chứng chỉ quỹ của nhà đầu tư thành viên. Ghi nhận số lượng và giá giao dịch theo từng quỹ."] {
  "ivsm_fnd_ivsr_cptl_tfr_id" varchar [pk]
  "ivsm_fnd_id" varchar
  "ivsm_fnd_ivsr_mbr_id" varchar
}

// Ref: "dscr_ivsm_ac"."dscr_ivsm_ivsr_id" > ""."" // out-of-source
Ref: "ivsm_fnd_ivsr_cptl_chg_log"."ivsm_fnd_ivsr_mbr_id" > "ivsm_fnd_ivsr_mbr"."ivsm_fnd_ivsr_mbr_id"
// Ref: "fnd_mgt_co"."cty_of_rgst_id" > ""."" // out-of-source
Ref: "ivsm_fnd"."fnd_mgt_co_id" > "fnd_mgt_co"."fnd_mgt_co_id"
Ref: "ivsm_fnd_ivsr_mbr"."ivsm_fnd_id" > "ivsm_fnd"."ivsm_fnd_id"
// Ref: "ivsm_fnd_ivsr_mbr"."dscr_ivsm_ivsr_id" > ""."" // out-of-source
Ref: "ivsm_fnd_rprs_board_mbr"."ivsm_fnd_id" > "ivsm_fnd"."ivsm_fnd_id"
// Ref: "ivsm_fnd_rprs_board_mbr"."fnd_mgt_co_key_psn_id" > ""."" // out-of-source
Ref: "fnd_mgt_co_shr_tfr"."fnd_mgt_co_id" > "fnd_mgt_co"."fnd_mgt_co_id"
Ref: "ivsm_fnd_ctf_tfr"."ivsm_fnd_id" > "ivsm_fnd"."ivsm_fnd_id"
Ref: "ivsm_fnd_ctf_tfr"."ivsm_fnd_ivsr_mbr_id" > "ivsm_fnd_ivsr_mbr"."ivsm_fnd_ivsr_mbr_id"
