// FIMS — UID08 Công bố thông tin

Project FIMS_UID08 {
  database_type: "Delta Lake"
  Note: "FIMS — UID08 Công bố thông tin"
}

Table "Disclosure Representative" [note: "Người hoặc tổ chức đại diện thực hiện công bố thông tin trên thị trường chứng khoán."] {
  "Disclosure Representative Id" varchar [pk]
  "Nationality Id" varchar
}

Table "Disclosure Announcement" [note: "Tin công bố thông tin của thành viên thị trường qua người đại diện CBTT."] {
  "Disclosure Announcement Id" varchar [pk]
  "Disclosure Representative Id" varchar
}

// Ref: "Disclosure Representative"."Nationality Id" > "Geographic Area"."Geographic Area Id" // out-of-source
