// FIMS — UID08 Công bố thông tin

Project FIMS_UID08 {
  database_type: "Delta Lake"
  Note: "FIMS — UID08 Công bố thông tin"
}

Table "dscl_ancm" [note: "Tin công bố thông tin của thành viên thị trường qua người đại diện CBTT."] {
  "dscl_ancm_id" varchar [pk]
  "dscl_rprs_id" varchar
}

Table "dscl_rprs" [note: "Người hoặc tổ chức đại diện thực hiện công bố thông tin trên thị trường chứng khoán."] {
  "dscl_rprs_id" varchar [pk]
  "nat_id" varchar
}

Ref: "dscl_ancm"."dscl_rprs_id" > "dscl_rprs"."dscl_rprs_id"
// Ref: "dscl_rprs"."nat_id" > ""."" // out-of-source
