// Atomic Lakehouse — FIMS

Project FIMS {
  database_type: "Delta Lake"
  Note: "Atomic Lakehouse — FIMS"
}

Table "Stock Exchange" [note: "Sở giao dịch chứng khoán - thành viên thị trường trong hệ thống FIMS (HNX, HOSE)."] {
  "Stock Exchange Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Depository Center" [note: "Trung tâm lưu ký chứng khoán quốc gia - thành viên thị trường trong hệ thống FIMS (VSD)."] {
  "Depository Center Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Fund Management Company" [note: "Công ty quản lý quỹ đầu tư chứng khoán trong nước được UBCKNN cấp phép hoạt động. Lưu thông tin pháp lý và hoạt động của công ty."] {
  "Fund Management Company Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Securities Company" [note: "Công ty chứng khoán - thành viên thị trường trong hệ thống FIMS. Quản lý tài khoản và danh mục NĐT nước ngoài."] {
  "Securities Company Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Custodian Bank" [note: "Ngân hàng lưu ký giám sát tài sản quỹ đầu tư chứng khoán được UBCKNN chấp thuận. Chịu trách nhiệm lưu giữ và giám sát tài sản của quỹ."] {
  "Custodian Bank Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Fund Management Company Organization Unit" [note: "Chi nhánh hoặc văn phòng đại diện của công ty quản lý quỹ trong nước. Có địa chỉ và giấy phép hoạt động riêng."] {
  "Fund Management Company Organization Unit Id" varchar [pk]
  "Fund Management Company Id" varchar
  "Parent Organization Unit Id" varchar
  "Legal Representative Id" varchar
  "Country of Registration Id" varchar
}

Table "Disclosure Representative" [note: "Người hoặc tổ chức đại diện thực hiện công bố thông tin trên thị trường chứng khoán."] {
  "Disclosure Representative Id" varchar [pk]
  "Nationality Id" varchar
}

Table "Foreign Investor" [note: "Danh mục nhà đầu tư đăng ký giao dịch trên thị trường chứng khoán. Bao gồm cá nhân và tổ chức, phân biệt bằng ObjectType."] {
  "Foreign Investor Id" varchar [pk]
  "Nationality Id" varchar
  "Securities Company Id" varchar
  "Custodian Bank Id" varchar
  "Capital Account Custodian Bank Id" varchar
}

Table "Disclosure Representative Key Person" [note: "Nhân sự thực hiện công bố thông tin tại các tổ chức thành viên thị trường."] {
  "Disclosure Representative Key Person Id" varchar [pk]
  "Nationality Id" varchar
  "Fund Management Company Id" varchar
  "Securities Company Id" varchar
  "Custodian Bank Id" varchar
  "Depository Center Id" varchar
  "Stock Exchange Id" varchar
  "Disclosure Representative Id" varchar
}

Table "Report Template" [note: "Biểu mẫu báo cáo đầu vào - khuôn mẫu tờ khai định kỳ mà thành viên thị trường phải nộp theo quy định."] {
  "Report Template Id" varchar [pk]
}

Table "Geographic Area" [note: "Đơn vị địa lý dùng làm FK tham chiếu: quốc gia/quốc tịch (COUNTRY), vùng/miền (REGION), tỉnh/thành phố mới/cũ (PROVINCE/PROVINCE_OLD), quận/huyện cũ (DISTRICT_OLD), phường/xã mới/cũ (WARD/WARD_OLD). P"] {
  "Geographic Area Id" varchar [pk]
}

Table "Reporting Period" [note: "Kỳ báo cáo định kỳ (ngày/tuần/tháng/quý/bán niên/năm) mà thành viên thị trường phải nộp báo cáo lên UBCKNN."] {
  "Reporting Period Id" varchar [pk]
  "Report Template Id" varchar
}

Table "Member Regulatory Report" [note: "Báo cáo định kỳ của thành viên thị trường nộp lên UBCK. Ghi nhận biểu mẫu, kỳ, trạng thái nộp và thành viên nộp."] {
  "Member Regulatory Report Id" varchar [pk]
  "Report Template Id" varchar
  "Reporting Period Id" varchar
  "Fund Management Company Id" varchar
  "Securities Company Id" varchar
  "Custodian Bank Id" varchar
  "Depository Center Id" varchar
  "Stock Exchange Id" varchar
  "Foreign Investor Id" varchar
  "Fund Management Company Organization Unit Id" varchar
}

Table "Member Conduct Violation" [note: "Vi phạm được ghi nhận từ cảnh báo hệ thống hoặc kiểm tra định kỳ đối với thành viên thị trường."] {
  "Member Conduct Violation Id" varchar [pk]
  "Fund Management Company Id" varchar
  "Securities Company Id" varchar
  "Custodian Bank Id" varchar
  "Depository Center Id" varchar
  "Stock Exchange Id" varchar
  "Disclosure Representative Id" varchar
  "Fund Management Company Organization Unit Id" varchar
}

Table "Disclosure Authorization" [note: "Ủy quyền công bố thông tin của người đại diện CBTT cho nhà đầu tư nước ngoài. Ghi nhận bên được ủy quyền, loại quan hệ và thời hạn hiệu lực."] {
  "Disclosure Authorization Id" varchar [pk]
  "Disclosure Representative Id" varchar
}

Table "Disclosure Announcement" [note: "Tin công bố thông tin của thành viên thị trường qua người đại diện CBTT."] {
  "Disclosure Announcement Id" varchar [pk]
  "Disclosure Representative Id" varchar
}

Table "Foreign Investor Securities Account" [note: "Tài khoản giao dịch chứng khoán của nhà đầu tư nước ngoài tại công ty chứng khoán."] {
  "Foreign Investor Securities Account Id" varchar [pk]
  "Securities Company Id" varchar
  "Foreign Investor Id" varchar
}

Table "Foreign Investor Stock Portfolio Snapshot" [note: "Danh mục sở hữu chứng khoán của nhà đầu tư nước ngoài tại từng công ty chứng khoán."] {
  "Foreign Investor Stock Portfolio Snapshot Id" varchar [pk]
  "Securities Company Id" varchar
  "Foreign Investor Id" varchar
}

Table "Member Report Value" [note: "Giá trị từng chỉ tiêu trong báo cáo định kỳ của thành viên. Mỗi dòng = 1 chỉ tiêu trong 1 báo cáo."] {
  "Member Report Value Id" varchar [pk]
  "Member Regulatory Report Id" varchar
  "Reporting Period Id" varchar
  "Report Template Id" varchar
  "Fund Management Company Id" varchar
  "Securities Company Id" varchar
  "Custodian Bank Id" varchar
  "Depository Center Id" varchar
  "Stock Exchange Id" varchar
  "Disclosure Representative Id" varchar
  "Fund Management Company Organization Unit Id" varchar
}

Table "Involved Party Postal Address" [note: "Lưu trữ các địa chỉ bưu chính của Involved Party (trụ sở/kinh doanh/thường trú/nơi ở hiện tại). Mỗi dòng = 1 loại địa chỉ từ 1 nguồn."] {
  "Involved Party Id" varchar
  "Province Id" varchar
  "Geographic Area Id" varchar
}

Table "Involved Party Electronic Address" [note: "Lưu trữ các địa chỉ liên lạc điện tử của Involved Party (điện thoại/fax/email). Mỗi dòng = 1 kênh liên lạc từ 1 nguồn."] {
  "Involved Party Id" varchar
}

Table "Involved Party Alternative Identification" [note: "Lưu trữ các giấy tờ định danh thay thế của Involved Party (CMND/CCCD/Hộ chiếu/Giấy phép kinh doanh/Chứng chỉ hành nghề). Mỗi dòng = 1 loại giấy tờ từ 1 nguồn."] {
  "Involved Party Id" varchar
}

TableGroup "UID01 — Quản trị phân hệ" {
  "Report Template"
  "Geographic Area"
  "Reporting Period"
}

TableGroup "UID03 — Đối tượng gửi báo cáo" {
  "Stock Exchange"
  "Depository Center"
  "Fund Management Company"
  "Securities Company"
  "Custodian Bank"
  "Fund Management Company Organization Unit"
  "Disclosure Representative"
  "Disclosure Representative Key Person"
  "Geographic Area"
}

TableGroup "UID04 — Nhà đầu tư nước ngoài" {
  "Foreign Investor"
  "Geographic Area"
  "Foreign Investor Securities Account"
  "Foreign Investor Stock Portfolio Snapshot"
}

TableGroup "UID05 — Báo cáo thành viên" {
  "Report Template"
  "Reporting Period"
  "Member Regulatory Report"
  "Member Report Value"
}

TableGroup "UID07 — Ủy quyền" {
  "Disclosure Representative"
  "Disclosure Authorization"
}

TableGroup "UID08 — Công bố thông tin" {
  "Disclosure Representative"
  "Disclosure Announcement"
}

TableGroup "UID09 — Cảnh báo" {
  "Member Conduct Violation"
}

TableGroup "UID10 — Tiện ích" {
  "Geographic Area"
}

