// Atomic Lakehouse — FIMS

Project FIMS {
  database_type: "Delta Lake"
  Note: "Atomic Lakehouse — FIMS"
}

Table "stk_exg" [note: "Sở giao dịch chứng khoán - thành viên thị trường trong hệ thống FIMS (HNX, HOSE)."] {
  "stk_exg_id" varchar [pk]
  "cty_of_rgst_id" varchar
}

Table "depst_cntr" [note: "Trung tâm lưu ký chứng khoán quốc gia - thành viên thị trường trong hệ thống FIMS (VSD)."] {
  "depst_cntr_id" varchar [pk]
  "cty_of_rgst_id" varchar
}

Table "fnd_mgt_co" [note: "Công ty quản lý quỹ đầu tư chứng khoán trong nước được UBCKNN cấp phép hoạt động. Lưu thông tin pháp lý và hoạt động của công ty."] {
  "fnd_mgt_co_id" varchar [pk]
  "cty_of_rgst_id" varchar
}

Table "scr_co" [note: "Công ty chứng khoán - thành viên thị trường trong hệ thống FIMS. Quản lý tài khoản và danh mục NĐT nước ngoài."] {
  "scr_co_id" varchar [pk]
  "cty_of_rgst_id" varchar
}

Table "cstd_bnk" [note: "Ngân hàng lưu ký giám sát tài sản quỹ đầu tư chứng khoán được UBCKNN chấp thuận. Chịu trách nhiệm lưu giữ và giám sát tài sản của quỹ."] {
  "cstd_bnk_id" varchar [pk]
  "cty_of_rgst_id" varchar
}

Table "fnd_mgt_co_ou" [note: "Chi nhánh hoặc văn phòng đại diện của công ty quản lý quỹ trong nước. Có địa chỉ và giấy phép hoạt động riêng."] {
  "fnd_mgt_co_ou_id" varchar [pk]
  "fnd_mgt_co_id" varchar
  "prn_ou_id" varchar
  "lgl_rprs_id" varchar
  "cty_of_rgst_id" varchar
}

Table "dscl_rprs" [note: "Người hoặc tổ chức đại diện thực hiện công bố thông tin trên thị trường chứng khoán."] {
  "dscl_rprs_id" varchar [pk]
  "nat_id" varchar
}

Table "frgn_ivsr" [note: "Danh mục nhà đầu tư đăng ký giao dịch trên thị trường chứng khoán. Bao gồm cá nhân và tổ chức, phân biệt bằng ObjectType."] {
  "frgn_ivsr_id" varchar [pk]
  "nat_id" varchar
  "scr_co_id" varchar
  "cstd_bnk_id" varchar
  "cptl_ac_cstd_bnk_id" varchar
}

Table "dscl_rprs_key_psn" [note: "Nhân sự thực hiện công bố thông tin tại các tổ chức thành viên thị trường."] {
  "dscl_rprs_key_psn_id" varchar [pk]
  "nat_id" varchar
  "fnd_mgt_co_id" varchar
  "scr_co_id" varchar
  "cstd_bnk_id" varchar
  "depst_cntr_id" varchar
  "stk_exg_id" varchar
  "dscl_rprs_id" varchar
}

Table "rpt_tpl" [note: "Biểu mẫu báo cáo đầu vào - khuôn mẫu tờ khai định kỳ mà thành viên thị trường phải nộp theo quy định."] {
  "rpt_tpl_id" varchar [pk]
}

Table "geo" [note: "Đơn vị địa lý dùng làm FK tham chiếu: quốc gia/quốc tịch (COUNTRY), vùng/miền (REGION), tỉnh/thành phố mới/cũ (PROVINCE/PROVINCE_OLD), quận/huyện cũ (DISTRICT_OLD), phường/xã mới/cũ (WARD/WARD_OLD). P"] {
  "geo_id" varchar [pk]
  "prn_geo_id" varchar
}

Table "rpt_prd" [note: "Kỳ báo cáo định kỳ (ngày/tuần/tháng/quý/bán niên/năm) mà thành viên thị trường phải nộp báo cáo lên UBCKNN."] {
  "rpt_prd_id" varchar [pk]
  "rpt_tpl_id" varchar
}

Table "mbr_reg_rpt" [note: "Báo cáo định kỳ của thành viên thị trường nộp lên UBCK. Ghi nhận biểu mẫu, kỳ, trạng thái nộp và thành viên nộp."] {
  "mbr_reg_rpt_id" varchar [pk]
  "rpt_tpl_id" varchar
  "rpt_prd_id" varchar
  "fnd_mgt_co_id" varchar
  "scr_co_id" varchar
  "cstd_bnk_id" varchar
  "depst_cntr_id" varchar
  "stk_exg_id" varchar
  "frgn_ivsr_id" varchar
  "fnd_mgt_co_ou_id" varchar
}

Table "mbr_conduct_vln" [note: "Vi phạm được ghi nhận từ cảnh báo hệ thống hoặc kiểm tra định kỳ đối với thành viên thị trường."] {
  "mbr_conduct_vln_id" varchar [pk]
  "fnd_mgt_co_id" varchar
  "scr_co_id" varchar
  "cstd_bnk_id" varchar
  "depst_cntr_id" varchar
  "stk_exg_id" varchar
  "dscl_rprs_id" varchar
  "fnd_mgt_co_ou_id" varchar
}

Table "dscl_ahr" [note: "Ủy quyền công bố thông tin của người đại diện CBTT cho nhà đầu tư nước ngoài. Ghi nhận bên được ủy quyền, loại quan hệ và thời hạn hiệu lực."] {
  "dscl_ahr_id" varchar [pk]
  "dscl_rprs_id" varchar
}

Table "dscl_ancm" [note: "Tin công bố thông tin của thành viên thị trường qua người đại diện CBTT."] {
  "dscl_ancm_id" varchar [pk]
  "dscl_rprs_id" varchar
}

Table "frgn_ivsr_scr_ac" [note: "Tài khoản giao dịch chứng khoán của nhà đầu tư nước ngoài tại công ty chứng khoán."] {
  "frgn_ivsr_scr_ac_id" varchar [pk]
  "scr_co_id" varchar
  "frgn_ivsr_id" varchar
}

Table "frgn_ivsr_stk_prtfl_snpst" [note: "Danh mục sở hữu chứng khoán của nhà đầu tư nước ngoài tại từng công ty chứng khoán."] {
  "frgn_ivsr_stk_prtfl_snpst_id" varchar [pk]
  "scr_co_id" varchar
  "frgn_ivsr_id" varchar
}

Table "mbr_rpt_val" [note: "Giá trị từng chỉ tiêu trong báo cáo định kỳ của thành viên. Mỗi dòng = 1 chỉ tiêu trong 1 báo cáo."] {
  "mbr_rpt_val_id" varchar [pk]
  "mbr_reg_rpt_id" varchar
  "rpt_prd_id" varchar
  "rpt_tpl_id" varchar
  "fnd_mgt_co_id" varchar
  "scr_co_id" varchar
  "cstd_bnk_id" varchar
  "depst_cntr_id" varchar
  "stk_exg_id" varchar
  "dscl_rprs_id" varchar
  "fnd_mgt_co_ou_id" varchar
}

Table "ip_pst_adr" [note: "Lưu trữ các địa chỉ bưu chính của Involved Party (trụ sở/kinh doanh/thường trú/nơi ở hiện tại). Mỗi dòng = 1 loại địa chỉ từ 1 nguồn."] {
  "ip_id" varchar
  "prov_id" varchar
  "geo_id" varchar
}

Table "ip_elc_adr" [note: "Lưu trữ các địa chỉ liên lạc điện tử của Involved Party (điện thoại/fax/email). Mỗi dòng = 1 kênh liên lạc từ 1 nguồn."] {
  "ip_id" varchar
}

Table "ip_alt_identn" [note: "Lưu trữ các giấy tờ định danh thay thế của Involved Party (CMND/CCCD/Hộ chiếu/Giấy phép kinh doanh/Chứng chỉ hành nghề). Mỗi dòng = 1 loại giấy tờ từ 1 nguồn."] {
  "ip_id" varchar
}

TableGroup "UID01 — Quản trị phân hệ" {
  "rpt_tpl"
  "geo"
  "rpt_prd"
}

TableGroup "UID03 — Đối tượng gửi báo cáo" {
  "stk_exg"
  "depst_cntr"
  "fnd_mgt_co"
  "scr_co"
  "cstd_bnk"
  "fnd_mgt_co_ou"
  "dscl_rprs"
  "dscl_rprs_key_psn"
  "geo"
}

TableGroup "UID04 — Nhà đầu tư nước ngoài" {
  "frgn_ivsr"
  "geo"
  "frgn_ivsr_scr_ac"
  "frgn_ivsr_stk_prtfl_snpst"
}

TableGroup "UID05 — Báo cáo thành viên" {
  "rpt_tpl"
  "rpt_prd"
  "mbr_reg_rpt"
  "mbr_rpt_val"
}

TableGroup "UID07 — Ủy quyền" {
  "dscl_rprs"
  "dscl_ahr"
}

TableGroup "UID08 — Công bố thông tin" {
  "dscl_rprs"
  "dscl_ancm"
}

TableGroup "UID09 — Cảnh báo" {
  "mbr_conduct_vln"
}

TableGroup "UID10 — Tiện ích" {
  "geo"
}

Ref: "stk_exg"."cty_of_rgst_id" > "geo"."geo_id"
Ref: "depst_cntr"."cty_of_rgst_id" > "geo"."geo_id"
Ref: "fnd_mgt_co"."cty_of_rgst_id" > "geo"."geo_id"
