// FIMS — UID07 Ủy quyền

Project FIMS_UID07 {
  database_type: "Delta Lake"
  Note: "FIMS — UID07 Ủy quyền"
}

Table "Disclosure Representative" [note: "Người hoặc tổ chức đại diện thực hiện công bố thông tin trên thị trường chứng khoán."] {
  "Disclosure Representative Id" varchar [pk]
  "Nationality Id" varchar
}

Table "Disclosure Authorization" [note: "Ủy quyền công bố thông tin của người đại diện CBTT cho nhà đầu tư nước ngoài. Ghi nhận bên được ủy quyền, loại quan hệ và thời hạn hiệu lực."] {
  "Disclosure Authorization Id" varchar [pk]
  "Disclosure Representative Id" varchar
}

// Ref: "Disclosure Representative"."Nationality Id" > "Geographic Area"."Geographic Area Id" // out-of-source
Ref: "Disclosure Authorization"."Disclosure Representative Id" > "Disclosure Representative"."Disclosure Representative Id"
