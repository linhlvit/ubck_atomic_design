// FIMS — UID05 Báo cáo thành viên

Project FIMS_UID05 {
  database_type: "Delta Lake"
  Note: "FIMS — UID05 Báo cáo thành viên"
}

Table "Report Template" [note: "Biểu mẫu báo cáo đầu vào - khuôn mẫu tờ khai định kỳ mà thành viên thị trường phải nộp theo quy định."] {
  "Report Template Id" varchar [pk]
}

Table "Reporting Period" [note: "Kỳ báo cáo định kỳ (ngày/tuần/tháng/quý/bán niên/năm) mà thành viên thị trường phải nộp báo cáo lên UBCKNN."] {
  "Reporting Period Id" varchar [pk]
  "Report Template Id" varchar
}

Table "Member Regulatory Report" [note: "Báo cáo định kỳ của thành viên thị trường nộp lên UBCK. Ghi nhận biểu mẫu, kỳ, trạng thái nộp và thành viên nộp."] {
  "Member Regulatory Report Id" varchar [pk]
  "Report Template Id" varchar
  "Reporting Period Id" varchar
  "Fund Management Company Id" varchar
  "Securities Company Id" varchar
  "Custodian Bank Id" varchar
  "Depository Center Id" varchar
  "Stock Exchange Id" varchar
  "Foreign Investor Id" varchar
  "Fund Management Company Organization Unit Id" varchar
}

Table "Member Report Value" [note: "Giá trị từng chỉ tiêu trong báo cáo định kỳ của thành viên. Mỗi dòng = 1 chỉ tiêu trong 1 báo cáo."] {
  "Member Report Value Id" varchar [pk]
  "Member Regulatory Report Id" varchar
  "Reporting Period Id" varchar
  "Report Template Id" varchar
  "Fund Management Company Id" varchar
  "Securities Company Id" varchar
  "Custodian Bank Id" varchar
  "Depository Center Id" varchar
  "Stock Exchange Id" varchar
  "Disclosure Representative Id" varchar
  "Fund Management Company Organization Unit Id" varchar
}

Ref: "Reporting Period"."Report Template Id" > "Report Template"."Report Template Id"
Ref: "Member Regulatory Report"."Report Template Id" > "Report Template"."Report Template Id"
Ref: "Member Regulatory Report"."Reporting Period Id" > "Reporting Period"."Reporting Period Id"
// Ref: "Member Regulatory Report"."Fund Management Company Id" > "Fund Management Company"."Fund Management Company Id" // out-of-source
// Ref: "Member Regulatory Report"."Securities Company Id" > "Securities Company"."Securities Company Id" // out-of-source
// Ref: "Member Regulatory Report"."Custodian Bank Id" > "Custodian Bank"."Custodian Bank Id" // out-of-source
// Ref: "Member Regulatory Report"."Depository Center Id" > "Depository Center"."Depository Center Id" // out-of-source
// Ref: "Member Regulatory Report"."Stock Exchange Id" > "Stock Exchange"."Stock Exchange Id" // out-of-source
// Ref: "Member Regulatory Report"."Foreign Investor Id" > "Foreign Investor"."Foreign Investor Id" // out-of-source
// Ref: "Member Regulatory Report"."Fund Management Company Organization Unit Id" > "Fund Management Company Organization Unit"."Fund Management Company Organization Unit Id" // out-of-source
Ref: "Member Report Value"."Member Regulatory Report Id" > "Member Regulatory Report"."Member Regulatory Report Id"
Ref: "Member Report Value"."Reporting Period Id" > "Reporting Period"."Reporting Period Id"
Ref: "Member Report Value"."Report Template Id" > "Report Template"."Report Template Id"
// Ref: "Member Report Value"."Fund Management Company Id" > "Fund Management Company"."Fund Management Company Id" // out-of-source
// Ref: "Member Report Value"."Securities Company Id" > "Securities Company"."Securities Company Id" // out-of-source
// Ref: "Member Report Value"."Custodian Bank Id" > "Custodian Bank"."Custodian Bank Id" // out-of-source
// Ref: "Member Report Value"."Depository Center Id" > "Depository Center"."Depository Center Id" // out-of-source
// Ref: "Member Report Value"."Stock Exchange Id" > "Stock Exchange"."Stock Exchange Id" // out-of-source
// Ref: "Member Report Value"."Disclosure Representative Id" > "Disclosure Representative"."Disclosure Representative Id" // out-of-source
// Ref: "Member Report Value"."Fund Management Company Organization Unit Id" > "Fund Management Company Organization Unit"."Fund Management Company Organization Unit Id" // out-of-source
