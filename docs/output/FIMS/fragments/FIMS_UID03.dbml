// FIMS — UID03 Đối tượng gửi báo cáo

Project FIMS_UID03 {
  database_type: "Delta Lake"
  Note: "FIMS — UID03 Đối tượng gửi báo cáo"
}

Table "Stock Exchange" [note: "Sở giao dịch chứng khoán - thành viên thị trường trong hệ thống FIMS (HNX, HOSE)."] {
  "Stock Exchange Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Depository Center" [note: "Trung tâm lưu ký chứng khoán quốc gia - thành viên thị trường trong hệ thống FIMS (VSD)."] {
  "Depository Center Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Fund Management Company" [note: "Công ty quản lý quỹ đầu tư chứng khoán trong nước được UBCKNN cấp phép hoạt động. Lưu thông tin pháp lý và hoạt động của công ty."] {
  "Fund Management Company Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Securities Company" [note: "Công ty chứng khoán - thành viên thị trường trong hệ thống FIMS. Quản lý tài khoản và danh mục NĐT nước ngoài."] {
  "Securities Company Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Custodian Bank" [note: "Ngân hàng lưu ký giám sát tài sản quỹ đầu tư chứng khoán được UBCKNN chấp thuận. Chịu trách nhiệm lưu giữ và giám sát tài sản của quỹ."] {
  "Custodian Bank Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Fund Management Company Organization Unit" [note: "Chi nhánh hoặc văn phòng đại diện của công ty quản lý quỹ trong nước. Có địa chỉ và giấy phép hoạt động riêng."] {
  "Fund Management Company Organization Unit Id" varchar [pk]
  "Fund Management Company Id" varchar
  "Parent Organization Unit Id" varchar
  "Legal Representative Id" varchar
  "Country of Registration Id" varchar
}

Table "Disclosure Representative" [note: "Người hoặc tổ chức đại diện thực hiện công bố thông tin trên thị trường chứng khoán."] {
  "Disclosure Representative Id" varchar [pk]
  "Nationality Id" varchar
}

Table "Disclosure Representative Key Person" [note: "Nhân sự thực hiện công bố thông tin tại các tổ chức thành viên thị trường."] {
  "Disclosure Representative Key Person Id" varchar [pk]
  "Nationality Id" varchar
  "Fund Management Company Id" varchar
  "Securities Company Id" varchar
  "Custodian Bank Id" varchar
  "Depository Center Id" varchar
  "Stock Exchange Id" varchar
  "Disclosure Representative Id" varchar
}

Table "Geographic Area" [note: "Đơn vị địa lý dùng làm FK tham chiếu: quốc gia/quốc tịch (COUNTRY), vùng/miền (REGION), tỉnh/thành phố mới/cũ (PROVINCE/PROVINCE_OLD), quận/huyện cũ (DISTRICT_OLD), phường/xã mới/cũ (WARD/WARD_OLD). P"] {
  "Geographic Area Id" varchar [pk]
}

Ref: "Stock Exchange"."Country of Registration Id" > "Geographic Area"."Geographic Area Id"
Ref: "Depository Center"."Country of Registration Id" > "Geographic Area"."Geographic Area Id"
Ref: "Fund Management Company"."Country of Registration Id" > "Geographic Area"."Geographic Area Id"
Ref: "Securities Company"."Country of Registration Id" > "Geographic Area"."Geographic Area Id"
Ref: "Custodian Bank"."Country of Registration Id" > "Geographic Area"."Geographic Area Id"
Ref: "Fund Management Company Organization Unit"."Fund Management Company Id" > "Fund Management Company"."Fund Management Company Id"
Ref: "Fund Management Company Organization Unit"."Parent Organization Unit Id" > "Fund Management Company Organization Unit"."Fund Management Company Organization Unit Id"
// Ref: "Fund Management Company Organization Unit"."Legal Representative Id" > "Fund Management Company Key Person"."Fund Management Company Key Person Id" // out-of-source
Ref: "Fund Management Company Organization Unit"."Country of Registration Id" > "Geographic Area"."Geographic Area Id"
Ref: "Disclosure Representative"."Nationality Id" > "Geographic Area"."Geographic Area Id"
Ref: "Disclosure Representative Key Person"."Nationality Id" > "Geographic Area"."Geographic Area Id"
Ref: "Disclosure Representative Key Person"."Fund Management Company Id" > "Fund Management Company"."Fund Management Company Id"
Ref: "Disclosure Representative Key Person"."Securities Company Id" > "Securities Company"."Securities Company Id"
Ref: "Disclosure Representative Key Person"."Custodian Bank Id" > "Custodian Bank"."Custodian Bank Id"
Ref: "Disclosure Representative Key Person"."Depository Center Id" > "Depository Center"."Depository Center Id"
Ref: "Disclosure Representative Key Person"."Stock Exchange Id" > "Stock Exchange"."Stock Exchange Id"
Ref: "Disclosure Representative Key Person"."Disclosure Representative Id" > "Disclosure Representative"."Disclosure Representative Id"
