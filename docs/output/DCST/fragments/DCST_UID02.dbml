// DCST — UID02 Báo cáo tài chính từ Tổng cục Thuế

Project DCST_UID02 {
  database_type: "Delta Lake"
  Note: "DCST — UID02 Báo cáo tài chính từ Tổng cục Thuế"
}

Table "tax_fnc_stmt" [note: "Tờ khai tài chính điện tử nộp lên cơ quan thuế. Ghi nhận kỳ kê khai và thông tin kiểm toán."] {
  "tax_fnc_stmt_id" varchar [pk]
  "rgst_taxpayer_id" varchar
}

Table "tax_fnc_stmt_itm" [note: "Chỉ tiêu chi tiết trong tờ khai tài chính. Ghi nhận giá trị số liệu theo từng ô chỉ tiêu trong biểu mẫu."] {
  "tax_fnc_stmt_itm_id" varchar [pk]
  "tax_fnc_stmt_id" varchar
}

// Ref: "tax_fnc_stmt"."rgst_taxpayer_id" > ""."" // out-of-source
Ref: "tax_fnc_stmt_itm"."tax_fnc_stmt_id" > "tax_fnc_stmt"."tax_fnc_stmt_id"
