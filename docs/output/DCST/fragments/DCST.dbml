// Atomic Lakehouse — DCST

Project DCST {
  database_type: "Delta Lake"
  Note: "Atomic Lakehouse — DCST"
}

Table "Registered Taxpayer" [note: "Doanh nghiệp/hộ kinh doanh đã đăng ký thuế với cơ quan thuế. Lưu thông tin pháp lý và trạng thái hoạt động."] {
  "Registered Taxpayer Id" varchar [pk]
  "Charter Capital Currency Code" varchar
  "Foreign Charter Capital Currency Code" varchar
}

Table "Taxpayer Representative" [note: "Người đại diện hoặc chủ hộ kinh doanh của người nộp thuế. Ghi nhận tên và chức vụ."] {
  "Taxpayer Representative Id" varchar [pk]
  "Registered Taxpayer Id" varchar
}

Table "High Risk Taxpayer Assessment Snapshot" [note: "Đánh giá xếp loại doanh nghiệp rủi ro cao về thuế theo năm. Ghi nhận thông tin tổ chức bị đánh giá rủi ro."] {
  "High Risk Taxpayer Assessment Snapshot Id" varchar [pk]
  "Registered Taxpayer Id" varchar
}

Table "Involved Party Postal Address" [note: "Lưu trữ các địa chỉ bưu chính của Involved Party (trụ sở/kinh doanh/thường trú/nơi ở hiện tại). Mỗi dòng = 1 loại địa chỉ từ 1 nguồn."] {
  "Involved Party Id" varchar
  "Province Id" varchar
  "Geographic Area Id" varchar
}

Table "Involved Party Electronic Address" [note: "Lưu trữ các địa chỉ liên lạc điện tử của Involved Party (điện thoại/fax/email). Mỗi dòng = 1 kênh liên lạc từ 1 nguồn."] {
  "Involved Party Id" varchar
}

Table "Involved Party Alternative Identification" [note: "Lưu trữ các giấy tờ định danh thay thế của Involved Party (CMND/CCCD/Hộ chiếu/Giấy phép kinh doanh/Chứng chỉ hành nghề). Mỗi dòng = 1 loại giấy tờ từ 1 nguồn."] {
  "Involved Party Id" varchar
}

Table "Tax Financial Statement" [note: "Tờ khai tài chính điện tử nộp lên cơ quan thuế. Ghi nhận kỳ kê khai và thông tin kiểm toán."] {
  "Tax Financial Statement Id" varchar [pk]
  "Registered Taxpayer Id" varchar
}

Table "Tax Financial Statement Item" [note: "Chỉ tiêu chi tiết trong tờ khai tài chính. Ghi nhận giá trị số liệu theo từng ô chỉ tiêu trong biểu mẫu."] {
  "Tax Financial Statement Item Id" varchar [pk]
  "Tax Financial Statement Id" varchar
}

Table "Tax Debt Enforcement Order" [note: "Quyết định cưỡng chế nợ thuế. Ghi nhận hình thức cưỡng chế và thông tin tài sản/tài khoản liên quan."] {
  "Tax Debt Enforcement Order Id" varchar [pk]
  "Registered Taxpayer Id" varchar
}

Table "Tax Violation Penalty Decision" [note: "Quyết định xử lý vi phạm hành chính về thuế. Ghi nhận hành vi vi phạm và mức phạt/truy thu."] {
  "Tax Violation Penalty Decision Id" varchar [pk]
  "Registered Taxpayer Id" varchar
}

Table "Tax Invoice Enforcement Order" [note: "Quyết định cưỡng chế nợ thuế theo hình thức ngừng sử dụng hóa đơn. Ghi nhận thông tin quyết định và thông báo."] {
  "Tax Invoice Enforcement Order Id" varchar [pk]
  "Registered Taxpayer Id" varchar
}

Table "Tax Invoice Enforcement Order Item" [note: "Chi tiết hóa đơn thuộc quyết định cưỡng chế ngừng sử dụng hóa đơn. Ghi nhận số hiệu và loại hóa đơn."] {
  "Tax Invoice Enforcement Order Item Id" varchar [pk]
  "Tax Invoice Enforcement Order Id" varchar
}

TableGroup "UID01 — Quản lý thông tin đăng ký thuế" {
  "Registered Taxpayer"
  "Taxpayer Representative"
}

TableGroup "UID02 — Báo cáo tài chính từ Tổng cục Thuế" {
  "Tax Financial Statement"
  "Tax Financial Statement Item"
}

TableGroup "UID03 — Cưỡng chế nợ thuế" {
  "Tax Debt Enforcement Order"
  "Tax Invoice Enforcement Order"
  "Tax Invoice Enforcement Order Item"
}

TableGroup "UID04 — Xử lý vi phạm pháp luật về thuế" {
  "Tax Violation Penalty Decision"
}

TableGroup "UID05 — Giám sát doanh nghiệp rủi ro cao" {
  "High Risk Taxpayer Assessment Snapshot"
}

// Ref: "Registered Taxpayer"."Charter Capital Currency Code" > "Currency"."Currency Code" // out-of-source
// Ref: "Registered Taxpayer"."Foreign Charter Capital Currency Code" > "Currency"."Currency Code" // out-of-source
Ref: "Taxpayer Representative"."Registered Taxpayer Id" > "Registered Taxpayer"."Registered Taxpayer Id"
Ref: "High Risk Taxpayer Assessment Snapshot"."Registered Taxpayer Id" > "Registered Taxpayer"."Registered Taxpayer Id"
Ref: "Involved Party Postal Address"."Involved Party Id" > "Registered Taxpayer"."Registered Taxpayer Id"
// Ref: "Involved Party Postal Address"."Province Id" > "Geographic Area"."Geographic Area Id" // out-of-source
// Ref: "Involved Party Postal Address"."Geographic Area Id" > "Geographic Area"."Geographic Area Id" // out-of-source
Ref: "Involved Party Electronic Address"."Involved Party Id" > "Registered Taxpayer"."Registered Taxpayer Id"
Ref: "Involved Party Alternative Identification"."Involved Party Id" > "Registered Taxpayer"."Registered Taxpayer Id"
Ref: "Involved Party Electronic Address"."Involved Party Id" > "Taxpayer Representative"."Taxpayer Representative Id"
Ref: "Involved Party Alternative Identification"."Involved Party Id" > "Taxpayer Representative"."Taxpayer Representative Id"
Ref: "Tax Financial Statement"."Registered Taxpayer Id" > "Registered Taxpayer"."Registered Taxpayer Id"
Ref: "Tax Financial Statement Item"."Tax Financial Statement Id" > "Tax Financial Statement"."Tax Financial Statement Id"
Ref: "Tax Debt Enforcement Order"."Registered Taxpayer Id" > "Registered Taxpayer"."Registered Taxpayer Id"
Ref: "Tax Violation Penalty Decision"."Registered Taxpayer Id" > "Registered Taxpayer"."Registered Taxpayer Id"
Ref: "Tax Invoice Enforcement Order"."Registered Taxpayer Id" > "Registered Taxpayer"."Registered Taxpayer Id"
Ref: "Tax Invoice Enforcement Order Item"."Tax Invoice Enforcement Order Id" > "Tax Invoice Enforcement Order"."Tax Invoice Enforcement Order Id"
