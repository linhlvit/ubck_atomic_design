// DCST — UID03 Cưỡng chế nợ thuế

Project DCST_UID03 {
  database_type: "Delta Lake"
  Note: "DCST — UID03 Cưỡng chế nợ thuế"
}

Table "Tax Debt Enforcement Order" [note: "Quyết định cưỡng chế nợ thuế. Ghi nhận hình thức cưỡng chế và thông tin tài sản/tài khoản liên quan."] {
  "Tax Debt Enforcement Order Id" varchar [pk]
  "Registered Taxpayer Id" varchar
}

Table "Tax Invoice Enforcement Order" [note: "Quyết định cưỡng chế nợ thuế theo hình thức ngừng sử dụng hóa đơn. Ghi nhận thông tin quyết định và thông báo."] {
  "Tax Invoice Enforcement Order Id" varchar [pk]
  "Registered Taxpayer Id" varchar
}

Table "Tax Invoice Enforcement Order Item" [note: "Chi tiết hóa đơn thuộc quyết định cưỡng chế ngừng sử dụng hóa đơn. Ghi nhận số hiệu và loại hóa đơn."] {
  "Tax Invoice Enforcement Order Item Id" varchar [pk]
  "Tax Invoice Enforcement Order Id" varchar
}

// Ref: "Tax Debt Enforcement Order"."Registered Taxpayer Id" > "Registered Taxpayer"."Registered Taxpayer Id" // out-of-source
// Ref: "Tax Invoice Enforcement Order"."Registered Taxpayer Id" > "Registered Taxpayer"."Registered Taxpayer Id" // out-of-source
Ref: "Tax Invoice Enforcement Order Item"."Tax Invoice Enforcement Order Id" > "Tax Invoice Enforcement Order"."Tax Invoice Enforcement Order Id"
