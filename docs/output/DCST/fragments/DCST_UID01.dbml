// DCST — UID01 Quản lý thông tin đăng ký thuế

Project DCST_UID01 {
  database_type: "Delta Lake"
  Note: "DCST — UID01 Quản lý thông tin đăng ký thuế"
}

Table "Registered Taxpayer" [note: "Doanh nghiệp/hộ kinh doanh đã đăng ký thuế với cơ quan thuế. Lưu thông tin pháp lý và trạng thái hoạt động."] {
  "Registered Taxpayer Id" varchar [pk]
  "Charter Capital Currency Code" varchar
  "Foreign Charter Capital Currency Code" varchar
}

Table "Taxpayer Representative" [note: "Người đại diện hoặc chủ hộ kinh doanh của người nộp thuế. Ghi nhận tên và chức vụ."] {
  "Taxpayer Representative Id" varchar [pk]
  "Registered Taxpayer Id" varchar
}

// Ref: "Registered Taxpayer"."Charter Capital Currency Code" > "Currency"."Currency Code" // out-of-source
// Ref: "Registered Taxpayer"."Foreign Charter Capital Currency Code" > "Currency"."Currency Code" // out-of-source
Ref: "Taxpayer Representative"."Registered Taxpayer Id" > "Registered Taxpayer"."Registered Taxpayer Id"
