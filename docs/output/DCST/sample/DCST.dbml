// Atomic Lakehouse — DCST

Project DCST {
  database_type: "Delta Lake"
  Note: "Atomic Lakehouse — DCST"
}

Table "tax_vln_pny_dcsn" [note: "Quyết định xử lý vi phạm hành chính về thuế. Ghi nhận hành vi vi phạm và mức phạt/truy thu."] {
  "tax_vln_pny_dcsn_id" varchar [pk]
  "rgst_taxpayer_id" varchar
}

Table "tax_dbt_nfrc_ordr" [note: "Quyết định cưỡng chế nợ thuế. Ghi nhận hình thức cưỡng chế và thông tin tài sản/tài khoản liên quan."] {
  "tax_dbt_nfrc_ordr_id" varchar [pk]
  "rgst_taxpayer_id" varchar
}

TableGroup "UID03 — Cưỡng chế nợ thuế" {
  "tax_dbt_nfrc_ordr"
}

TableGroup "UID04 — Xử lý vi phạm pháp luật về thuế" {
  "tax_vln_pny_dcsn"
}

// Ref: "tax_vln_pny_dcsn"."rgst_taxpayer_id" > ""."" // out-of-source
// Ref: "tax_dbt_nfrc_ordr"."rgst_taxpayer_id" > ""."" // out-of-source
