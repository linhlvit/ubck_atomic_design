// Atomic Lakehouse — DCST

Project DCST {
  database_type: "Delta Lake"
  Note: "Atomic Lakehouse — DCST"
}

Table "rgst_taxpayer" [note: "Doanh nghiệp/hộ kinh doanh đã đăng ký thuế với cơ quan thuế. Lưu thông tin pháp lý và trạng thái hoạt động."] {
  "rgst_taxpayer_id" varchar [pk]
  "charter_cptl_ccy_code" varchar
  "frgn_charter_cptl_ccy_code" varchar
}

Table "taxpayer_rprs" [note: "Người đại diện hoặc chủ hộ kinh doanh của người nộp thuế. Ghi nhận tên và chức vụ."] {
  "taxpayer_rprs_id" varchar [pk]
  "rgst_taxpayer_id" varchar
}

TableGroup "UID01 — Quản lý thông tin đăng ký thuế" {
  "rgst_taxpayer"
  "taxpayer_rprs"
}

// Ref: "rgst_taxpayer"."charter_cptl_ccy_code" > ""."" // out-of-source
// Ref: "rgst_taxpayer"."frgn_charter_cptl_ccy_code" > ""."" // out-of-source
Ref: "taxpayer_rprs"."rgst_taxpayer_id" > "rgst_taxpayer"."rgst_taxpayer_id"
