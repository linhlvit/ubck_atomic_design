// QLRR — UID001 Khai thác Dashboard

Project QLRR_UID001 {
  database_type: "Delta Lake"
  Note: "QLRR — UID001 Khai thác Dashboard"
}

Table "rsk_alert" [note: "Bản ghi cảnh báo rủi ro phát sinh khi chỉ tiêu vượt ngưỡng cấu hình. Grain: 1 lần kích hoạt. Append-only. FK → Risk Alert Config + Risk Indicator."] {
  "rsk_alert_id" varchar [pk]
  "rsk_alert_config_id" varchar
  "rsk_ind_id" varchar
  "triggered_by_shd_id" varchar
}

Table "rsk_ind_val" [note: "Giá trị thực tế của chỉ tiêu rủi ro theo từng kỳ (ngày/tháng/quý/năm). Grain: chỉ tiêu × kỳ. Append-only. FK → Risk Indicator."] {
  "rsk_ind_val_id" varchar [pk]
  "rsk_ind_id" varchar
}

Table "rsk_ind_val_chg" [note: "Lịch sử từng lần thay đổi giá trị chỉ tiêu (SYNC tự động / UPDATE thủ công). Grain: 1 lần thay đổi. Append-only. FK → Risk Indicator."] {
  "rsk_ind_val_chg_id" varchar [pk]
  "rsk_ind_id" varchar
}

Table "rsk_ind" [note: "Danh mục chỉ tiêu tài chính rủi ro — gộp chỉ tiêu hệ thống (risk_indicator) và tự tạo (risk_indicator_custom). Phân biệt bằng indicator_type_code. indicator_category_id nullable (chỉ tiêu tự tạo không"] {
  "rsk_ind_id" varchar [pk]
  "rsk_ind_cgy_id" varchar
}

Table "rsk_ind_cgy" [note: "Nhóm phân loại chỉ tiêu tài chính rủi ro theo bộ (trong nước/quốc tế) và nhóm nghiệp vụ (vĩ mô/tiền tệ/thị trường CK). FK nguồn cho Risk Indicator."] {
  "rsk_ind_cgy_id" varchar [pk]
}

// Ref: "rsk_alert"."rsk_alert_config_id" > ""."" // out-of-source
Ref: "rsk_alert"."rsk_ind_id" > "rsk_ind"."rsk_ind_id"
// Ref: "rsk_alert"."triggered_by_shd_id" > ""."" // out-of-source
Ref: "rsk_ind_val"."rsk_ind_id" > "rsk_ind"."rsk_ind_id"
Ref: "rsk_ind_val_chg"."rsk_ind_id" > "rsk_ind"."rsk_ind_id"
Ref: "rsk_ind"."rsk_ind_cgy_id" > "rsk_ind_cgy"."rsk_ind_cgy_id"
