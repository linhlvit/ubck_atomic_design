Ref: "pblc_co_fnc_rpt_val"."fnc_rpt_ctlg_id" > "fnc_rpt_ctlg"."fnc_rpt_ctlg_id"
Ref: "pblc_co_rpt_subm"."pblc_co_id" > "pblc_co"."pblc_co_id"
Ref: "pblc_co_rpt_subm"."dscl_form_defn_id" > "dscl_form_defn"."dscl_form_defn_id"
Ref: "audt_firm_lgl_rprs"."audt_firm_id" > "audt_firm"."audt_firm_id"
Ref: "pblc_co_lgl_rprs"."pblc_co_id" > "pblc_co"."pblc_co_id"
Ref: "pblc_co_rel_ent"."pblc_co_id" > "pblc_co"."pblc_co_id"
