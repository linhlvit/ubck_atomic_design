  "dscl_notf"
  "dscl_form_defn"
  "dscl_notf_config"
  "pblc_co_fnc_rpt_val"
  "pblc_co_rpt_subm"
  "pblc_co"
}

TableGroup "UID06 — Báo cáo tài chính và báo cáo định kỳ" {
  "fnc_rpt_ctlg"
  "fnc_rpt_clmn_tpl"
  "fnc_rpt_row_tpl"
  "prd_rpt_form"
  "prd_rpt_form_clmn_tpl"
  "prd_rpt_form_row_tpl"
  "pblc_co_fnc_rpt_val"
}

TableGroup "UID07 — Quản lý công ty kiểm toán" {
  "audt_firm_sanction"
  "audt_firm_wrn"
  "audt_firm_aprv"
  "auditor_aprv"
  "audt_firm"
  "audt_firm_lgl_rprs"
  "ip_alt_identn"
  "ip_elc_adr"
  "ip_pst_adr"
}

TableGroup "UID08 — Lịch sử thay đổi (SCD2 kỹ thuật)" {
  "pblc_co"
  "stk_hldr"
}

Ref: "pblc_co_ste_cptl"."pblc_co_id" > "pblc_co"."pblc_co_id"
Ref: "stk_hldr_tdg_ac"."stk_hldr_id" > "stk_hldr"."stk_hldr_id"
Ref: "audt_firm_sanction"."audt_firm_aprv_id" > "audt_firm_aprv"."audt_firm_aprv_id"
Ref: "audt_firm_sanction"."auditor_aprv_id" > "auditor_aprv"."auditor_aprv_id"
Ref: "audt_firm_wrn"."audt_firm_aprv_id" > "audt_firm_aprv"."audt_firm_aprv_id"
Ref: "audt_firm_wrn"."auditor_aprv_id" > "auditor_aprv"."auditor_aprv_id"
