  "pblc_co_insp"
  "pblc_co_pny"
  "pblc_co"
}

TableGroup "UID04 — Quản lý cổ đông giao dịch" {
  "stk_hldr_tdg_ac"
  "stk_cntl"
  "pblc_co"
  "stk_hldr"
  "stk_hldr_rltnp"
  "ip_alt_identn"
