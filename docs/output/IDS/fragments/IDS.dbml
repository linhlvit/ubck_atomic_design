// Atomic Lakehouse — IDS

Project IDS {
  database_type: "Delta Lake"
  Note: "Atomic Lakehouse — IDS"
}

Table "pblc_co_ste_cptl" [note: "Thông tin sở hữu nhà nước trong công ty đại chúng — tên đại diện nhà nước và tỷ lệ sở hữu. FK to Public Company."] {
  "pblc_co_ste_cptl_id" varchar [pk]
  "pblc_co_id" varchar
}

Table "stk_hldr_tdg_ac" [note: "Tài khoản giao dịch chứng khoán của cổ đông tại CTCK — số tài khoản và trạng thái. FK to Stock Holder."] {
  "stk_hldr_tdg_ac_id" varchar [pk]
  "stk_hldr_id" varchar
}

Table "audt_firm_sanction" [note: "Xử phạt hành chính đối với công ty kiểm toán hoặc kiểm toán viên — quyết định và nội dung xử phạt. FK nullable: Audit Firm Approval hoặc Auditor Approval."] {
  "audt_firm_sanction_id" varchar [pk]
  "audt_firm_aprv_id" varchar
  "auditor_aprv_id" varchar
}

Table "audt_firm_wrn" [note: "Nhắc nhở từ BTC hoặc UBCKNN đến công ty kiểm toán hoặc kiểm toán viên — số văn bản và nội dung. FK nullable: Audit Firm Approval hoặc Auditor Approval."] {
  "audt_firm_wrn_id" varchar [pk]
  "audt_firm_aprv_id" varchar
  "auditor_aprv_id" varchar
}

Table "pblc_co_cptl_incr" [note: "Tăng vốn điều lệ sau khi thành công ty đại chúng — vốn cuối năm tài chính và số đợt tăng. FK to Public Company."] {
  "pblc_co_cptl_incr_id" varchar [pk]
  "pblc_co_id" varchar
}

Table "pblc_co_cptl_mobilization" [note: "Tăng vốn trước khi thành công ty đại chúng — tổng vốn cuối năm và hình thức tăng. Grain: 1 năm x 1 công ty. FK to Public Company."] {
  "pblc_co_cptl_mobilization_id" varchar [pk]
  "pblc_co_id" varchar
}

Table "pblc_co_insp" [note: "Thanh tra/kiểm tra công ty đại chúng — loại/số quyết định/đơn vị chủ trì/biên bản. FK to Public Company."] {
  "pblc_co_insp_id" varchar [pk]
  "pblc_co_id" varchar
}

Table "pblc_co_pny" [note: "Xử phạt hành chính công ty đại chúng hoặc nhà đầu tư liên quan — hành vi vi phạm và quyết định xử phạt. FK to Public Company."] {
  "pblc_co_pny_id" varchar [pk]
  "pblc_co_id" varchar
}

Table "pblc_co_scr_ofrg" [note: "Hoạt động chào bán/phát hành chứng khoán — loại CK/kế hoạch/kết quả thực tế theo từng hình thức. FK to Public Company."] {
  "pblc_co_scr_ofrg_id" varchar [pk]
  "pblc_co_id" varchar
}

Table "pblc_co_tender_ofr" [note: "Chào mua công khai — bên chào mua/số lượng dự kiến/kết quả/tỷ lệ sở hữu trước-sau. FK to Public Company."] {
  "pblc_co_tender_ofr_id" varchar [pk]
  "pblc_co_id" varchar
}

Table "dscl_notf" [note: "Instance thông báo CBTT gửi đi — nội dung/tiêu đề/ngày gửi/trạng thái. Grain: 1 lần gửi thông báo. FK to Disclosure Form Definition."] {
  "dscl_notf_id" varchar [pk]
  "dscl_form_defn_id" varchar
}

Table "dscl_form_defn" [note: "Định nghĩa loại hồ sơ/tin CBTT — loại form/quy trình duyệt/nghiệp vụ. Master entity của vòng đời CBTT. Self-join parent_form_id."] {
  "dscl_form_defn_id" varchar [pk]
  "prn_dscl_form_defn_id" varchar
}

Table "dscl_notf_config" [note: "Cấu hình thông báo CBTT — kênh gửi/hệ thống nhận/người quản lý. FK to Disclosure Notification."] {
  "dscl_notf_config_id" varchar [pk]
  "dscl_notf_id" varchar
}

Table "fnc_rpt_ctlg" [note: "Danh mục báo cáo tài chính — loại báo cáo/năm/scope hợp nhất/loại hình doanh nghiệp. Master entity FK từ Financial Report Row/Column Template."] {
  "fnc_rpt_ctlg_id" varchar [pk]
}

Table "fnc_rpt_clmn_tpl" [note: "Định nghĩa cột trong biểu mẫu BCTC — mã cột/tên/công thức/thứ tự. FK to Financial Report Catalog."] {
  "fnc_rpt_clmn_tpl_id" varchar [pk]
  "fnc_rpt_ctlg_id" varchar
}

Table "fnc_rpt_row_tpl" [note: "Định nghĩa hàng trong biểu mẫu BCTC — mã hàng/tên/công thức/thứ tự. FK to Financial Report Catalog."] {
  "fnc_rpt_row_tpl_id" varchar [pk]
  "fnc_rpt_ctlg_id" varchar
}

Table "prd_rpt_form" [note: "Biểu mẫu báo cáo định kỳ (thường niên/quý/tháng) cho CBTT. Master entity FK từ Periodic Report Form Row/Column Template."] {
  "prd_rpt_form_id" varchar [pk]
}

Table "prd_rpt_form_clmn_tpl" [note: "Định nghĩa cột trong biểu mẫu báo cáo định kỳ — tên/thứ tự/công thức. FK to Periodic Report Form."] {
  "prd_rpt_form_clmn_tpl_id" varchar [pk]
  "prd_rpt_form_id" varchar
}

Table "prd_rpt_form_row_tpl" [note: "Định nghĩa hàng trong biểu mẫu báo cáo định kỳ — tên/thứ tự/kiểu dữ liệu. FK to Periodic Report Form."] {
  "prd_rpt_form_row_tpl_id" varchar [pk]
  "prd_rpt_form_id" varchar
}

Table "pblc_co_frgn_own_lmt" [note: "Giới hạn tỷ lệ sở hữu nước ngoài của công ty đại chúng — max_owner_rate và khoảng thời gian áp dụng. FK to Public Company."] {
  "pblc_co_frgn_own_lmt_id" varchar [pk]
  "pblc_co_id" varchar
}

Table "stk_cntl" [note: "Hạn chế chuyển nhượng cổ phiếu của cổ đông — số lượng bị hạn chế/thời gian/loại hạn chế. FK to Stock Holder."] {
  "stk_cntl_id" varchar [pk]
  "stk_hldr_id" varchar
}

Table "audt_firm_aprv" [note: "Quyết định chấp thuận/đình chỉ công ty kiểm toán từ BTC và UBCKNN — số văn bản/ngày/nội dung. Gộp 2 cơ quan. FK to Audit Firm."] {
  "audt_firm_aprv_id" varchar [pk]
  "audt_firm_id" varchar
}

Table "auditor_aprv" [note: "Quyết định chấp thuận/đình chỉ kiểm toán viên từ BTC và UBCKNN — chứng chỉ hành nghề/năm chấp thuận. FK to Audit Firm."] {
  "auditor_aprv_id" varchar [pk]
  "audt_firm_id" varchar
}

Table "pblc_co_fnc_rpt_val" [note: "Giá trị từng ô BCTC trong một lần nộp báo cáo đã duyệt. Grain: 1 dòng = 1 ô (lần nộp × biểu mẫu × hàng × cột). FK to Public Company Report Submission và Financial Report Catalog."] {
  "pblc_co_fnc_rpt_val_id" varchar [pk]
  "pblc_co_rpt_subm_id" varchar
  "fnc_rpt_ctlg_id" varchar
}

Table "pblc_co_rpt_subm" [note: "Lần nộp báo cáo/tin CBTT của công ty đại chúng đã được phê duyệt (news_status_cd = APPROVED). Grain: 1 dòng = 1 lần nộp. FK to Public Company và Disclosure Form Definition."] {
  "pblc_co_rpt_subm_id" varchar [pk]
  "pblc_co_id" varchar
  "dscl_form_defn_id" varchar
}

Table "audt_firm" [note: "Công ty kiểm toán được UBCKNN chấp thuận. Ghi nhận thông tin pháp lý và trạng thái hoạt động."] {
  "audt_firm_id" varchar [pk]
}

Table "audt_firm_lgl_rprs" [note: "Người đại diện pháp luật của công ty kiểm toán — chức vụ và ngày bổ nhiệm/kết thúc nhiệm kỳ. FK to Audit Firm."] {
  "audt_firm_lgl_rprs_id" varchar [pk]
  "audt_firm_id" varchar
}

Table "pblc_co" [note: "Công ty đại chúng được UBCKNN quản lý. Lưu thông tin pháp lý và trạng thái hoạt động."] {
  "pblc_co_id" varchar [pk]
}

Table "pblc_co_lgl_rprs" [note: "Người đại diện pháp luật và người CBTT của công ty đại chúng — representative_role_code phân biệt 2 vai trò. FK to Public Company."] {
  "pblc_co_lgl_rprs_id" varchar [pk]
  "pblc_co_id" varchar
}

Table "pblc_co_rel_ent" [note: "Công ty mẹ/con/liên kết của công ty đại chúng — tên/MST/vốn/tỷ lệ sở hữu/thời hạn hiệu lực. FK to Public Company."] {
  "pblc_co_rel_ent_id" varchar [pk]
  "pblc_co_id" varchar
}

Table "stk_hldr" [note: "Cổ đông giao dịch — cá nhân hoặc tổ chức nắm giữ cổ phần công ty đại chúng. Grain: cổ đông x công ty. FK to Public Company."] {
  "stk_hldr_id" varchar [pk]
  "pblc_co_id" varchar
}

Table "stk_hldr_rltnp" [note: "Quan hệ giữa các cổ đông giao dịch — loại quan hệ/thời hạn/trạng thái. FK to Stock Holder x 2."] {
  "stk_hldr_rltnp_id" varchar [pk]
  "stk_hldr_id" varchar
  "rel_stk_hldr_id" varchar
}

Table "pblc_co_trsr_stk_avy" [note: "Giao dịch cổ phiếu quỹ theo năm — số lượng mua/bán và số đợt. FK to Public Company."] {
  "pblc_co_trsr_stk_avy_id" varchar [pk]
  "pblc_co_id" varchar
}

Table "ip_alt_identn" [note: "Lưu trữ các giấy tờ định danh thay thế của Involved Party (CMND/CCCD/Hộ chiếu/Giấy phép kinh doanh/Chứng chỉ hành nghề). Mỗi dòng = 1 loại giấy tờ từ 1 nguồn."] {
  "ip_id" varchar
}

Table "ip_elc_adr" [note: "Lưu trữ các địa chỉ liên lạc điện tử của Involved Party (điện thoại/fax/email). Mỗi dòng = 1 kênh liên lạc từ 1 nguồn."] {
  "ip_id" varchar
}

Table "ip_pst_adr" [note: "Lưu trữ các địa chỉ bưu chính của Involved Party (trụ sở/kinh doanh/thường trú/nơi ở hiện tại). Mỗi dòng = 1 loại địa chỉ từ 1 nguồn."] {
  "ip_id" varchar
  "prov_id" varchar
  "geo_id" varchar
}

TableGroup "UID01 — Quản lý hồ sơ công ty đại chúng" {
  "pblc_co_ste_cptl"
  "pblc_co_frgn_own_lmt"
  "pblc_co"
  "pblc_co_lgl_rprs"
  "pblc_co_rel_ent"
  "ip_elc_adr"
  "ip_pst_adr"
}

