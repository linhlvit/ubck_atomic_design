// IDS — UID04 Quản lý cổ đông giao dịch

Project IDS_UID04 {
  database_type: "Delta Lake"
  Note: "IDS — UID04 Quản lý cổ đông giao dịch"
}

Table "Involved Party Electronic Address" [note: "Lưu trữ các địa chỉ liên lạc điện tử của Involved Party (điện thoại/fax/email). Mỗi dòng = 1 kênh liên lạc từ 1 nguồn."] {
  "Involved Party Id" varchar
}

Table "Involved Party Postal Address" [note: "Lưu trữ các địa chỉ bưu chính của Involved Party (trụ sở/kinh doanh/thường trú/nơi ở hiện tại). Mỗi dòng = 1 loại địa chỉ từ 1 nguồn."] {
  "Involved Party Id" varchar
  "Province Id" varchar
  "Geographic Area Id" varchar
}

Table "Public Company" [note: "Công ty đại chúng được UBCKNN quản lý. Lưu thông tin pháp lý và trạng thái hoạt động."] {
  "Public Company Id" varchar [pk]
}

Table "Stock Holder" [note: "Cổ đông giao dịch — cá nhân hoặc tổ chức nắm giữ cổ phần công ty đại chúng. Grain: cổ đông x công ty. FK to Public Company."] {
  "Stock Holder Id" varchar [pk]
  "Public Company Id" varchar
}

Table "Involved Party Alternative Identification" [note: "Lưu trữ các giấy tờ định danh thay thế của Involved Party (CMND/CCCD/Hộ chiếu/Giấy phép kinh doanh/Chứng chỉ hành nghề). Mỗi dòng = 1 loại giấy tờ từ 1 nguồn."] {
  "Involved Party Id" varchar
}

Table "Stock Holder Trading Account" [note: "Tài khoản giao dịch chứng khoán của cổ đông tại CTCK — số tài khoản và trạng thái. FK to Stock Holder."] {
  "Stock Holder Trading Account Id" varchar [pk]
  "Stock Holder Id" varchar
}

Table "Stock Holder Relationship" [note: "Quan hệ giữa các cổ đông giao dịch — loại quan hệ/thời hạn/trạng thái. FK to Stock Holder x 2."] {
  "Stock Holder Relationship Id" varchar [pk]
  "Stock Holder Id" varchar
  "Related Stock Holder Id" varchar
}

Table "Stock Control" [note: "Hạn chế chuyển nhượng cổ phiếu của cổ đông — số lượng bị hạn chế/thời gian/loại hạn chế. FK to Stock Holder."] {
  "Stock Control Id" varchar [pk]
  "Stock Holder Id" varchar
}

// Ref: "Involved Party Electronic Address"."Involved Party Id" > "Audit Firm"."Audit Firm Id" // out-of-source
// Ref: "Involved Party Postal Address"."Involved Party Id" > "Audit Firm"."Audit Firm Id" // out-of-source
// Ref: "Involved Party Postal Address"."Province Id" > "Geographic Area"."Geographic Area Id" // out-of-source
// Ref: "Involved Party Postal Address"."Geographic Area Id" > "Geographic Area"."Geographic Area Id" // out-of-source
Ref: "Involved Party Postal Address"."Involved Party Id" > "Public Company"."Public Company Id"
Ref: "Involved Party Electronic Address"."Involved Party Id" > "Public Company"."Public Company Id"
Ref: "Stock Holder"."Public Company Id" > "Public Company"."Public Company Id"
Ref: "Involved Party Postal Address"."Involved Party Id" > "Stock Holder"."Stock Holder Id"
Ref: "Involved Party Electronic Address"."Involved Party Id" > "Stock Holder"."Stock Holder Id"
// Ref: "Involved Party Electronic Address"."Involved Party Id" > "Audit Firm Legal Representative"."Audit Firm Legal Representative Id" // out-of-source
// Ref: "Involved Party Alternative Identification"."Involved Party Id" > "Audit Firm Legal Representative"."Audit Firm Legal Representative Id" // out-of-source
// Ref: "Involved Party Electronic Address"."Involved Party Id" > "Public Company Legal Representative"."Public Company Legal Representative Id" // out-of-source
// Ref: "Involved Party Alternative Identification"."Involved Party Id" > "Public Company Legal Representative"."Public Company Legal Representative Id" // out-of-source
Ref: "Involved Party Alternative Identification"."Involved Party Id" > "Stock Holder"."Stock Holder Id"
Ref: "Stock Holder Trading Account"."Stock Holder Id" > "Stock Holder"."Stock Holder Id"
Ref: "Stock Holder Relationship"."Stock Holder Id" > "Stock Holder"."Stock Holder Id"
Ref: "Stock Holder Relationship"."Related Stock Holder Id" > "Stock Holder"."Stock Holder Id"
Ref: "Stock Control"."Stock Holder Id" > "Stock Holder"."Stock Holder Id"
