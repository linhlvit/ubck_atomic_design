// SCMS — UID04 Quản lý ngân hàng thanh toán, lưu ký

Project SCMS_UID04 {
  database_type: "Delta Lake"
  Note: "SCMS — UID04 Quản lý ngân hàng thanh toán, lưu ký"
}

Table "scr_co_rpt_vln" [note: "Vi phạm nộp báo cáo định kỳ của CTCK. Ghi nhận loại vi phạm và thông tin xử lý."] {
  "scr_co_rpt_vln_id" varchar [pk]
  "scr_co_id" varchar
}

Table "mbr_prd_rpt" [note: "Báo cáo định kỳ do thành viên thị trường nộp lên UBCKNN theo từng kỳ báo cáo. Ghi nhận trạng thái nộp và thời hạn."] {
  "mbr_prd_rpt_id" varchar [pk]
  "fnd_mgt_co_id" varchar
  "ivsm_fnd_id" varchar
  "cstd_bnk_id" varchar
  "frgn_fnd_mgt_ou_id" varchar
  "rpt_tpl_id" varchar
  "rpt_prd_id" varchar
  "scr_co_id" varchar
  "rpt_subm_shd_id" varchar
}

Table "mbr_rpt_ind_val" [note: "Giá trị từng chỉ tiêu trong một lần nộp báo cáo định kỳ. Grain = 1 giá trị cell-level (submission x template_indicator x row). FK đến Member Periodic Report."] {
  "mbr_rpt_ind_val_id" varchar [pk]
  "rpt_tpl_id" varchar
  "scr_co_id" varchar
  "rpt_tpl_shet_id" varchar
  "rpt_tpl_row_id" varchar
  "rpt_tpl_clmn_id" varchar
  "mbr_prd_rpt_id" varchar
  "rpt_tpl_ind_id" varchar
  "rpt_ind_id" varchar
}

Table "scr_co" [note: "Công ty chứng khoán - thành viên thị trường trong hệ thống FIMS. Quản lý tài khoản và danh mục NĐT nước ngoài."] {
  "scr_co_id" varchar [pk]
  "cty_of_rgst_id" varchar
}

Ref: "scr_co_rpt_vln"."scr_co_id" > "scr_co"."scr_co_id"
// Ref: "mbr_prd_rpt"."fnd_mgt_co_id" > ""."" // out-of-source
// Ref: "mbr_prd_rpt"."ivsm_fnd_id" > ""."" // out-of-source
// Ref: "mbr_prd_rpt"."cstd_bnk_id" > ""."" // out-of-source
// Ref: "mbr_prd_rpt"."frgn_fnd_mgt_ou_id" > ""."" // out-of-source
// Ref: "mbr_prd_rpt"."rpt_tpl_id" > ""."" // out-of-source
// Ref: "mbr_prd_rpt"."rpt_prd_id" > ""."" // out-of-source
Ref: "mbr_prd_rpt"."scr_co_id" > "scr_co"."scr_co_id"
// Ref: "mbr_prd_rpt"."rpt_subm_shd_id" > ""."" // out-of-source
// Ref: "mbr_rpt_ind_val"."rpt_tpl_id" > ""."" // out-of-source
Ref: "mbr_rpt_ind_val"."scr_co_id" > "scr_co"."scr_co_id"
// Ref: "mbr_rpt_ind_val"."rpt_tpl_shet_id" > ""."" // out-of-source
// Ref: "mbr_rpt_ind_val"."rpt_tpl_row_id" > ""."" // out-of-source
// Ref: "mbr_rpt_ind_val"."rpt_tpl_clmn_id" > ""."" // out-of-source
Ref: "mbr_rpt_ind_val"."mbr_prd_rpt_id" > "mbr_prd_rpt"."mbr_prd_rpt_id"
// Ref: "mbr_rpt_ind_val"."rpt_tpl_ind_id" > ""."" // out-of-source
// Ref: "mbr_rpt_ind_val"."rpt_ind_id" > ""."" // out-of-source
// Ref: "scr_co"."cty_of_rgst_id" > ""."" // out-of-source
