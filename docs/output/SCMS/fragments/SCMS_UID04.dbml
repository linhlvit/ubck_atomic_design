// SCMS — UID04 Quản lý ngân hàng thanh toán, lưu ký

Project SCMS_UID04 {
  database_type: "Delta Lake"
  Note: "SCMS — UID04 Quản lý ngân hàng thanh toán, lưu ký"
}

Table "Securities Company" [note: "Công ty chứng khoán - thành viên thị trường trong hệ thống FIMS. Quản lý tài khoản và danh mục NĐT nước ngoài."] {
  "Securities Company Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Member Periodic Report" [note: "Báo cáo định kỳ do thành viên thị trường nộp lên UBCKNN theo từng kỳ báo cáo. Ghi nhận trạng thái nộp và thời hạn."] {
  "Member Periodic Report Id" varchar [pk]
  "Fund Management Company Id" varchar
  "Investment Fund Id" varchar
  "Custodian Bank Id" varchar
  "Foreign Fund Management Organization Unit Id" varchar
  "Report Template Id" varchar
  "Reporting Period Id" varchar
  "Securities Company Id" varchar
  "Report Submission Schedule Id" varchar
}

Table "Securities Company Report Violation" [note: "Vi phạm nộp báo cáo định kỳ của CTCK. Ghi nhận loại vi phạm và thông tin xử lý."] {
  "Securities Company Report Violation Id" varchar [pk]
  "Securities Company Id" varchar
}

Table "Member Report Indicator Value" [note: "Giá trị từng chỉ tiêu trong một lần nộp báo cáo định kỳ. Grain = 1 giá trị cell-level (submission x template_indicator x row). FK đến Member Periodic Report."] {
  "Member Report Indicator Value Id" varchar [pk]
  "Report Template Id" varchar
  "Securities Company Id" varchar
  "Report Template Sheet Id" varchar
  "Report Template Row Id" varchar
  "Report Template Column Id" varchar
  "Member Periodic Report Id" varchar
  "Report Template Indicator Id" varchar
  "Report Indicator Id" varchar
}

// Ref: "Securities Company"."Country of Registration Id" > "Geographic Area"."Geographic Area Id" // out-of-source
// Ref: "Member Periodic Report"."Fund Management Company Id" > "Fund Management Company"."Fund Management Company Id" // out-of-source
// Ref: "Member Periodic Report"."Investment Fund Id" > "Investment Fund"."Investment Fund Id" // out-of-source
// Ref: "Member Periodic Report"."Custodian Bank Id" > "Custodian Bank"."Custodian Bank Id" // out-of-source
// Ref: "Member Periodic Report"."Foreign Fund Management Organization Unit Id" > "Foreign Fund Management Organization Unit"."Foreign Fund Management Organization Unit Id" // out-of-source
// Ref: "Member Periodic Report"."Report Template Id" > "Report Template"."Report Template Id" // out-of-source
// Ref: "Member Periodic Report"."Reporting Period Id" > "Reporting Period"."Reporting Period Id" // out-of-source
Ref: "Member Periodic Report"."Securities Company Id" > "Securities Company"."Securities Company Id"
// Ref: "Member Periodic Report"."Report Submission Schedule Id" > "Report Submission Schedule"."Report Submission Schedule Id" // out-of-source
Ref: "Securities Company Report Violation"."Securities Company Id" > "Securities Company"."Securities Company Id"
// Ref: "Member Report Indicator Value"."Report Template Id" > "Report Template"."Report Template Id" // out-of-source
Ref: "Member Report Indicator Value"."Securities Company Id" > "Securities Company"."Securities Company Id"
// Ref: "Member Report Indicator Value"."Report Template Sheet Id" > "Report Template Sheet"."Report Template Sheet Id" // out-of-source
// Ref: "Member Report Indicator Value"."Report Template Row Id" > "Report Template Row"."Report Template Row Id" // out-of-source
// Ref: "Member Report Indicator Value"."Report Template Column Id" > "Report Template Column"."Report Template Column Id" // out-of-source
Ref: "Member Report Indicator Value"."Member Periodic Report Id" > "Member Periodic Report"."Member Periodic Report Id"
// Ref: "Member Report Indicator Value"."Report Template Indicator Id" > "Report Template Indicator"."Report Template Indicator Id" // out-of-source
// Ref: "Member Report Indicator Value"."Report Indicator Id" > "Report Indicator"."Report Indicator Id" // out-of-source
