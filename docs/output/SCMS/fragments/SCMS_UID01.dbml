Ref: "ip_alt_identn"."ip_id" > "scr_co_shrhlr"."scr_co_shrhlr_id"
Ref: "ip_alt_identn"."ip_id" > "scr_co_shrhlr_rprs"."scr_co_shrhlr_rprs_id"
