Ref: "scr_co_shrhlr_rel_p"."scr_co_id" > "scr_co"."scr_co_id"
Ref: "scr_co_shrhlr_rprs"."scr_co_shrhlr_id" > "scr_co_shrhlr"."scr_co_shrhlr_id"
