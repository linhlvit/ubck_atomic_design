// SCMS — UID01 Quản lý CTCK

Project SCMS_UID01 {
  database_type: "Delta Lake"
  Note: "SCMS — UID01 Quản lý CTCK"
}

Table "dscl_rpt_subm" [note: "Báo cáo công bố thông tin do CTCK nộp lên UBCKNN theo yêu cầu minh bạch thị trường."] {
  "dscl_rpt_subm_id" varchar [pk]
  "scr_co_id" varchar
}

Table "dscl_scr_ofrg" [note: "Thông tin chào bán chứng khoán được công bố bởi CTCK. Ghi nhận loại chứng khoán và điều kiện chào bán."] {
  "dscl_scr_ofrg_id" varchar [pk]
  "scr_co_id" varchar
}

Table "dscl_shrhlr_chg" [note: "Thông tin thay đổi cổ đông được công bố bởi CTCK. Ghi nhận cổ đông và tỷ lệ sở hữu thay đổi."] {
  "dscl_shrhlr_chg_id" varchar [pk]
  "scr_co_id" varchar
}

Table "scr_co_admn_pny" [note: "Quyết định xử lý hành chính đối với CTCK. Ghi nhận hành vi vi phạm và quyết định xử phạt."] {
  "scr_co_admn_pny_id" varchar [pk]
  "scr_co_id" varchar
}

Table "scr_co_rpt_vln" [note: "Vi phạm nộp báo cáo định kỳ của CTCK. Ghi nhận loại vi phạm và thông tin xử lý."] {
  "scr_co_rpt_vln_id" varchar [pk]
  "scr_co_id" varchar
}

Table "mbr_prd_rpt" [note: "Báo cáo định kỳ do thành viên thị trường nộp lên UBCKNN theo từng kỳ báo cáo. Ghi nhận trạng thái nộp và thời hạn."] {
  "mbr_prd_rpt_id" varchar [pk]
  "fnd_mgt_co_id" varchar
  "ivsm_fnd_id" varchar
  "cstd_bnk_id" varchar
  "frgn_fnd_mgt_ou_id" varchar
  "rpt_tpl_id" varchar
  "rpt_prd_id" varchar
  "scr_co_id" varchar
  "rpt_subm_shd_id" varchar
}

Table "mbr_rpt_ind_val" [note: "Giá trị từng chỉ tiêu trong một lần nộp báo cáo định kỳ. Grain = 1 giá trị cell-level (submission x template_indicator x row). FK đến Member Periodic Report."] {
  "mbr_rpt_ind_val_id" varchar [pk]
  "rpt_tpl_id" varchar
  "scr_co_id" varchar
  "rpt_tpl_shet_id" varchar
  "rpt_tpl_row_id" varchar
  "rpt_tpl_clmn_id" varchar
  "mbr_prd_rpt_id" varchar
  "rpt_tpl_ind_id" varchar
  "rpt_ind_id" varchar
}

Table "scr_co" [note: "Công ty chứng khoán - thành viên thị trường trong hệ thống FIMS. Quản lý tài khoản và danh mục NĐT nước ngoài."] {
  "scr_co_id" varchar [pk]
  "cty_of_rgst_id" varchar
}

Table "scr_co_ou" [note: "Đơn vị trực thuộc CTCK: chi nhánh, văn phòng đại diện, phòng giao dịch. Cấu trúc self-join qua parent_org_unit_id."] {
  "scr_co_ou_id" varchar [pk]
  "scr_co_id" varchar
  "prn_ou_id" varchar
}

Table "scr_co_snr_psn" [note: "Nhân sự cao cấp của CTCK (Chủ tịch HĐQT, Tổng Giám đốc, Kế toán trưởng...). Ghi nhận chức vụ và thời gian đảm nhận."] {
  "scr_co_snr_psn_id" varchar [pk]
  "scr_co_id" varchar
  "ou_id" varchar
  "nat_id" varchar
}

Table "scr_co_svc_rgst" [note: "Đăng ký dịch vụ của CTCK tại UBCKNN. Grain: 1 dòng = 1 dịch vụ x 1 CTCK. Ghi nhận loại dịch vụ — số văn bản và ngày đăng ký/kết thúc — trạng thái hiệu lực."] {
  "scr_co_svc_rgst_id" varchar [pk]
  "scr_co_id" varchar
}

Table "scr_co_shrhlr" [note: "Cổ đông của CTCK - cá nhân hoặc tổ chức. Ghi nhận tỷ lệ sở hữu và số lượng cổ phần."] {
  "scr_co_shrhlr_id" varchar [pk]
  "scr_co_id" varchar
  "nat_id" varchar
}

Table "scr_co_shrhlr_rel_p" [note: "Người có quan hệ gia đình hoặc công tác với cổ đông của CTCK. Ghi nhận loại quan hệ và nơi làm việc."] {
  "scr_co_shrhlr_rel_p_id" varchar [pk]
  "scr_co_shrhlr_id" varchar
  "scr_co_id" varchar
}

Table "scr_co_shrhlr_rprs" [note: "Người đại diện được ủy quyền bởi cổ đông của CTCK. Ghi nhận chức vụ và số lượng cổ phần đại diện."] {
  "scr_co_shrhlr_rprs_id" varchar [pk]
  "scr_co_shrhlr_id" varchar
  "scr_co_id" varchar
}

Table "scr_prac" [note: "Người hành nghề chứng khoán được UBCKNN cấp phép. Ghi nhận thông tin cá nhân và trạng thái hành nghề. Attribute chi tiết (BirthDate full"] {
  "prac_id" varchar [pk]
  "cty_of_rsdnc_geo_id" varchar
  "scr_co_id" varchar
}

Table "scr_co_shrhlr_tfr" [note: "Giao dịch chuyển nhượng cổ phần giữa hai cổ đông của CTCK. Ghi nhận bên chuyển/nhận, số lượng và tỷ lệ chuyển nhượng."] {
  "scr_co_shrhlr_tfr_id" varchar [pk]
  "scr_co_id" varchar
  "fm_shrhlr_id" varchar
  "to_shrhlr_id" varchar
}

Table "ip_alt_identn" [note: "Lưu trữ các giấy tờ định danh thay thế của Involved Party (CMND/CCCD/Hộ chiếu/Giấy phép kinh doanh/Chứng chỉ hành nghề). Mỗi dòng = 1 loại giấy tờ từ 1 nguồn."] {
  "ip_id" varchar
}

Table "ip_elc_adr" [note: "Lưu trữ các địa chỉ liên lạc điện tử của Involved Party (điện thoại/fax/email). Mỗi dòng = 1 kênh liên lạc từ 1 nguồn."] {
  "ip_id" varchar
}

Table "ip_pst_adr" [note: "Lưu trữ các địa chỉ bưu chính của Involved Party (trụ sở/kinh doanh/thường trú/nơi ở hiện tại). Mỗi dòng = 1 loại địa chỉ từ 1 nguồn."] {
  "ip_id" varchar
  "prov_id" varchar
  "geo_id" varchar
}

Ref: "dscl_rpt_subm"."scr_co_id" > "scr_co"."scr_co_id"
Ref: "dscl_scr_ofrg"."scr_co_id" > "scr_co"."scr_co_id"
Ref: "dscl_shrhlr_chg"."scr_co_id" > "scr_co"."scr_co_id"
Ref: "scr_co_admn_pny"."scr_co_id" > "scr_co"."scr_co_id"
Ref: "scr_co_rpt_vln"."scr_co_id" > "scr_co"."scr_co_id"
// Ref: "mbr_prd_rpt"."fnd_mgt_co_id" > ""."" // out-of-source
