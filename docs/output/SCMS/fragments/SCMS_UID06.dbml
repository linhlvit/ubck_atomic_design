// SCMS — UID06 Cảnh báo vi phạm

Project SCMS_UID06 {
  database_type: "Delta Lake"
  Note: "SCMS — UID06 Cảnh báo vi phạm"
}

Table "mbr_prd_rpt" [note: "Báo cáo định kỳ do thành viên thị trường nộp lên UBCKNN theo từng kỳ báo cáo. Ghi nhận trạng thái nộp và thời hạn."] {
  "mbr_prd_rpt_id" varchar [pk]
  "fnd_mgt_co_id" varchar
  "ivsm_fnd_id" varchar
  "cstd_bnk_id" varchar
  "frgn_fnd_mgt_ou_id" varchar
  "rpt_tpl_id" varchar
  "rpt_prd_id" varchar
  "scr_co_id" varchar
  "rpt_subm_shd_id" varchar
}

Table "mbr_rpt_ind_val" [note: "Giá trị từng chỉ tiêu trong một lần nộp báo cáo định kỳ. Grain = 1 giá trị cell-level (submission x template_indicator x row). FK đến Member Periodic Report."] {
  "mbr_rpt_ind_val_id" varchar [pk]
  "rpt_tpl_id" varchar
  "scr_co_id" varchar
  "rpt_tpl_shet_id" varchar
  "rpt_tpl_row_id" varchar
  "rpt_tpl_clmn_id" varchar
  "mbr_prd_rpt_id" varchar
  "rpt_tpl_ind_id" varchar
  "rpt_ind_id" varchar
}

// Ref: "mbr_prd_rpt"."fnd_mgt_co_id" > ""."" // out-of-source
