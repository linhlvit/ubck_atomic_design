// SCMS — UID06 Cảnh báo vi phạm

Project SCMS_UID06 {
  database_type: "Delta Lake"
  Note: "SCMS — UID06 Cảnh báo vi phạm"
}

Table "Report Indicator" [note: ""] {
  "_id" bigint
}

Table "Member Periodic Report" [note: "Báo cáo định kỳ do thành viên thị trường nộp lên UBCKNN theo từng kỳ báo cáo. Ghi nhận trạng thái nộp và thời hạn."] {
  "Member Periodic Report Id" varchar [pk]
  "Fund Management Company Id" varchar
  "Investment Fund Id" varchar
  "Custodian Bank Id" varchar
  "Foreign Fund Management Organization Unit Id" varchar
  "Report Template Id" varchar
  "Reporting Period Id" varchar
  "Securities Company Id" varchar
  "Report Submission Schedule Id" varchar
}

Table "Member Report Indicator Value" [note: "Giá trị từng chỉ tiêu trong một lần nộp báo cáo định kỳ. Grain = 1 giá trị cell-level (submission x template_indicator x row). FK đến Member Periodic Report."] {
  "Member Report Indicator Value Id" varchar [pk]
  "Report Template Id" varchar
  "Securities Company Id" varchar
  "Report Template Sheet Id" varchar
  "Report Template Row Id" varchar
  "Report Template Column Id" varchar
  "Member Periodic Report Id" varchar
  "Report Template Indicator Id" varchar
  "Report Indicator Id" varchar
}

