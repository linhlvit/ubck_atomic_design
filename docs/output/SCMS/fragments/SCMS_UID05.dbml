// Ref: "Involved Party Alternative Identification"."Involved Party Id" > "Practitioner"."Practitioner Id" // out-of-source
// Ref: "Involved Party Postal Address"."Involved Party Id" > "Securities Company Senior Personnel"."Securities Company Senior Personnel Id" // out-of-source
// Ref: "Involved Party Electronic Address"."Involved Party Id" > "Securities Company Senior Personnel"."Securities Company Senior Personnel Id" // out-of-source
// Ref: "Involved Party Alternative Identification"."Involved Party Id" > "Securities Company Senior Personnel"."Securities Company Senior Personnel Id" // out-of-source
// Ref: "Involved Party Postal Address"."Involved Party Id" > "Securities Company Shareholder"."Securities Company Shareholder Id" // out-of-source
// Ref: "Involved Party Alternative Identification"."Involved Party Id" > "Securities Company Shareholder"."Securities Company Shareholder Id" // out-of-source
Ref: "Audit Firm Practitioner"."Audit Firm Id" > "Audit Firm"."Audit Firm Id"
Ref: "Involved Party Alternative Identification"."Involved Party Id" > "Audit Firm Practitioner"."Audit Firm Practitioner Id"
