// SCMS — UID05 Khai thác công ty kiểm toán và kiểm toán viên

Project SCMS_UID05 {
  database_type: "Delta Lake"
  Note: "SCMS — UID05 Khai thác công ty kiểm toán và kiểm toán viên"
}

Table "audt_firm" [note: "Công ty kiểm toán được UBCKNN chấp thuận. Ghi nhận thông tin pháp lý và trạng thái hoạt động."] {
  "audt_firm_id" varchar [pk]
}

Table "audt_firm_prac" [note: "Kiểm toán viên thuộc công ty kiểm toán. Ghi nhận chứng chỉ kiểm toán và trạng thái hành nghề."] {
  "audt_firm_prac_id" varchar [pk]
  "audt_firm_id" varchar
}

Table "ip_alt_identn" [note: "Lưu trữ các giấy tờ định danh thay thế của Involved Party (CMND/CCCD/Hộ chiếu/Giấy phép kinh doanh/Chứng chỉ hành nghề). Mỗi dòng = 1 loại giấy tờ từ 1 nguồn."] {
  "ip_id" varchar
}

Table "ip_elc_adr" [note: "Lưu trữ các địa chỉ liên lạc điện tử của Involved Party (điện thoại/fax/email). Mỗi dòng = 1 kênh liên lạc từ 1 nguồn."] {
  "ip_id" varchar
}

Table "ip_pst_adr" [note: "Lưu trữ các địa chỉ bưu chính của Involved Party (trụ sở/kinh doanh/thường trú/nơi ở hiện tại). Mỗi dòng = 1 loại địa chỉ từ 1 nguồn."] {
  "ip_id" varchar
  "prov_id" varchar
  "geo_id" varchar
}

Ref: "audt_firm_prac"."audt_firm_id" > "audt_firm"."audt_firm_id"
Ref: "ip_alt_identn"."ip_id" > "audt_firm"."audt_firm_id"
// Ref: "ip_alt_identn"."ip_id" > ""."" // out-of-source
Ref: "ip_alt_identn"."ip_id" > "audt_firm_prac"."audt_firm_prac_id"
// Ref: "ip_elc_adr"."ip_id" > ""."" // out-of-source
Ref: "ip_elc_adr"."ip_id" > "audt_firm"."audt_firm_id"
// Ref: "ip_pst_adr"."ip_id" > ""."" // out-of-source
// Ref: "ip_pst_adr"."prov_id" > ""."" // out-of-source
// Ref: "ip_pst_adr"."geo_id" > ""."" // out-of-source
Ref: "ip_pst_adr"."ip_id" > "audt_firm"."audt_firm_id"
