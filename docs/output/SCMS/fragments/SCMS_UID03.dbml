// SCMS — UID03 Quản lý VPDD CTCK nước ngoài tại VN

Project SCMS_UID03 {
  database_type: "Delta Lake"
  Note: "SCMS — UID03 Quản lý VPDD CTCK nước ngoài tại VN"
}

Table "Foreign Representative Office" [note: "Văn phòng đại diện của công ty chứng khoán nước ngoài tại Việt Nam. Pháp nhân độc lập, không FK đến CTCK trong nước."] {
  foreign_representative_office_id bigint [pk]
  nationality_id bigint
}

Table "Securities Company Senior Personnel" [note: "Nhân sự cao cấp của CTCK (Chủ tịch HĐQT, Tổng Giám đốc, Kế toán trưởng...). Ghi nhận chức vụ và thời gian đảm nhận."] {
  securities_company_senior_personnel_id bigint [pk]
  securities_company_id bigint
  organization_unit_id bigint
  nationality_id bigint
}

Table "Member Periodic Report" [note: "Báo cáo định kỳ do thành viên thị trường nộp lên UBCKNN theo từng kỳ báo cáo. Ghi nhận trạng thái nộp và thời hạn."] {
  member_periodic_report_id bigint [pk]
  fund_management_company_id bigint
  investment_fund_id bigint
  custodian_bank_id bigint
  foreign_fund_management_organization_unit_id bigint
  report_template_id bigint
  reporting_period_id bigint
  securities_company_id bigint
  report_submission_schedule_id bigint
}

Table "Member Report Indicator Value" [note: "Giá trị từng chỉ tiêu trong một lần nộp báo cáo định kỳ. Grain = 1 giá trị cell-level (submission x template_indicator x row). FK đến Member Periodic Report."] {
  member_report_indicator_value_id bigint [pk]
  report_template_id bigint
  securities_company_id bigint
  report_template_sheet_id bigint
  report_template_row_id bigint
  report_template_column_id bigint
  member_periodic_report_id bigint
  report_template_indicator_id bigint
  report_indicator_id bigint
}

// Ref: "Foreign Representative Office".nationality_id > "Geographic Area".geographic_area_id // out-of-source
// Ref: "Securities Company Senior Personnel".securities_company_id > "Securities Company".securities_company_id // out-of-source
// Ref: "Securities Company Senior Personnel".organization_unit_id > "Securities Company Organization Unit".securities_company_organization_unit_id // out-of-source
// Ref: "Securities Company Senior Personnel".nationality_id > "Geographic Area".geographic_area_id // out-of-source
