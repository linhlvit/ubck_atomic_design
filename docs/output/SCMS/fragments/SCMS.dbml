// Silver Lakehouse — SCMS

Project SCMS {
  database_type: "Delta Lake"
  Note: "Silver Lakehouse — SCMS"
}

Table "Securities Company" [note: "Công ty chứng khoán - thành viên thị trường trong hệ thống FIMS. Quản lý tài khoản và danh mục NĐT nước ngoài."] {
  "Securities Company Id" varchar [pk]
  "Country of Registration Id" varchar
}

Table "Audit Firm" [note: "Công ty kiểm toán được UBCKNN chấp thuận. Ghi nhận thông tin pháp lý và trạng thái hoạt động."] {
  "Audit Firm Id" varchar [pk]
}

Table "Involved Party Alternative Identification" [note: "Lưu trữ các giấy tờ định danh thay thế của Involved Party (CMND/CCCD/Hộ chiếu/Giấy phép kinh doanh/Chứng chỉ hành nghề). Mỗi dòng = 1 loại giấy tờ từ 1 nguồn."] {
  "Involved Party Id" varchar
}

Table "Foreign Representative Office" [note: "Văn phòng đại diện của công ty chứng khoán nước ngoài tại Việt Nam. Pháp nhân độc lập, không FK đến CTCK trong nước."] {
  "Foreign Representative Office Id" varchar [pk]
  "Nationality Id" varchar
}

Table "Geographic Area" [note: "Đơn vị địa lý dùng làm FK tham chiếu: quốc gia/quốc tịch (COUNTRY), vùng/miền (REGION), tỉnh/thành phố mới/cũ (PROVINCE/PROVINCE_OLD), quận/huyện cũ (DISTRICT_OLD), phường/xã mới/cũ (WARD/WARD_OLD). P"] {
  "Geographic Area Id" varchar [pk]
}

Table "Report Template" [note: "Biểu mẫu báo cáo đầu vào - khuôn mẫu tờ khai định kỳ mà thành viên thị trường phải nộp theo quy định."] {
  "Report Template Id" varchar [pk]
}

Table "Involved Party Postal Address" [note: "Lưu trữ các địa chỉ bưu chính của Involved Party (trụ sở/kinh doanh/thường trú/nơi ở hiện tại). Mỗi dòng = 1 loại địa chỉ từ 1 nguồn."] {
  "Involved Party Id" varchar
  "Province Id" varchar
  "Geographic Area Id" varchar
}

Table "Involved Party Electronic Address" [note: "Lưu trữ các địa chỉ liên lạc điện tử của Involved Party (điện thoại/fax/email). Mỗi dòng = 1 kênh liên lạc từ 1 nguồn."] {
  "Involved Party Id" varchar
}

Table "Securities Company Organization Unit" [note: "Đơn vị trực thuộc CTCK: chi nhánh, văn phòng đại diện, phòng giao dịch. Cấu trúc self-join qua parent_org_unit_id."] {
  "Securities Company Organization Unit Id" varchar [pk]
  "Securities Company Id" varchar
  "Parent Organization Unit Id" varchar
}

Table "Securities Practitioner" [note: "Người hành nghề chứng khoán được UBCKNN cấp phép. Ghi nhận thông tin cá nhân và trạng thái hành nghề. Attribute chi tiết (BirthDate full"] {
  "Practitioner Id" varchar [pk]
  "Country of Residence Geographic Area Id" varchar
  "Securities Company Id" varchar
}

Table "Securities Company Senior Personnel" [note: "Nhân sự cao cấp của CTCK (Chủ tịch HĐQT, Tổng Giám đốc, Kế toán trưởng...). Ghi nhận chức vụ và thời gian đảm nhận."] {
  "Securities Company Senior Personnel Id" varchar [pk]
  "Securities Company Id" varchar
  "Organization Unit Id" varchar
  "Nationality Id" varchar
}

Table "Securities Company Shareholder" [note: "Cổ đông của CTCK - cá nhân hoặc tổ chức. Ghi nhận tỷ lệ sở hữu và số lượng cổ phần."] {
  "Securities Company Shareholder Id" varchar [pk]
  "Securities Company Id" varchar
  "Nationality Id" varchar
}

Table "Audit Firm Practitioner" [note: "Kiểm toán viên thuộc công ty kiểm toán. Ghi nhận chứng chỉ kiểm toán và trạng thái hành nghề."] {
  "Audit Firm Practitioner Id" varchar [pk]
  "Audit Firm Id" varchar
}

Table "Report Template Sheet" [note: ""] {
  "_id" bigint
}

Table "Report Template Row" [note: ""] {
  "_id" bigint
}

Table "Report Template Column" [note: ""] {
  "_id" bigint
}

Table "Report Submission Schedule" [note: "Lịch định kỳ gửi báo cáo theo biểu mẫu (hàng ngày/tuần/tháng/quý/năm). Xác định tần suất nghĩa vụ nộp báo cáo."] {
  "Report Submission Schedule Id" varchar [pk]
  "Report Template Id" varchar
}

Table "Report Indicator" [note: ""] {
  "_id" bigint
}

Table "Report Template Indicator" [note: ""] {
  "_id" bigint
}

Table "Report Submission Obligation" [note: "Nghĩa vụ gửi báo cáo của từng CTCK theo định kỳ cụ thể. Xác định đơn vị nào phải nộp biểu mẫu nào theo lịch nào."] {
  "Report Submission Obligation Id" varchar [pk]
  "Report Submission Schedule Id" varchar
  "Securities Company Id" varchar
}

Table "Member Periodic Report" [note: "Báo cáo định kỳ do thành viên thị trường nộp lên UBCKNN theo từng kỳ báo cáo. Ghi nhận trạng thái nộp và thời hạn."] {
  "Member Periodic Report Id" varchar [pk]
  "Fund Management Company Id" varchar
  "Investment Fund Id" varchar
  "Custodian Bank Id" varchar
  "Foreign Fund Management Organization Unit Id" varchar
  "Report Template Id" varchar
  "Reporting Period Id" varchar
  "Securities Company Id" varchar
  "Report Submission Schedule Id" varchar
}

Table "Securities Company Report Violation" [note: "Vi phạm nộp báo cáo định kỳ của CTCK. Ghi nhận loại vi phạm và thông tin xử lý."] {
  "Securities Company Report Violation Id" varchar [pk]
  "Securities Company Id" varchar
}

Table "Securities Company Administrative Penalty" [note: "Quyết định xử lý hành chính đối với CTCK. Ghi nhận hành vi vi phạm và quyết định xử phạt."] {
  "Securities Company Administrative Penalty Id" varchar [pk]
  "Securities Company Id" varchar
}

Table "Disclosure Report Submission" [note: "Báo cáo công bố thông tin do CTCK nộp lên UBCKNN theo yêu cầu minh bạch thị trường."] {
  "Disclosure Report Submission Id" varchar [pk]
  "Securities Company Id" varchar
}

Table "Disclosure Securities Offering" [note: "Thông tin chào bán chứng khoán được công bố bởi CTCK. Ghi nhận loại chứng khoán và điều kiện chào bán."] {
  "Disclosure Securities Offering Id" varchar [pk]
  "Securities Company Id" varchar
}

Table "Disclosure Shareholder Change" [note: "Thông tin thay đổi cổ đông được công bố bởi CTCK. Ghi nhận cổ đông và tỷ lệ sở hữu thay đổi."] {
  "Disclosure Shareholder Change Id" varchar [pk]
  "Securities Company Id" varchar
}

Table "Member Report Indicator Value" [note: "Giá trị từng chỉ tiêu trong một lần nộp báo cáo định kỳ. Grain = 1 giá trị cell-level (submission x template_indicator x row). FK đến Member Periodic Report."] {
  "Member Report Indicator Value Id" varchar [pk]
  "Report Template Id" varchar
  "Securities Company Id" varchar
  "Report Template Sheet Id" varchar
  "Report Template Row Id" varchar
  "Report Template Column Id" varchar
  "Member Periodic Report Id" varchar
  "Report Template Indicator Id" varchar
  "Report Indicator Id" varchar
}

Table "Securities Company Shareholder Transfer" [note: "Giao dịch chuyển nhượng cổ phần giữa hai cổ đông của CTCK. Ghi nhận bên chuyển/nhận, số lượng và tỷ lệ chuyển nhượng."] {
  "Securities Company Shareholder Transfer Id" varchar [pk]
  "Securities Company Id" varchar
  "From Shareholder Id" varchar
  "To Shareholder Id" varchar
}

Table "Securities Company Shareholder Representative" [note: "Người đại diện được ủy quyền bởi cổ đông của CTCK. Ghi nhận chức vụ và số lượng cổ phần đại diện."] {
  "Securities Company Shareholder Representative Id" varchar [pk]
  "Securities Company Shareholder Id" varchar
  "Securities Company Id" varchar
}

Table "Securities Company Shareholder Related Party" [note: "Người có quan hệ gia đình hoặc công tác với cổ đông của CTCK. Ghi nhận loại quan hệ và nơi làm việc."] {
  "Securities Company Shareholder Related Party Id" varchar [pk]
  "Securities Company Shareholder Id" varchar
  "Securities Company Id" varchar
}

TableGroup "UID01 — Quản lý CTCK" {
  "Securities Company"
  "Involved Party Alternative Identification"
  "Involved Party Postal Address"
  "Involved Party Electronic Address"
  "Securities Company Organization Unit"
  "Securities Practitioner"
  "Securities Company Senior Personnel"
  "Securities Company Shareholder"
  "Member Periodic Report"
  "Securities Company Report Violation"
  "Securities Company Administrative Penalty"
  "Disclosure Report Submission"
  "Disclosure Securities Offering"
  "Disclosure Shareholder Change"
  "Member Report Indicator Value"
  "Securities Company Shareholder Transfer"
  "Securities Company Shareholder Representative"
  "Securities Company Shareholder Related Party"
}

TableGroup "UID02 — Quản lý CN CTCK nước ngoài tại VN" {
  "Securities Company"
  "Securities Practitioner"
  "Securities Company Senior Personnel"
  "Member Periodic Report"
  "Disclosure Report Submission"
  "Member Report Indicator Value"
}

TableGroup "UID03 — Quản lý VPDD CTCK nước ngoài tại VN" {
  "Foreign Representative Office"
  "Securities Company Senior Personnel"
  "Member Periodic Report"
  "Member Report Indicator Value"
}

TableGroup "UID04 — Quản lý ngân hàng thanh toán, lưu ký" {
  "Securities Company"
  "Member Periodic Report"
  "Securities Company Report Violation"
  "Member Report Indicator Value"
}

TableGroup "UID05 — Khai thác công ty kiểm toán và kiểm toán viên" {
  "Audit Firm"
  "Involved Party Alternative Identification"
  "Involved Party Postal Address"
  "Involved Party Electronic Address"
  "Audit Firm Practitioner"
}

TableGroup "UID06 — Cảnh báo vi phạm" {
  "Report Indicator"
  "Member Periodic Report"
  "Member Report Indicator Value"
}

TableGroup "UID08 — Quản trị phân hệ" {
  "Geographic Area"
  "Report Template"
  "Report Template Sheet"
  "Report Template Row"
  "Report Template Column"
  "Report Submission Schedule"
  "Report Indicator"
  "Report Template Indicator"
  "Report Submission Obligation"
}

