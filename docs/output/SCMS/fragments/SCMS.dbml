Ref: "mbr_prd_rpt"."rpt_tpl_id" > "rpt_tpl"."rpt_tpl_id"
// Ref: "mbr_prd_rpt"."rpt_prd_id" > ""."" // out-of-source
Ref: "mbr_prd_rpt"."scr_co_id" > "scr_co"."scr_co_id"
Ref: "mbr_prd_rpt"."rpt_subm_shd_id" > "rpt_subm_shd"."rpt_subm_shd_id"
Ref: "rpt_subm_oblg"."rpt_subm_shd_id" > "rpt_subm_shd"."rpt_subm_shd_id"
