// Ref: "Member Periodic Report".reporting_period_id > "Reporting Period".reporting_period_id // out-of-source
Ref: "Member Periodic Report".securities_company_id > "Securities Company".securities_company_id
// Ref: "Member Periodic Report".report_submission_schedule_id > "Report Submission Schedule".report_submission_schedule_id // out-of-source
Ref: "Disclosure Report Submission".securities_company_id > "Securities Company".securities_company_id
// Ref: "Member Report Indicator Value".report_template_id > "Report Template".report_template_id // out-of-source
Ref: "Member Report Indicator Value".securities_company_id > "Securities Company".securities_company_id
// Ref: "Member Report Indicator Value".report_template_sheet_id > "Report Template Sheet".report_template_sheet_id // out-of-source
// Ref: "Member Report Indicator Value".report_template_row_id > "Report Template Row".report_template_row_id // out-of-source
// Ref: "Member Report Indicator Value".report_template_column_id > "Report Template Column".report_template_column_id // out-of-source
Ref: "Member Report Indicator Value".member_periodic_report_id > "Member Periodic Report".member_periodic_report_id
