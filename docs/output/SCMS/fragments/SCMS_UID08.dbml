// SCMS — UID08 Quản trị phân hệ

Project SCMS_UID08 {
  database_type: "Delta Lake"
  Note: "SCMS — UID08 Quản trị phân hệ"
}

Table "rpt_subm_oblg" [note: "Nghĩa vụ gửi báo cáo của từng CTCK theo định kỳ cụ thể. Xác định đơn vị nào phải nộp biểu mẫu nào theo lịch nào."] {
  "rpt_subm_oblg_id" varchar [pk]
  "rpt_subm_shd_id" varchar
  "scr_co_id" varchar
}

Table "rpt_subm_shd" [note: "Lịch định kỳ gửi báo cáo theo biểu mẫu (hàng ngày/tuần/tháng/quý/năm). Xác định tần suất nghĩa vụ nộp báo cáo."] {
  "rpt_subm_shd_id" varchar [pk]
  "rpt_tpl_id" varchar
}

Table "rpt_tpl" [note: "Biểu mẫu báo cáo đầu vào - khuôn mẫu tờ khai định kỳ mà thành viên thị trường phải nộp theo quy định."] {
  "rpt_tpl_id" varchar [pk]
}

Table "geo" [note: "Đơn vị địa lý dùng làm FK tham chiếu: quốc gia/quốc tịch (COUNTRY), vùng/miền (REGION), tỉnh/thành phố mới/cũ (PROVINCE/PROVINCE_OLD), quận/huyện cũ (DISTRICT_OLD), phường/xã mới/cũ (WARD/WARD_OLD). P"] {
  "geo_id" varchar [pk]
  "prn_geo_id" varchar
}

Ref: "rpt_subm_oblg"."rpt_subm_shd_id" > "rpt_subm_shd"."rpt_subm_shd_id"
// Ref: "rpt_subm_oblg"."scr_co_id" > ""."" // out-of-source
Ref: "rpt_subm_shd"."rpt_tpl_id" > "rpt_tpl"."rpt_tpl_id"
Ref: "geo"."prn_geo_id" > "geo"."geo_id"
