// MDDS — UID01 Thị trường và chỉ số tổng hợp

Project MDDS_UID01 {
  database_type: "Delta Lake"
  Note: "MDDS — UID01 Thị trường và chỉ số tổng hợp"
}

Table "indx_constituent_snpst" [note: "Snapshot thành phần rổ chỉ số thị trường: mã chứng khoán thuộc rổ nào (IndexCode × Symbol × ngày giao dịch). Có attribute nghiệp vụ: tỷ trọng (Weighted) và ngày vào rổ (AddDate)."] {
  "indx_constituent_snpst_id" varchar [pk]
  "mkt_indx_snpst_id" varchar
  "scr_tdg_snpst_id" varchar
}

Table "mkt_indx_snpst" [note: "Snapshot thông tin chỉ số thị trường chứng khoán (VN30/VNINDEX/HNX30...) tại thời điểm phát sinh: giá trị chỉ số"] {
  "mkt_indx_snpst_id" varchar [pk]
}

Table "mkt_snpst" [note: "Snapshot trạng thái tổng hợp toàn sàn giao dịch (HOSE/HNX/UPCOM) tại mỗi thời điểm: điểm chỉ số sàn"] {
  "mkt_snpst_id" varchar [pk]
}

Table "scr_tdg_snpst" [note: "Snapshot trạng thái giao dịch đa loại chứng khoán (cổ phiếu/CCQ/chứng quyền/phái sinh) tại thời điểm có thay đổi lệnh/khớp lệnh: giá tham chiếu/trần/sàn"] {
  "scr_tdg_snpst_id" varchar [pk]
  "ulyg_imt_id" varchar
}

Ref: "indx_constituent_snpst"."mkt_indx_snpst_id" > "mkt_indx_snpst"."mkt_indx_snpst_id"
Ref: "indx_constituent_snpst"."scr_tdg_snpst_id" > "scr_tdg_snpst"."scr_tdg_snpst_id"
Ref: "scr_tdg_snpst"."ulyg_imt_id" > "scr_tdg_snpst"."scr_tdg_snpst_id"
