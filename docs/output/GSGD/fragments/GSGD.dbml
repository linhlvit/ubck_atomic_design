Ref: "Market Surveillance Account Relationship Analysis Result".market_surveillance_case_id > "Market Surveillance Case".market_surveillance_case_id
Ref: "Market Surveillance Account Relationship Analysis Result".investor_account_relationship_id > "Investor Account Relationship".investor_account_relationship_id
