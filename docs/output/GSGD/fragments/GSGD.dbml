// Atomic Lakehouse — GSGD

Project GSGD {
  database_type: "Delta Lake"
  Note: "Atomic Lakehouse — GSGD"
}

Table "ivsr_ac_rltnp" [note: "Quan hệ giữa 2 tài khoản nhà đầu tư trong giám sát (IP address, MAC address, chuyển tiền). Ghi nhận độ mạnh quan hệ. FK Investor Trading Account (x2) + Account Investor Group."] {
  "ivsr_ac_rltnp_id" varchar [pk]
  "frst_ivsr_tdg_ac_id" varchar
  "scd_ivsr_tdg_ac_id" varchar
  "ac_ivsr_grp_id" varchar
}

Table "ivsr_tdg_ac" [note: "Tài khoản giao dịch chứng khoán của nhà đầu tư trong hệ thống GSGD. Grain: 1 dòng = 1 tài khoản (phân biệt theo account_code từ VSDC). Bao gồm cá nhân và tổ chức, trong nước và nước ngoài."] {
  "ivsr_tdg_ac_id" varchar [pk]
}

Table "ivsr_tdg_ac_ahr" [note: "Ủy quyền giao dịch chứng khoán trên tài khoản nhà đầu tư. FK Investor Trading Account."] {
  "ivsr_tdg_ac_ahr_id" varchar [pk]
  "ivsr_tdg_ac_id" varchar
}

Table "ivsr_tdg_ac_fnc_svc" [note: "Dịch vụ tài chính đăng ký trên tài khoản giao dịch (ký quỹ / ứng trước tiền bán / HĐ tài chính khác). FK Investor Trading Account."] {
  "ivsr_tdg_ac_fnc_svc_id" varchar [pk]
  "ivsr_tdg_ac_id" varchar
}

Table "mkt_surveil_ac_grp_anl_rslt" [note: "Kết quả phân tích nhóm tài khoản nghi vấn. FK Market Surveillance Case."] {
  "mkt_surveil_ac_grp_anl_rslt_id" varchar [pk]
  "mkt_surveil_case_id" varchar
}

Table "mkt_surveil_ac_grp_mbr_anl_rslt" [note: "Thành viên nhóm tài khoản trong kết quả phân tích. FK Market Surveillance Case + Investor Account Relationship."] {
  "mkt_surveil_ac_grp_mbr_anl_rslt_id" varchar [pk]
  "mkt_surveil_case_id" varchar
  "ac_ivsr_grp_id" varchar
  "ivsr_ac_rltnp_id" varchar
}

Table "mkt_surveil_ac_rltnp_anl_rslt" [note: "Kết quả phân tích quan hệ giữa tài khoản nghi vấn. FK Market Surveillance Case + Investor Account Relationship."] {
  "mkt_surveil_ac_rltnp_anl_rslt_id" varchar [pk]
  "mkt_surveil_case_id" varchar
  "ivsr_ac_rltnp_id" varchar
}

Table "mkt_surveil_anl_exec_log" [note: "Log thực thi phân tích từng biểu mẫu trong vụ việc giám sát. FK Market Surveillance Case."] {
  "mkt_surveil_anl_exec_log_id" varchar [pk]
  "mkt_surveil_case_id" varchar
}

Table "mkt_surveil_anl_sspcs_ac_snpst" [note: "Snapshot thông tin tài khoản nghi vấn tại thời điểm phân tích biểu mẫu. FK Market Surveillance Case."] {
  "mkt_surveil_anl_sspcs_ac_snpst_id" varchar [pk]
  "mkt_surveil_case_id" varchar
}

Table "mkt_surveil_case" [note: "Vụ việc giám sát giao dịch chứng khoán bất thường. Ghi nhận loại vụ việc, mã CK liên quan, nguồn thông tin và trạng thái xử lý."] {
  "mkt_surveil_case_id" varchar [pk]
}

Table "mkt_surveil_case_aprv_step_log" [note: "Nhật ký phê duyệt từng bước xử lý vụ việc giám sát. Ghi nhận người duyệt, vai trò, trạng thái và thời điểm. FK Market Surveillance Case."] {
  "mkt_surveil_case_aprv_step_log_id" varchar [pk]
  "mkt_surveil_case_id" varchar
}

Table "mkt_surveil_case_workflow_step" [note: "Từng bước quy trình xử lý vụ việc giám sát. Append-only. FK Market Surveillance Case."] {
  "mkt_surveil_case_workflow_step_id" varchar [pk]
  "mkt_surveil_case_id" varchar
}

Table "mkt_surveil_sspcs_ac_anl_rslt" [note: "Kết quả phân tích/kiểm tra tài khoản nghi vấn trong vụ việc giám sát. FK Market Surveillance Case."] {
  "mkt_surveil_sspcs_ac_anl_rslt_id" varchar [pk]
  "mkt_surveil_case_id" varchar
}

Table "mkt_surveil_anl_criterion" [note: "Định nghĩa tiêu chí/công thức phân tích vụ việc giám sát (ngưỡng tỷ lệ, số phiên, v.v.). Grain: 1 dòng = 1 tiêu chí."] {
  "mkt_surveil_anl_criterion_id" varchar [pk]
}

Table "mkt_surveil_anl_criterion_val" [note: "Giá trị cụ thể của tiêu chí phân tích theo từng quy trình. FK Market Surveillance Analysis Criterion."] {
  "mkt_surveil_anl_criterion_val_id" varchar [pk]
  "mkt_surveil_anl_criterion_id" varchar
}

Table "mkt_surveil_cmpln_rpt_tpl" [note: "Định nghĩa loại báo cáo tuân thủ trong hệ thống GSGD (tên báo cáo, kỳ báo cáo). Grain: 1 dòng = 1 loại báo cáo."] {
  "mkt_surveil_cmpln_rpt_tpl_id" varchar [pk]
}

Table "abnormal_tdg_rpt" [note: "Báo cáo giao dịch bất thường do tổ chức thành viên nộp lên UBCKNN. Grain: 1 dòng = 1 báo cáo."] {
  "abnormal_tdg_rpt_id" varchar [pk]
}

Table "abnormal_tdg_rpt_file_attch" [note: "File đính kèm báo cáo giao dịch bất thường (có chữ ký số). FK Abnormal Trading Report."] {
  "abnormal_tdg_rpt_file_attch_id" varchar [pk]
  "abnormal_tdg_rpt_id" varchar
}

Table "mkt_surveil_anl_rpt" [note: "Báo cáo output của quá trình phân tích vụ việc giám sát (report_type"] {
  "mkt_surveil_anl_rpt_id" varchar [pk]
  "mkt_surveil_case_id" varchar
}

Table "mkt_surveil_case_doc_attch" [note: "File đính kèm vụ việc giám sát (tài liệu hồ sơ, danh sách TK nghi vấn). FK Market Surveillance Case."] {
  "mkt_surveil_case_doc_attch_id" varchar [pk]
  "mkt_surveil_case_id" varchar
}

Table "mkt_surveil_cmpln_rpt_clmn_config" [note: "Định nghĩa cấu trúc cột của từng loại báo cáo tuân thủ GSGD. FK Market Surveillance Compliance Report Template."] {
  "mkt_surveil_cmpln_rpt_clmn_config_id" varchar [pk]
  "mkt_surveil_cmpln_rpt_tpl_id" varchar
}

Table "mkt_surveil_cmpln_rpt_instn" [note: "Instance báo cáo tuân thủ theo từng kỳ. FK Market Surveillance Compliance Report Template."] {
  "mkt_surveil_cmpln_rpt_instn_id" varchar [pk]
  "mkt_surveil_cmpln_rpt_tpl_id" varchar
}

Table "mkt_surveil_cmpln_rpt_row_data" [note: "Dữ liệu từng dòng trong báo cáo tuân thủ GSGD (lưu dạng JSON). Grain: 1 dòng = 1 row x 1 kỳ. FK Market Surveillance Compliance Report Instance."] {
  "mkt_surveil_cmpln_rpt_row_data_id" varchar [pk]
  "mkt_surveil_cmpln_rpt_instn_id" varchar
}

Table "list_co_corp_ev" [note: "Sự kiện liên quan đến tổ chức niêm yết trong phạm vi giám sát GSGD. Grain: 1 dòng = 1 sự kiện."] {
  "list_co_corp_ev_id" varchar [pk]
}

Table "mkt_surveil_sspcs_ac" [note: "Tài khoản nghi vấn được xác định trong vụ việc giám sát. FK Market Surveillance Case + Investor Trading Account."] {
  "mkt_surveil_sspcs_ac_id" varchar [pk]
  "mkt_surveil_case_id" varchar
  "ivsr_tdg_ac_id" varchar
}

Table "mkt_surveil_sspcs_ac_grp" [note: "Nhóm tài khoản nghi vấn trong phạm vi 1 vụ việc giám sát cụ thể. FK Market Surveillance Case."] {
  "mkt_surveil_sspcs_ac_grp_id" varchar [pk]
  "mkt_surveil_case_id" varchar
}

Table "ac_ivsr_grp" [note: "Nhóm tài khoản nhà đầu tư do nghiệp vụ giám sát xác định theo tiêu chí quan hệ (Danh tính / IP / MAC / Tiền). Grain: 1 dòng = 1 nhóm."] {
  "ac_ivsr_grp_id" varchar [pk]
}

Table "ac_ivsr_grp_mbr" [note: "Quan hệ thành viên giữa tài khoản nhà đầu tư và nhóm giám sát. Ghi nhận loại quan hệ và trạng thái. FK Account Investor Group + Investor Trading Account."] {
  "ac_ivsr_grp_mbr_id" varchar [pk]
  "ac_ivsr_grp_id" varchar
  "ivsr_tdg_ac_id" varchar
}

Table "scr_watchlist_grp" [note: "Nhóm chứng khoán do nghiệp vụ giám sát tạo ra (thường hoặc theo ngành). Danh sách mã CK denormalize thành ARRAY."] {
  "scr_watchlist_grp_id" varchar [pk]
}

TableGroup "UID01 — Nhóm chức năng: Quản lý thông tin" {
  "ivsr_ac_rltnp"
  "ivsr_tdg_ac"
  "ivsr_tdg_ac_ahr"
  "ivsr_tdg_ac_fnc_svc"
  "mkt_surveil_cmpln_rpt_tpl"
  "abnormal_tdg_rpt"
  "abnormal_tdg_rpt_file_attch"
  "mkt_surveil_cmpln_rpt_clmn_config"
  "mkt_surveil_cmpln_rpt_instn"
  "mkt_surveil_cmpln_rpt_row_data"
  "list_co_corp_ev"
  "ac_ivsr_grp"
  "ac_ivsr_grp_mbr"
  "scr_watchlist_grp"
}

TableGroup "UID02 — Nhóm chức năng: Phân tích chuyên sâu vụ việc" {
  "mkt_surveil_ac_grp_anl_rslt"
  "mkt_surveil_ac_grp_mbr_anl_rslt"
  "mkt_surveil_ac_rltnp_anl_rslt"
  "mkt_surveil_anl_exec_log"
  "mkt_surveil_anl_sspcs_ac_snpst"
  "mkt_surveil_case"
  "mkt_surveil_case_aprv_step_log"
  "mkt_surveil_case_workflow_step"
  "mkt_surveil_sspcs_ac_anl_rslt"
  "mkt_surveil_anl_criterion"
  "mkt_surveil_anl_criterion_val"
  "mkt_surveil_anl_rpt"
  "mkt_surveil_case_doc_attch"
  "mkt_surveil_sspcs_ac"
  "mkt_surveil_sspcs_ac_grp"
}

Ref: "ivsr_ac_rltnp"."frst_ivsr_tdg_ac_id" > "ivsr_tdg_ac"."ivsr_tdg_ac_id"
Ref: "ivsr_ac_rltnp"."scd_ivsr_tdg_ac_id" > "ivsr_tdg_ac"."ivsr_tdg_ac_id"
Ref: "ivsr_ac_rltnp"."ac_ivsr_grp_id" > "ac_ivsr_grp"."ac_ivsr_grp_id"
Ref: "ivsr_tdg_ac_ahr"."ivsr_tdg_ac_id" > "ivsr_tdg_ac"."ivsr_tdg_ac_id"
Ref: "ivsr_tdg_ac_fnc_svc"."ivsr_tdg_ac_id" > "ivsr_tdg_ac"."ivsr_tdg_ac_id"
Ref: "mkt_surveil_ac_grp_anl_rslt"."mkt_surveil_case_id" > "mkt_surveil_case"."mkt_surveil_case_id"
