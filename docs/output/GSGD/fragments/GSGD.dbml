// Silver Lakehouse — GSGD

Project GSGD {
  database_type: "Delta Lake"
  Note: "Silver Lakehouse — GSGD"
}

Table "Investor Trading Account" [note: "Tài khoản giao dịch chứng khoán của nhà đầu tư trong hệ thống GSGD. Grain: 1 dòng = 1 tài khoản (phân biệt theo account_code từ VSDC). Bao gồm cá nhân và tổ chức, trong nước và nước ngoài."] {
  investor_trading_account_id bigint [pk]
}

Table "Account Investor Group" [note: "Nhóm tài khoản nhà đầu tư do nghiệp vụ giám sát xác định theo tiêu chí quan hệ (Danh tính / IP / MAC / Tiền). Grain: 1 dòng = 1 nhóm."] {
  account_investor_group_id bigint [pk]
}

Table "Securities Watchlist Group" [note: "Nhóm chứng khoán do nghiệp vụ giám sát tạo ra (thường hoặc theo ngành). Danh sách mã CK denormalize thành ARRAY."] {
  securities_watchlist_group_id bigint [pk]
}

Table "Market Surveillance Case" [note: "Vụ việc giám sát giao dịch chứng khoán bất thường. Ghi nhận loại vụ việc, mã CK liên quan, nguồn thông tin và trạng thái xử lý."] {
  market_surveillance_case_id bigint [pk]
}

Table "Market Surveillance Analysis Criterion" [note: "Định nghĩa tiêu chí/công thức phân tích vụ việc giám sát (ngưỡng tỷ lệ, số phiên, v.v.). Grain: 1 dòng = 1 tiêu chí."] {
  market_surveillance_analysis_criterion_id bigint [pk]
}

Table "Abnormal Trading Report" [note: "Báo cáo giao dịch bất thường do tổ chức thành viên nộp lên UBCKNN. Grain: 1 dòng = 1 báo cáo."] {
  abnormal_trading_report_id bigint [pk]
}

Table "Market Surveillance Compliance Report Template" [note: "Định nghĩa loại báo cáo tuân thủ trong hệ thống GSGD (tên báo cáo, kỳ báo cáo). Grain: 1 dòng = 1 loại báo cáo."] {
  market_surveillance_compliance_report_template_id bigint [pk]
}

Table "Investor Trading Account Financial Service" [note: "Dịch vụ tài chính đăng ký trên tài khoản giao dịch (ký quỹ / ứng trước tiền bán / HĐ tài chính khác). FK Investor Trading Account."] {
  investor_trading_account_financial_service_id bigint [pk]
  investor_trading_account_id bigint
}

Table "Investor Trading Account Authorization" [note: "Ủy quyền giao dịch chứng khoán trên tài khoản nhà đầu tư. FK Investor Trading Account."] {
  investor_trading_account_authorization_id bigint [pk]
  investor_trading_account_id bigint
}

Table "Account Investor Group Member" [note: "Quan hệ thành viên giữa tài khoản nhà đầu tư và nhóm giám sát. Ghi nhận loại quan hệ và trạng thái. FK Account Investor Group + Investor Trading Account."] {
  account_investor_group_member_id bigint [pk]
  account_investor_group_id bigint
  investor_trading_account_id bigint
}

Table "Investor Account Relationship" [note: "Quan hệ giữa 2 tài khoản nhà đầu tư trong giám sát (IP address, MAC address, chuyển tiền). Ghi nhận độ mạnh quan hệ. FK Investor Trading Account (x2) + Account Investor Group."] {
  investor_account_relationship_id bigint [pk]
  first_investor_trading_account_id bigint
  second_investor_trading_account_id bigint
  account_investor_group_id bigint
}

Table "Listed Company Corporate Event" [note: "Sự kiện liên quan đến tổ chức niêm yết trong phạm vi giám sát GSGD. Grain: 1 dòng = 1 sự kiện."] {
  listed_company_corporate_event_id bigint [pk]
}

Table "Market Surveillance Case Document Attachment" [note: "File đính kèm vụ việc giám sát (tài liệu hồ sơ, danh sách TK nghi vấn). FK Market Surveillance Case."] {
  market_surveillance_case_document_attachment_id bigint [pk]
  market_surveillance_case_id bigint
}

Table "Market Surveillance Case Workflow Step" [note: "Từng bước quy trình xử lý vụ việc giám sát. Append-only. FK Market Surveillance Case."] {
  market_surveillance_case_workflow_step_id bigint [pk]
  market_surveillance_case_id bigint
}

Table "Market Surveillance Case Approval Step Log" [note: "Nhật ký phê duyệt từng bước xử lý vụ việc giám sát. Ghi nhận người duyệt, vai trò, trạng thái và thời điểm. FK Market Surveillance Case."] {
  market_surveillance_case_approval_step_log_id bigint [pk]
  market_surveillance_case_id bigint
}

Table "Market Surveillance Suspicious Account" [note: "Tài khoản nghi vấn được xác định trong vụ việc giám sát. FK Market Surveillance Case + Investor Trading Account."] {
  market_surveillance_suspicious_account_id bigint [pk]
  market_surveillance_case_id bigint
  investor_trading_account_id bigint
}

Table "Market Surveillance Suspicious Account Group" [note: "Nhóm tài khoản nghi vấn trong phạm vi 1 vụ việc giám sát cụ thể. FK Market Surveillance Case."] {
  market_surveillance_suspicious_account_group_id bigint [pk]
  market_surveillance_case_id bigint
}

Table "Market Surveillance Analysis Criterion Value" [note: "Giá trị cụ thể của tiêu chí phân tích theo từng quy trình. FK Market Surveillance Analysis Criterion."] {
  market_surveillance_analysis_criterion_value_id bigint [pk]
  market_surveillance_analysis_criterion_id bigint
}

Table "Market Surveillance Compliance Report Column Config" [note: "Định nghĩa cấu trúc cột của từng loại báo cáo tuân thủ GSGD. FK Market Surveillance Compliance Report Template."] {
  market_surveillance_compliance_report_column_config_id bigint [pk]
  market_surveillance_compliance_report_template_id bigint
}

Table "Market Surveillance Compliance Report Instance" [note: "Instance báo cáo tuân thủ theo từng kỳ. FK Market Surveillance Compliance Report Template."] {
  market_surveillance_compliance_report_instance_id bigint [pk]
  market_surveillance_compliance_report_template_id bigint
}

Table "Abnormal Trading Report File Attachment" [note: "File đính kèm báo cáo giao dịch bất thường (có chữ ký số). FK Abnormal Trading Report."] {
  abnormal_trading_report_file_attachment_id bigint [pk]
  abnormal_trading_report_id bigint
}

Table "Market Surveillance Compliance Report Row Data" [note: "Dữ liệu từng dòng trong báo cáo tuân thủ GSGD (lưu dạng JSON). Grain: 1 dòng = 1 row x 1 kỳ. FK Market Surveillance Compliance Report Instance."] {
  market_surveillance_compliance_report_row_data_id bigint [pk]
  market_surveillance_compliance_report_instance_id bigint
}

Table "Market Surveillance Analysis Execution Log" [note: "Log thực thi phân tích từng biểu mẫu trong vụ việc giám sát. FK Market Surveillance Case."] {
  market_surveillance_analysis_execution_log_id bigint [pk]
  market_surveillance_case_id bigint
}

Table "Market Surveillance Analysis Suspicious Account Snapshot" [note: "Snapshot thông tin tài khoản nghi vấn tại thời điểm phân tích biểu mẫu. FK Market Surveillance Case."] {
  market_surveillance_analysis_suspicious_account_snapshot_id bigint [pk]
  market_surveillance_case_id bigint
}

Table "Market Surveillance Suspicious Account Analysis Result" [note: "Kết quả phân tích/kiểm tra tài khoản nghi vấn trong vụ việc giám sát. FK Market Surveillance Case."] {
  market_surveillance_suspicious_account_analysis_result_id bigint [pk]
  market_surveillance_case_id bigint
}

Table "Market Surveillance Account Relationship Analysis Result" [note: "Kết quả phân tích quan hệ giữa tài khoản nghi vấn. FK Market Surveillance Case + Investor Account Relationship."] {
  market_surveillance_account_relationship_analysis_result_id bigint [pk]
  market_surveillance_case_id bigint
  investor_account_relationship_id bigint
}

Table "Market Surveillance Account Group Analysis Result" [note: "Kết quả phân tích nhóm tài khoản nghi vấn. FK Market Surveillance Case."] {
  market_surveillance_account_group_analysis_result_id bigint [pk]
  market_surveillance_case_id bigint
}

Table "Market Surveillance Account Group Member Analysis Result" [note: "Thành viên nhóm tài khoản trong kết quả phân tích. FK Market Surveillance Case + Investor Account Relationship."] {
  market_surveillance_account_group_member_analysis_result_id bigint [pk]
  market_surveillance_case_id bigint
  account_investor_group_id bigint
  investor_account_relationship_id bigint
}

Table "Market Surveillance Analysis Report" [note: "Báo cáo output của quá trình phân tích vụ việc giám sát (report_type"] {
  market_surveillance_analysis_report_id bigint [pk]
  market_surveillance_case_id bigint
}

TableGroup "UID01 — Nhóm chức năng: Quản lý thông tin" {
  "Investor Trading Account"
  "Account Investor Group"
  "Securities Watchlist Group"
  "Abnormal Trading Report"
  "Market Surveillance Compliance Report Template"
  "Investor Trading Account Financial Service"
  "Investor Trading Account Authorization"
  "Account Investor Group Member"
  "Investor Account Relationship"
  "Listed Company Corporate Event"
  "Market Surveillance Compliance Report Column Config"
  "Market Surveillance Compliance Report Instance"
  "Abnormal Trading Report File Attachment"
  "Market Surveillance Compliance Report Row Data"
}

TableGroup "UID02 — Nhóm chức năng: Phân tích chuyên sâu vụ việc" {
  "Market Surveillance Case"
  "Market Surveillance Analysis Criterion"
  "Market Surveillance Case Document Attachment"
  "Market Surveillance Case Workflow Step"
  "Market Surveillance Case Approval Step Log"
  "Market Surveillance Suspicious Account"
  "Market Surveillance Suspicious Account Group"
  "Market Surveillance Analysis Criterion Value"
  "Market Surveillance Analysis Execution Log"
  "Market Surveillance Analysis Suspicious Account Snapshot"
  "Market Surveillance Suspicious Account Analysis Result"
  "Market Surveillance Account Relationship Analysis Result"
  "Market Surveillance Account Group Analysis Result"
  "Market Surveillance Account Group Member Analysis Result"
  "Market Surveillance Analysis Report"
}

Ref: "Investor Trading Account Financial Service".investor_trading_account_id > "Investor Trading Account".investor_trading_account_id
Ref: "Investor Trading Account Authorization".investor_trading_account_id > "Investor Trading Account".investor_trading_account_id
Ref: "Account Investor Group Member".account_investor_group_id > "Account Investor Group".account_investor_group_id
Ref: "Account Investor Group Member".investor_trading_account_id > "Investor Trading Account".investor_trading_account_id
Ref: "Investor Account Relationship".first_investor_trading_account_id > "Investor Trading Account".investor_trading_account_id
Ref: "Investor Account Relationship".second_investor_trading_account_id > "Investor Trading Account".investor_trading_account_id
Ref: "Investor Account Relationship".account_investor_group_id > "Account Investor Group".account_investor_group_id
Ref: "Market Surveillance Case Document Attachment".market_surveillance_case_id > "Market Surveillance Case".market_surveillance_case_id
Ref: "Market Surveillance Case Workflow Step".market_surveillance_case_id > "Market Surveillance Case".market_surveillance_case_id
