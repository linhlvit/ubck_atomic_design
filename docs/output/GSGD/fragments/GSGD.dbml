Ref: "Market Surveillance Account Group Member Analysis Result".account_investor_group_id > "Account Investor Group".account_investor_group_id
Ref: "Market Surveillance Account Group Member Analysis Result".investor_account_relationship_id > "Investor Account Relationship".investor_account_relationship_id
