Ref: "Market Surveillance Suspicious Account".investor_trading_account_id > "Investor Trading Account".investor_trading_account_id
Ref: "Market Surveillance Suspicious Account Group".market_surveillance_case_id > "Market Surveillance Case".market_surveillance_case_id
Ref: "Market Surveillance Analysis Criterion Value".market_surveillance_analysis_criterion_id > "Market Surveillance Analysis Criterion".market_surveillance_analysis_criterion_id
Ref: "Market Surveillance Compliance Report Column Config".market_surveillance_compliance_report_template_id > "Market Surveillance Compliance Report Template".market_surveillance_compliance_report_template_id
