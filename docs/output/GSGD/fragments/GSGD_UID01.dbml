// GSGD — UID01 Nhóm chức năng: Quản lý thông tin

Project GSGD_UID01 {
  database_type: "Delta Lake"
  Note: "GSGD — UID01 Nhóm chức năng: Quản lý thông tin"
}

Table "Investor Trading Account" [note: "Tài khoản giao dịch chứng khoán của nhà đầu tư trong hệ thống GSGD. Grain: 1 dòng = 1 tài khoản (phân biệt theo account_code từ VSDC). Bao gồm cá nhân và tổ chức, trong nước và nước ngoài."] {
  "Investor Trading Account Id" varchar [pk]
}

Table "Account Investor Group" [note: "Nhóm tài khoản nhà đầu tư do nghiệp vụ giám sát xác định theo tiêu chí quan hệ (Danh tính / IP / MAC / Tiền). Grain: 1 dòng = 1 nhóm."] {
  "Account Investor Group Id" varchar [pk]
}

Table "Securities Watchlist Group" [note: "Nhóm chứng khoán do nghiệp vụ giám sát tạo ra (thường hoặc theo ngành). Danh sách mã CK denormalize thành ARRAY."] {
  "Securities Watchlist Group Id" varchar [pk]
}

Table "Abnormal Trading Report" [note: "Báo cáo giao dịch bất thường do tổ chức thành viên nộp lên UBCKNN. Grain: 1 dòng = 1 báo cáo."] {
  "Abnormal Trading Report Id" varchar [pk]
}

Table "Market Surveillance Compliance Report Template" [note: "Định nghĩa loại báo cáo tuân thủ trong hệ thống GSGD (tên báo cáo, kỳ báo cáo). Grain: 1 dòng = 1 loại báo cáo."] {
  "Market Surveillance Compliance Report Template Id" varchar [pk]
}

Table "Investor Trading Account Financial Service" [note: "Dịch vụ tài chính đăng ký trên tài khoản giao dịch (ký quỹ / ứng trước tiền bán / HĐ tài chính khác). FK Investor Trading Account."] {
  "Investor Trading Account Financial Service Id" varchar [pk]
  "Investor Trading Account Id" varchar
}

Table "Investor Trading Account Authorization" [note: "Ủy quyền giao dịch chứng khoán trên tài khoản nhà đầu tư. FK Investor Trading Account."] {
  "Investor Trading Account Authorization Id" varchar [pk]
  "Investor Trading Account Id" varchar
}

Table "Account Investor Group Member" [note: "Quan hệ thành viên giữa tài khoản nhà đầu tư và nhóm giám sát. Ghi nhận loại quan hệ và trạng thái. FK Account Investor Group + Investor Trading Account."] {
  "Account Investor Group Member Id" varchar [pk]
  "Account Investor Group Id" varchar
  "Investor Trading Account Id" varchar
}

Table "Investor Account Relationship" [note: "Quan hệ giữa 2 tài khoản nhà đầu tư trong giám sát (IP address, MAC address, chuyển tiền). Ghi nhận độ mạnh quan hệ. FK Investor Trading Account (x2) + Account Investor Group."] {
  "Investor Account Relationship Id" varchar [pk]
  "First Investor Trading Account Id" varchar
  "Second Investor Trading Account Id" varchar
  "Account Investor Group Id" varchar
}

Table "Listed Company Corporate Event" [note: "Sự kiện liên quan đến tổ chức niêm yết trong phạm vi giám sát GSGD. Grain: 1 dòng = 1 sự kiện."] {
  "Listed Company Corporate Event Id" varchar [pk]
}

Table "Market Surveillance Compliance Report Column Config" [note: "Định nghĩa cấu trúc cột của từng loại báo cáo tuân thủ GSGD. FK Market Surveillance Compliance Report Template."] {
  "Market Surveillance Compliance Report Column Config Id" varchar [pk]
  "Market Surveillance Compliance Report Template Id" varchar
}

Table "Market Surveillance Compliance Report Instance" [note: "Instance báo cáo tuân thủ theo từng kỳ. FK Market Surveillance Compliance Report Template."] {
  "Market Surveillance Compliance Report Instance Id" varchar [pk]
  "Market Surveillance Compliance Report Template Id" varchar
}

Table "Abnormal Trading Report File Attachment" [note: "File đính kèm báo cáo giao dịch bất thường (có chữ ký số). FK Abnormal Trading Report."] {
  "Abnormal Trading Report File Attachment Id" varchar [pk]
  "Abnormal Trading Report Id" varchar
}

Table "Market Surveillance Compliance Report Row Data" [note: "Dữ liệu từng dòng trong báo cáo tuân thủ GSGD (lưu dạng JSON). Grain: 1 dòng = 1 row x 1 kỳ. FK Market Surveillance Compliance Report Instance."] {
  "Market Surveillance Compliance Report Row Data Id" varchar [pk]
  "Market Surveillance Compliance Report Instance Id" varchar
}

Ref: "Investor Trading Account Financial Service"."Investor Trading Account Id" > "Investor Trading Account"."Investor Trading Account Id"
Ref: "Investor Trading Account Authorization"."Investor Trading Account Id" > "Investor Trading Account"."Investor Trading Account Id"
Ref: "Account Investor Group Member"."Account Investor Group Id" > "Account Investor Group"."Account Investor Group Id"
Ref: "Account Investor Group Member"."Investor Trading Account Id" > "Investor Trading Account"."Investor Trading Account Id"
Ref: "Investor Account Relationship"."First Investor Trading Account Id" > "Investor Trading Account"."Investor Trading Account Id"
Ref: "Investor Account Relationship"."Second Investor Trading Account Id" > "Investor Trading Account"."Investor Trading Account Id"
Ref: "Investor Account Relationship"."Account Investor Group Id" > "Account Investor Group"."Account Investor Group Id"
Ref: "Market Surveillance Compliance Report Column Config"."Market Surveillance Compliance Report Template Id" > "Market Surveillance Compliance Report Template"."Market Surveillance Compliance Report Template Id"
Ref: "Market Surveillance Compliance Report Instance"."Market Surveillance Compliance Report Template Id" > "Market Surveillance Compliance Report Template"."Market Surveillance Compliance Report Template Id"
Ref: "Abnormal Trading Report File Attachment"."Abnormal Trading Report Id" > "Abnormal Trading Report"."Abnormal Trading Report Id"
Ref: "Market Surveillance Compliance Report Row Data"."Market Surveillance Compliance Report Instance Id" > "Market Surveillance Compliance Report Instance"."Market Surveillance Compliance Report Instance Id"
