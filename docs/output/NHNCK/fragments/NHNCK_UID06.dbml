// NHNCK — UID06 Quản lý người hành nghề chứng khoán

Project NHNCK_UID06 {
  database_type: "Delta Lake"
  Note: "NHNCK — UID06 Quản lý người hành nghề chứng khoán"
}

Table "Securities Practitioner" [note: "Người hành nghề chứng khoán được UBCKNN cấp phép. Ghi nhận thông tin cá nhân và trạng thái hành nghề. Attribute chi tiết (BirthDate full"] {
  "Practitioner Id" varchar [pk]
  "Country of Residence Geographic Area Id" varchar
  "Securities Company Id" varchar
}

Table "Securities Practitioner Related Party" [note: "Quan hệ thân nhân của người hành nghề chứng khoán. Ghi nhận loại quan hệ và thông tin người liên quan."] {
  "Securities Practitioner Related Party Id" varchar [pk]
  "Practitioner Id" varchar
}

Table "Securities Practitioner Conduct Violation" [note: "Vi phạm pháp luật hoặc hành chính của người hành nghề chứng khoán. Ghi nhận loại vi phạm và quyết định xử lý."] {
  "Conduct Violation Id" varchar [pk]
  "Practitioner Id" varchar
  "License Decision Document Id" varchar
  "Created By Officer Id" varchar
  "Updated By Officer Id" varchar
}

Table "Securities Organization Reference" [note: "Tổ chức tham gia thị trường chứng khoán (CTCK/QLQ/NH) được UBCKNN quản lý. Danh mục tổ chức tham chiếu trong hệ thống NHNCK."] {
  "Securities Organization Reference Id" varchar [pk]
  "Parent Organization Id" varchar
  "Created By Officer Id" varchar
}

// Ref: "Securities Practitioner"."Country of Residence Geographic Area Id" > "Geographic Area"."Geographic Area Id" // out-of-source
// Ref: "Securities Practitioner"."Securities Company Id" > "Securities Company"."Securities Company Id" // out-of-source
Ref: "Securities Practitioner Related Party"."Practitioner Id" > "Securities Practitioner"."Practitioner Id"
Ref: "Securities Practitioner Conduct Violation"."Practitioner Id" > "Securities Practitioner"."Practitioner Id"
// Ref: "Securities Practitioner Conduct Violation"."License Decision Document Id" > "Securities Practitioner License Decision Document"."License Decision Document Id" // out-of-source
// Ref: "Securities Practitioner Conduct Violation"."Created By Officer Id" > "Regulatory Authority Officer"."Officer Id" // out-of-source
// Ref: "Securities Practitioner Conduct Violation"."Updated By Officer Id" > "Regulatory Authority Officer"."Officer Id" // out-of-source
Ref: "Securities Organization Reference"."Parent Organization Id" > "Securities Organization Reference"."Securities Organization Reference Id"
// Ref: "Securities Organization Reference"."Created By Officer Id" > "Regulatory Authority Officer"."Officer Id" // out-of-source
