// Atomic Lakehouse — NHNCK

Project NHNCK {
  database_type: "Delta Lake"
  Note: "Atomic Lakehouse — NHNCK"
}

Table "scr_prac_conduct_vln" [note: "Vi phạm pháp luật hoặc hành chính của người hành nghề chứng khoán. Ghi nhận loại vi phạm và quyết định xử lý."] {
  "conduct_vln_id" varchar [pk]
  "prac_id" varchar
  "license_dcsn_doc_id" varchar
  "crt_by_ofcr_id" varchar
  "udt_by_ofcr_id" varchar
}

Table "scr_prac_license_ap_pcs_avy_log" [note: "Nhật ký hoạt động xử lý hồ sơ CCHN. Ghi nhận từng bước xử lý và trạng thái hồ sơ theo thời gian."] {
  "license_ap_pcs_avy_log_id" varchar [pk]
  "ofcr_id" varchar
}

Table "scr_prac_license_ap_verf_st" [note: "Bản ghi phê duyệt nội bộ hồ sơ CCHN theo cấp lãnh đạo. Ghi nhận người phê duyệt và kết quả phê duyệt tại từng cấp."] {
  "license_ap_verf_st_id" varchar [pk]
  "license_ap_id" varchar
  "verf_by_ofcr_id" varchar
  "crt_by_ofcr_id" varchar
  "udt_by_ofcr_id" varchar
}

Table "scr_prac_license_ctf_doc_avy_log" [note: "Nhật ký hoạt động tác động lên chứng chỉ hành nghề. Ghi nhận hành động và người thực hiện."] {
  "license_ctf_doc_avy_log_id" varchar [pk]
  "license_ctf_doc_id" varchar
  "license_dcsn_doc_id" varchar
  "pcs_by_ofcr_id" varchar
}

Table "scr_prac_license_ctf_doc_st_hist" [note: "Lịch sử thay đổi trạng thái của chứng chỉ hành nghề. Ghi nhận trạng thái trước/sau và lý do thay đổi."] {
  "license_ctf_doc_st_hist_id" varchar [pk]
  "license_ctf_doc_id" varchar
  "license_dcsn_doc_id" varchar
}

Table "scr_prac_prof_trn_clss_enrollment" [note: "Đăng ký tham gia và kết quả học tập của người hành nghề tại một khóa đào tạo chuyên môn."] {
  "prof_trn_clss_enrollment_id" varchar [pk]
  "prof_trn_clss_id" varchar
  "prac_id" varchar
  "assignee_ofcr_id" varchar
  "crt_by_ofcr_id" varchar
  "udt_by_ofcr_id" varchar
}

Table "scr_prac_id_verf_rcrd" [note: "Kết quả xác thực danh tính người hành nghề qua hệ thống C06 của Bộ Công An. Lưu trạng thái và phản hồi xác thực."] {
  "id_verf_rcrd_id" varchar [pk]
  "udt_by_ofcr_id" varchar
}

Table "scr_prac_qualf_exam_ases" [note: "Đợt thi sát hạch cấp chứng chỉ hành nghề chứng khoán. Ghi nhận thông tin tổ chức đợt thi và quyết định công nhận kết quả."] {
  "exam_ases_id" varchar [pk]
  "license_dcsn_doc_id" varchar
  "crt_by_ofcr_id" varchar
}

Table "scr_prac_qualf_exam_ases_rslt" [note: "Kết quả thi sát hạch của từng thí sinh trong một đợt thi. Ghi nhận điểm thi và kết quả đạt/không đạt."] {
  "exam_ases_rslt_id" varchar [pk]
  "exam_ases_id" varchar
  "prac_id" varchar
  "license_ap_id" varchar
  "crt_by_ofcr_id" varchar
}

Table "scr_prac_qualf_exam_ases_fee" [note: "Biểu phí thi sát hạch theo đợt thi và loại chứng chỉ. Ghi nhận mức phí thi và phúc khảo."] {
  "exam_ases_fee_id" varchar [pk]
  "exam_ases_id" varchar
  "crt_by_ofcr_id" varchar
  "udt_by_ofcr_id" varchar
}

Table "scr_prac_license_ap" [note: "Hồ sơ đăng ký cấp/cấp lại/gia hạn chứng chỉ hành nghề chứng khoán. Ghi nhận đầy đủ thông tin người nộp và kết quả xử lý."] {
  "license_ap_id" varchar [pk]
  "prac_id" varchar
  "license_ctf_doc_id" varchar
  "prev_license_ctf_doc_id" varchar
  "exam_ases_id" varchar
  "assignee_ofcr_id" varchar
  "license_ap_verf_st_id" varchar
  "crt_by_ofcr_id" varchar
  "udt_by_ofcr_id" varchar
}

Table "scr_prac_license_ap_doc_attch" [note: "Tài liệu đính kèm hồ sơ CCHN. Ghi nhận loại tài liệu và trạng thái thẩm định."] {
  "license_ap_doc_attch_id" varchar [pk]
  "license_ap_id" varchar
  "assignee_ofcr_id" varchar
}

Table "scr_prac_license_ap_ed_ctf_doc" [note: "Văn bằng/chứng chỉ học tập đính kèm hồ sơ CCHN. Ghi nhận loại chuyên môn và file đính kèm kèm trạng thái thẩm định."] {
  "license_ap_ed_ctf_doc_id" varchar [pk]
  "license_ap_id" varchar
  "assignee_ofcr_id" varchar
}

Table "scr_prac_license_ctf_doc" [note: "Chứng chỉ hành nghề chứng khoán được cấp cho người hành nghề. Ghi nhận loại chứng chỉ và quyết định cấp/thu hồi."] {
  "license_ctf_doc_id" varchar [pk]
  "prac_id" varchar
  "issn_dcsn_doc_id" varchar
  "revocation_dcsn_doc_id" varchar
  "cncl_dcsn_doc_id" varchar
  "crt_by_ofcr_id" varchar
}

Table "scr_prac_license_ctf_grp_doc" [note: "Nhóm chứng chỉ hành nghề trong một quyết định cấp/thu hồi/hủy tập thể. Liên kết với quyết định hành chính."] {
  "license_ctf_grp_doc_id" varchar [pk]
  "license_dcsn_doc_id" varchar
}

Table "scr_prac_license_ctf_grp_mbr" [note: "Quan hệ thành viên giữa chứng chỉ hành nghề và nhóm cấp/thu hồi. Liên kết Certificate ↔ Group ↔ Application."] {
  "license_ctf_grp_mbr_id" varchar [pk]
  "license_ctf_grp_doc_id" varchar
  "license_ctf_doc_id" varchar
}

Table "scr_prac_license_dcsn_doc" [note: "Quyết định hành chính của UBCKNN về cấp/thu hồi/hủy chứng chỉ hành nghề chứng khoán."] {
  "license_dcsn_doc_id" varchar [pk]
  "crt_by_ofcr_id" varchar
}

Table "scr_prac_org_emp_rpt" [note: "Báo cáo của tổ chức về tình trạng tuyển dụng/chấm dứt hợp đồng người hành nghề chứng khoán."] {
  "org_emp_rpt_id" varchar [pk]
  "prac_id" varchar
  "scr_org_id" varchar
  "license_ctf_doc_id" varchar
  "prn_org_emp_rpt_id" varchar
  "crt_by_ofcr_id" varchar
}

Table "scr_prac_prof_trn_clss" [note: "Khóa đào tạo chuyên môn nghiệp vụ chứng khoán do UBCKNN tổ chức. Ghi nhận thông tin khóa học và ngày thi."] {
  "prof_trn_clss_id" varchar [pk]
  "crt_by_ofcr_id" varchar
  "udt_by_ofcr_id" varchar
}

Table "reg_ahr_ou" [note: "Đơn vị/phòng ban thuộc UBCKNN. Cấu trúc phân cấp gộp Units và Departments."] {
  "ou_id" varchar [pk]
  "prn_ou_id" varchar
}

Table "scr_org_refr" [note: "Tổ chức tham gia thị trường chứng khoán (CTCK/QLQ/NH) được UBCKNN quản lý. Danh mục tổ chức tham chiếu trong hệ thống NHNCK."] {
  "scr_org_refr_id" varchar [pk]
  "prn_org_id" varchar
  "crt_by_ofcr_id" varchar
}

Table "scr_prac" [note: "Người hành nghề chứng khoán được UBCKNN cấp phép. Ghi nhận thông tin cá nhân và trạng thái hành nghề. Attribute chi tiết (BirthDate full"] {
  "prac_id" varchar [pk]
  "cty_of_rsdnc_geo_id" varchar
  "scr_co_id" varchar
}

Table "scr_prac_rel_p" [note: "Quan hệ thân nhân của người hành nghề chứng khoán. Ghi nhận loại quan hệ và thông tin người liên quan."] {
  "scr_prac_rel_p_id" varchar [pk]
  "prac_id" varchar
}

Table "scr_prac_license_ap_fee" [note: "Phí thực tế phát sinh theo từng hồ sơ đăng ký CCHN. Ghi nhận loại phí và trạng thái thanh toán."] {
  "license_ap_fee_id" varchar [pk]
  "license_ap_id" varchar
  "prac_id" varchar
  "crt_by_ofcr_id" varchar
}

Table "ip_alt_identn" [note: "Lưu trữ các giấy tờ định danh thay thế của Involved Party (CMND/CCCD/Hộ chiếu/Giấy phép kinh doanh/Chứng chỉ hành nghề). Mỗi dòng = 1 loại giấy tờ từ 1 nguồn."] {
  "ip_id" varchar
}

Table "ip_elc_adr" [note: "Lưu trữ các địa chỉ liên lạc điện tử của Involved Party (điện thoại/fax/email). Mỗi dòng = 1 kênh liên lạc từ 1 nguồn."] {
  "ip_id" varchar
}

Table "ip_pst_adr" [note: "Lưu trữ các địa chỉ bưu chính của Involved Party (trụ sở/kinh doanh/thường trú/nơi ở hiện tại). Mỗi dòng = 1 loại địa chỉ từ 1 nguồn."] {
  "ip_id" varchar
}

TableGroup "UID01 — Quản trị phân hệ" {
  "reg_ahr_ou"
}

TableGroup "UID02 — Quản lý danh mục dùng riêng" {
  "scr_prac_license_dcsn_doc"
  "scr_org_refr"
}

TableGroup "UID03 — Quản lý hồ sơ" {
  "scr_prac_license_ap"
}

TableGroup "UID04 — Quản lý thi sát hạch" {
  "scr_prac"
}

TableGroup "UID05 — Quản lý chứng chỉ hành nghề" {
  "scr_prac"
}

TableGroup "UID06 — Quản lý người hành nghề chứng khoán" {
  "scr_prac_conduct_vln"
  "scr_org_refr"
  "scr_prac"
  "scr_prac_rel_p"
}

TableGroup "UID10 — Quản lý đào tạo tập huấn" {
  "scr_prac_license_dcsn_doc"
  "reg_ahr_ou"
  "scr_org_refr"
}

