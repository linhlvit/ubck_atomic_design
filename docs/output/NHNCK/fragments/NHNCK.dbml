// Silver Lakehouse — NHNCK

Project NHNCK {
  database_type: "Delta Lake"
  Note: "Silver Lakehouse — NHNCK"
}

Table "Securities Practitioner License Application" [note: "Hồ sơ đăng ký cấp/cấp lại/gia hạn chứng chỉ hành nghề chứng khoán. Ghi nhận đầy đủ thông tin người nộp và kết quả xử lý."] {
  "License Application Id" varchar [pk]
  "Practitioner Id" varchar
  "License Certificate Document Id" varchar
  "Previous License Certificate Document Id" varchar
  "Examination Assessment Id" varchar
  "Assignee Officer Id" varchar
  "License Application Verification Status Id" varchar
  "Created By Officer Id" varchar
  "Updated By Officer Id" varchar
}

Table "Securities Practitioner License Application Education Certificate Document" [note: "Văn bằng/chứng chỉ học tập đính kèm hồ sơ CCHN. Ghi nhận loại chuyên môn và file đính kèm kèm trạng thái thẩm định."] {
  "License Application Education Certificate Document Id" varchar [pk]
  "License Application Id" varchar
  "Assignee Officer Id" varchar
}

Table "Securities Practitioner License Application Document Attachment" [note: "Tài liệu đính kèm hồ sơ CCHN. Ghi nhận loại tài liệu và trạng thái thẩm định."] {
  "License Application Document Attachment Id" varchar [pk]
  "License Application Id" varchar
  "Assignee Officer Id" varchar
}

Table "Securities Practitioner License Application Processing Activity Log" [note: "Nhật ký hoạt động xử lý hồ sơ CCHN. Ghi nhận từng bước xử lý và trạng thái hồ sơ theo thời gian."] {
  "License Application Processing Activity Log Id" varchar [pk]
  "Officer Id" varchar
}

Table "Securities Practitioner License Application Fee" [note: "Phí thực tế phát sinh theo từng hồ sơ đăng ký CCHN. Ghi nhận loại phí và trạng thái thanh toán."] {
  "License Application Fee Id" varchar [pk]
  "License Application Id" varchar
  "Practitioner Id" varchar
  "Created By Officer Id" varchar
}

Table "Securities Practitioner License Application Verification Status" [note: "Bản ghi phê duyệt nội bộ hồ sơ CCHN theo cấp lãnh đạo. Ghi nhận người phê duyệt và kết quả phê duyệt tại từng cấp."] {
  "License Application Verification Status Id" varchar [pk]
  "License Application Id" varchar
  "Verified By Officer Id" varchar
  "Created By Officer Id" varchar
  "Updated By Officer Id" varchar
}

Table "Securities Practitioner" [note: "Người hành nghề chứng khoán được UBCKNN cấp phép. Ghi nhận thông tin cá nhân và trạng thái hành nghề. Attribute chi tiết (BirthDate full"] {
  "Practitioner Id" varchar [pk]
  "Country of Residence Geographic Area Id" varchar
  "Securities Company Id" varchar
}

Table "Involved Party Postal Address" [note: "Lưu trữ các địa chỉ bưu chính của Involved Party (trụ sở/kinh doanh/thường trú/nơi ở hiện tại). Mỗi dòng = 1 loại địa chỉ từ 1 nguồn."] {
  "Involved Party Id" varchar
}

Table "Involved Party Electronic Address" [note: "Lưu trữ các địa chỉ liên lạc điện tử của Involved Party (điện thoại/fax/email). Mỗi dòng = 1 kênh liên lạc từ 1 nguồn."] {
  "Involved Party Id" varchar
}

Table "Involved Party Alternative Identification" [note: "Lưu trữ các giấy tờ định danh thay thế của Involved Party (CMND/CCCD/Hộ chiếu/Giấy phép kinh doanh/Chứng chỉ hành nghề). Mỗi dòng = 1 loại giấy tờ từ 1 nguồn."] {
  "Involved Party Id" varchar
}

Table "Securities Practitioner License Certificate Document" [note: "Chứng chỉ hành nghề chứng khoán được cấp cho người hành nghề. Ghi nhận loại chứng chỉ và quyết định cấp/thu hồi."] {
  "License Certificate Document Id" varchar [pk]
  "Practitioner Id" varchar
  "Issuance Decision Document Id" varchar
  "Revocation Decision Document Id" varchar
  "Cancellation Decision Document Id" varchar
  "Created By Officer Id" varchar
}

Table "Securities Practitioner License Certificate Group Document" [note: "Nhóm chứng chỉ hành nghề trong một quyết định cấp/thu hồi/hủy tập thể. Liên kết với quyết định hành chính."] {
  "License Certificate Group Document Id" varchar [pk]
  "License Decision Document Id" varchar
}

Table "Securities Practitioner License Certificate Group Member" [note: "Quan hệ thành viên giữa chứng chỉ hành nghề và nhóm cấp/thu hồi. Liên kết Certificate ↔ Group ↔ Application."] {
  "License Certificate Group Member Id" varchar [pk]
  "License Certificate Group Document Id" varchar
  "License Certificate Document Id" varchar
}

Table "Securities Practitioner License Certificate Document Status History" [note: "Lịch sử thay đổi trạng thái của chứng chỉ hành nghề. Ghi nhận trạng thái trước/sau và lý do thay đổi."] {
  "License Certificate Document Status History Id" varchar [pk]
  "License Certificate Document Id" varchar
  "License Decision Document Id" varchar
}

Table "Securities Practitioner License Certificate Document Activity Log" [note: "Nhật ký hoạt động tác động lên chứng chỉ hành nghề. Ghi nhận hành động và người thực hiện."] {
  "License Certificate Document Activity Log Id" varchar [pk]
  "License Certificate Document Id" varchar
  "License Decision Document Id" varchar
  "Processed By Officer Id" varchar
}

Table "Securities Practitioner Related Party" [note: "Quan hệ thân nhân của người hành nghề chứng khoán. Ghi nhận loại quan hệ và thông tin người liên quan."] {
  "Securities Practitioner Related Party Id" varchar [pk]
  "Practitioner Id" varchar
}

Table "Securities Practitioner Conduct Violation" [note: "Vi phạm pháp luật hoặc hành chính của người hành nghề chứng khoán. Ghi nhận loại vi phạm và quyết định xử lý."] {
  "Conduct Violation Id" varchar [pk]
  "Practitioner Id" varchar
  "License Decision Document Id" varchar
  "Created By Officer Id" varchar
  "Updated By Officer Id" varchar
}

Table "Securities Practitioner Organization Employment Report" [note: "Báo cáo của tổ chức về tình trạng tuyển dụng/chấm dứt hợp đồng người hành nghề chứng khoán."] {
  "Organization Employment Report Id" varchar [pk]
  "Practitioner Id" varchar
  "Securities Organization Id" varchar
  "License Certificate Document Id" varchar
  "Parent Organization Employment Report Id" varchar
  "Created By Officer Id" varchar
}

Table "Securities Practitioner Identity Verification Record" [note: "Kết quả xác thực danh tính người hành nghề qua hệ thống C06 của Bộ Công An. Lưu trạng thái và phản hồi xác thực."] {
  "Identity Verification Record Id" varchar [pk]
  "Updated By Officer Id" varchar
}

Table "Securities Practitioner Professional Training Class" [note: "Khóa đào tạo chuyên môn nghiệp vụ chứng khoán do UBCKNN tổ chức. Ghi nhận thông tin khóa học và ngày thi."] {
  "Professional Training Class Id" varchar [pk]
  "Created By Officer Id" varchar
  "Updated By Officer Id" varchar
}

Table "Securities Practitioner Professional Training Class Enrollment" [note: "Đăng ký tham gia và kết quả học tập của người hành nghề tại một khóa đào tạo chuyên môn."] {
  "Professional Training Class Enrollment Id" varchar [pk]
  "Professional Training Class Id" varchar
  "Practitioner Id" varchar
  "Assignee Officer Id" varchar
  "Created By Officer Id" varchar
  "Updated By Officer Id" varchar
}

Table "Securities Practitioner Qualification Examination Assessment" [note: "Đợt thi sát hạch cấp chứng chỉ hành nghề chứng khoán. Ghi nhận thông tin tổ chức đợt thi và quyết định công nhận kết quả."] {
  "Examination Assessment Id" varchar [pk]
  "License Decision Document Id" varchar
  "Created By Officer Id" varchar
}

Table "Securities Practitioner Qualification Examination Assessment Result" [note: "Kết quả thi sát hạch của từng thí sinh trong một đợt thi. Ghi nhận điểm thi và kết quả đạt/không đạt."] {
  "Examination Assessment Result Id" varchar [pk]
  "Examination Assessment Id" varchar
  "Practitioner Id" varchar
  "License Application Id" varchar
  "Created By Officer Id" varchar
}

Table "Securities Practitioner Qualification Examination Assessment Fee" [note: "Biểu phí thi sát hạch theo đợt thi và loại chứng chỉ. Ghi nhận mức phí thi và phúc khảo."] {
  "Examination Assessment Fee Id" varchar [pk]
  "Examination Assessment Id" varchar
  "Created By Officer Id" varchar
  "Updated By Officer Id" varchar
}

Table "Securities Organization Reference" [note: "Tổ chức tham gia thị trường chứng khoán (CTCK/QLQ/NH) được UBCKNN quản lý. Danh mục tổ chức tham chiếu trong hệ thống NHNCK."] {
  "Securities Organization Reference Id" varchar [pk]
  "Parent Organization Id" varchar
  "Created By Officer Id" varchar
}

Table "Securities Practitioner License Decision Document" [note: "Quyết định hành chính của UBCKNN về cấp/thu hồi/hủy chứng chỉ hành nghề chứng khoán."] {
  "License Decision Document Id" varchar [pk]
  "Created By Officer Id" varchar
}

Table "Regulatory Authority Organization Unit" [note: "Đơn vị/phòng ban thuộc UBCKNN. Cấu trúc phân cấp gộp Units và Departments."] {
  "Organization Unit Id" varchar [pk]
  "Parent Organization Unit Id" varchar
}

TableGroup "UID01 — Quản trị phân hệ" {
  "Regulatory Authority Organization Unit"
}

TableGroup "UID02 — Quản lý danh mục dùng riêng" {
  "Securities Organization Reference"
  "Securities Practitioner License Decision Document"
}

TableGroup "UID03 — Quản lý hồ sơ" {
  "Securities Practitioner License Application"
}

TableGroup "UID04 — Quản lý thi sát hạch" {
  "Securities Practitioner"
}

TableGroup "UID05 — Quản lý chứng chỉ hành nghề" {
  "Securities Practitioner"
}

TableGroup "UID06 — Quản lý người hành nghề chứng khoán" {
  "Securities Practitioner"
  "Securities Practitioner Related Party"
  "Securities Practitioner Conduct Violation"
  "Securities Organization Reference"
}

TableGroup "UID10 — Quản lý đào tạo tập huấn" {
  "Securities Organization Reference"
  "Securities Practitioner License Decision Document"
  "Regulatory Authority Organization Unit"
}

