// NHNCK — UID10 Quản lý đào tạo tập huấn

Project NHNCK_UID10 {
  database_type: "Delta Lake"
  Note: "NHNCK — UID10 Quản lý đào tạo tập huấn"
}

Table "scr_prac_license_dcsn_doc" [note: "Quyết định hành chính của UBCKNN về cấp/thu hồi/hủy chứng chỉ hành nghề chứng khoán."] {
  "license_dcsn_doc_id" varchar [pk]
  "crt_by_ofcr_id" varchar
}

Table "reg_ahr_ou" [note: "Đơn vị/phòng ban thuộc UBCKNN. Cấu trúc phân cấp gộp Units và Departments."] {
  "ou_id" varchar [pk]
  "prn_ou_id" varchar
}

Table "scr_org_refr" [note: "Tổ chức tham gia thị trường chứng khoán (CTCK/QLQ/NH) được UBCKNN quản lý. Danh mục tổ chức tham chiếu trong hệ thống NHNCK."] {
  "scr_org_refr_id" varchar [pk]
  "prn_org_id" varchar
  "crt_by_ofcr_id" varchar
}

// Ref: "scr_prac_license_dcsn_doc"."crt_by_ofcr_id" > ""."" // out-of-source
Ref: "reg_ahr_ou"."prn_ou_id" > "reg_ahr_ou"."ou_id"
Ref: "scr_org_refr"."prn_org_id" > "scr_org_refr"."scr_org_refr_id"
// Ref: "scr_org_refr"."crt_by_ofcr_id" > ""."" // out-of-source
